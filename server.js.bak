// Research endpoints
app.get('/api/research', async (req, res) => {
  const fs = require('fs');
  const path = require('path');
  const researchDir = path.join(__dirname, 'research');
  
  try {
    if (!fs.existsSync(researchDir)) return res.json({ files: [] });
    
    const files = fs.readdirSync(researchDir)
      .filter(f => f.endsWith('.md'))
      .map(f => ({ name: f.replace('.md', ''), path: f }));
    
    res.json({ files });
  } catch (err) {
    res.json({ files: [], error: err.message });
  }
});

app.get('/api/research/:company', async (req, res) => {
  const fs = require('fs');
  const path = require('path');
  const { company } = req.params;
  const filePath = path.join(__dirname, 'research', `${company}.md`);
  
  try {
    if (!fs.existsSync(filePath)) return res.status(404).json({ error: 'Not found' });
    const content = fs.readFileSync(filePath, 'utf8');
    res.json({ company, content });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Response times (use data from imann_positive_replies if available)
app.get('/api/response-times/stats', async (req, res) => {
  try {
    const { initSupabase } = require('./lib/supabase');
    const client = initSupabase();
    
    if (!client) {
      return res.json({ 
        daily: [], weekly: {}, monthly: [], 
        first_response: {}, follow_up_response: {}, overall_response: {},
        all_time_distribution: {}, alerts: { inboxes: [] }, per_campaign: []
      });
    }
    
    // Get response time data from leads
    const { data } = await client.from('imann_positive_replies').select('*').not('response_time_seconds', 'is', null);
    const leads = data || [];
    
    // Calculate distribution
    const dist = { under_5min: 0, under_15min: 0, under_1hr: 0, under_3hr: 0, under_6hr: 0, under_12hr: 0, under_24hr: 0, over_24hr: 0 };
    let totalSeconds = 0;
    
    for (const l of leads) {
      const s = l.response_time_seconds || 0;
      totalSeconds += s;
      if (s < 300) dist.under_5min++;
      else if (s < 900) dist.under_15min++;
      else if (s < 3600) dist.under_1hr++;
      else if (s < 10800) dist.under_3hr++;
      else if (s < 21600) dist.under_6hr++;
      else if (s < 43200) dist.under_12hr++;
      else if (s < 86400) dist.under_24hr++;
      else dist.over_24hr++;
    }
    
    const avgSeconds = leads.length > 0 ? Math.round(totalSeconds / leads.length) : 0;
    
    res.json({
      daily: [],
      weekly: {},
      monthly: [],
      first_response: { avg_seconds: avgSeconds, total: leads.length },
      follow_up_response: {},
      overall_response: { avg_seconds: avgSeconds, total: leads.length, ...dist },
      all_time_distribution: dist,
      alerts: { inboxes: [] },
      per_campaign: []
    });
  } catch (err) {
    res.json({ 
      daily: [], weekly: {}, monthly: [], 
      first_response: {}, follow_up_response: {}, overall_response: {},
      all_time_distribution: {}, alerts: { inboxes: [] }, per_campaign: [],
      error: err.message
    });
  }
});

