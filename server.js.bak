// Stale Leads
app.get('/api/stale-leads', async (req, res) => {
  try {
    const { initSupabase } = require('./lib/supabase');
    const client = initSupabase();
    if (!client) return res.json({ leads: [], total: 0, summary: { critical: 0, warm: 0, recent: 0 } });
    
    const { data } = await client
      .from('imann_positive_replies')
      .select('*')
      .not('status', 'eq', 'Booked')
      .order('created_at', { ascending: true });
    
    // Calculate staleness
    const now = Date.now();
    const leads = (data || []).map(l => {
      const age = l.created_at ? Math.floor((now - new Date(l.created_at).getTime()) / (1000 * 60 * 60 * 24)) : 0;
      return { ...l, ageDays: age, urgency: age > 60 ? 'critical' : age > 30 ? 'warm' : 'recent' };
    }).filter(l => l.ageDays >= 15);
    
    const summary = {
      critical: leads.filter(l => l.urgency === 'critical').length,
      warm: leads.filter(l => l.urgency === 'warm').length,
      recent: leads.filter(l => l.urgency === 'recent').length
    };
    
    res.json({ leads, total: leads.length, summary });
  } catch (err) {
    console.error('Stale leads error:', err);
    res.json({ leads: [], total: 0, summary: { critical: 0, warm: 0, recent: 0 }, error: err.message });
  }
});

