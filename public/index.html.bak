            <div class="summary-card" style="text-align: center; padding: 20px; border-left: 4px solid var(--accent);">
              <div style="font-size: 36px; font-weight: 700;">${count}</div>
              <div style="font-size: 12px; color: var(--text-muted);">Research Files</div>
            </div>
            <div class="summary-card" style="text-align: center; padding: 20px; border-left: 4px solid var(--green);">
              <div style="font-size: 36px; font-weight: 700; color: var(--green);">${hotCount}</div>
              <div style="font-size: 12px; color: var(--text-muted);">🔥 Hot Leads</div>
            </div>
            <div class="summary-card" style="text-align: center; padding: 20px; border-left: 4px solid var(--red);">
              <div style="font-size: 36px; font-weight: 700; color: var(--red);">${files.filter(f => f.status.includes('CRITICAL')).length}</div>
              <div style="font-size: 12px; color: var(--text-muted);">Critical Priority</div>
            </div>
          </div>
          
          <div class="summary-card">
            <table style="width: 100%;">
              <thead>
                <tr>
                  <th>Company</th>
                  <th>Contact</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                ${files.map(f => {
                  const hot = f.isHot ? '<span style="background: var(--red-bg); color: var(--red); padding: 2px 6px; border-radius: 4px; font-size: 10px; margin-left: 8px;">🔥 HOT</span>' : '';
                  const statusColor = f.status.includes('CRITICAL') ? 'var(--red)' : f.status.includes('warm') ? 'var(--yellow)' : 'var(--green)';
