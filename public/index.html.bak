                        <button onclick="copyToClipboard('${f.email}')" class="btn btn-default" style="padding: 4px 8px; font-size: 11px;">📋</button>
                      </td>
                    </tr>
                  `;
                }).join('')}
              </tbody>
            </table>
          </div>
          
          <div class="summary-card" style="margin-top: 24px; background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.05)); border: 1px solid var(--blue);">
            <h3 style="font-size: 14px; color: var(--blue); margin-bottom: 12px;">💡 ADD MORE RESEARCH</h3>
            <pre style="background: var(--bg-dark); padding: 12px; border-radius: 6px; font-size: 12px;">node research-lead.js email@company.com</pre>
          </div>
          
          <div id="researchModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); z-index: 1000; align-items: center; justify-content: center; padding: 20px;">
            <div style="background: #1e1e1e; border: 1px solid var(--border-light); border-radius: 12px; padding: 24px; width: 700px; max-width: 95vw; max-height: 90vh; overflow-y: auto;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 style="margin: 0;" id="researchTitle">Research</h3>
                <button onclick="hideResearchModal()" style="background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 20px;">×</button>
