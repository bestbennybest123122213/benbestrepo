<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BULL OS - SmartLead Analytics</title>
  <style>
    :root {
      --bg-dark: #0d0d0d;
      --bg-main: #141414;
      --bg-card: #1a1a1a;
      --bg-card-hover: #222;
      --sidebar-bg: #111;
      --text: #fff;
      --text-muted: #888;
      --text-dim: #666;
      --accent: #f97316;
      --accent-hover: #ea580c;
      --green: #22c55e;
      --green-bg: rgba(34, 197, 94, 0.15);
      --red: #ef4444;
      --red-bg: rgba(239, 68, 68, 0.15);
      --yellow: #eab308;
      --yellow-bg: rgba(234, 179, 8, 0.15);
      --orange: #f97316;
      --orange-bg: rgba(249, 115, 22, 0.15);
      --blue: #3b82f6;
      --blue-bg: rgba(59, 130, 246, 0.15);
      --purple: #a855f7;
      --purple-bg: rgba(168, 85, 247, 0.15);
      --cyan: #06b6d4;
      --cyan-bg: rgba(6, 182, 212, 0.15);
      --border: #2a2a2a;
      --border-light: #333;
      --hypertide: #06b6d4;
      --hypertide-bg: rgba(6, 182, 212, 0.15);
      --google: #a855f7;
      --google-bg: rgba(168, 85, 247, 0.15);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    /* Toast Notifications */
    .toast-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 10000;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .toast {
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 280px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.4);
      animation: slideIn 0.3s ease-out;
      cursor: pointer;
    }
    .toast.success { background: var(--green); color: #000; }
    .toast.error { background: var(--red); color: white; }
    .toast.warning { background: var(--yellow); color: #000; }
    .toast.info { background: var(--blue); color: white; }
    .toast.delete { background: var(--red); color: white; }
    @keyframes slideIn {
      from { transform: translateX(100%); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
    @keyframes slideOut {
      from { transform: translateX(0); opacity: 1; }
      to { transform: translateX(100%); opacity: 0; }
    }
    .toast.hide { animation: slideOut 0.3s ease-in forwards; }
    
    /* Loading Skeletons */
    .skeleton {
      background: linear-gradient(90deg, var(--bg-card) 25%, var(--bg-card-hover) 50%, var(--bg-card) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
      border-radius: 4px;
    }
    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    .skeleton-text { height: 16px; width: 100%; margin-bottom: 8px; }
    .skeleton-text.short { width: 60%; }
    .skeleton-card { height: 80px; width: 100%; }
    .skeleton-row { height: 48px; width: 100%; margin-bottom: 4px; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg-main);
      color: var(--text);
      line-height: 1.5;
      display: flex;
      min-height: 100vh;
    }

    /* Sidebar */
    .sidebar {
      width: 220px;
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }
    .sidebar-logo {
      padding: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid var(--border);
    }
    .logo-icon {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: transform 0.15s;
      overflow: hidden;
    }
    .logo-icon:hover {
      transform: scale(1.05);
    }
    .logo-icon img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .logo-text {
      font-weight: 600;
      font-size: 16px;
    }
    .sidebar-section {
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }
    .sidebar-section-title {
      padding: 8px 16px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      color: var(--text-dim);
      letter-spacing: 0.5px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.15s;
      border-left: 3px solid transparent;
    }
    .nav-item:hover {
      color: var(--text);
      background: rgba(255,255,255,0.03);
    }
    .nav-item.active {
      color: var(--accent);
      background: rgba(249, 115, 22, 0.1);
      border-left-color: var(--accent);
    }
    .nav-icon { font-size: 16px; }

    /* Main Content */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .topbar {
      padding: 12px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      color: var(--text-muted);
    }
    .content {
      flex: 1;
      padding: 24px;
      overflow-y: auto;
    }

    /* Page Header */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 24px;
    }
    .page-title {
      font-size: 22px;
      font-weight: 600;
      margin-bottom: 4px;
    }
    .page-subtitle {
      color: var(--text-muted);
      font-size: 13px;
    }
    .header-actions {
      display: flex;
      gap: 8px;
    }

    /* Buttons */
    .btn {
      padding: 8px 16px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      display: flex;
      align-items: center;
      gap: 6px;
      border: none;
    }
    .btn-default {
      background: var(--bg-card);
      border: 1px solid var(--border);
      color: var(--text);
    }
    .btn-default:hover { background: var(--bg-card-hover); }
    .btn-primary {
      background: var(--accent);
      color: white;
    }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .snooze-wrap { position: relative; display: inline-flex; align-items: center; }
    .snooze-menu {
      position: absolute;
      top: 100%;
      right: 0;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px;
      display: none;
      z-index: 20;
      min-width: 180px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.35);
    }
    .snooze-menu select,
    .snooze-menu input {
      width: 100%;
      background: var(--bg-dark);
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 6px;
      padding: 6px 8px;
      font-size: 11px;
      outline: none;
    }
    .snooze-menu button {
      width: 100%;
      margin-top: 6px;
    }

    /* Summary Cards */
    .summary-cards {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }
    .summary-card {
      background: var(--bg-card);
      border-radius: 8px;
      padding: 16px 20px;
      border: 1px solid var(--border);
    }
    .summary-card-header {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text-muted);
      font-size: 12px;
      margin-bottom: 8px;
    }
    .summary-value {
      font-size: 28px;
      font-weight: 700;
    }
    .summary-sub {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 4px;
    }

    /* Status indicators */
    .status-badge {
      display: inline-flex;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
    }
    .status-success { background: var(--green-bg); color: var(--green); }
    .status-warning { background: var(--yellow-bg); color: var(--yellow); }
    .status-error { background: var(--red-bg); color: var(--red); }
    .status-info { background: var(--blue-bg); color: var(--blue); }

    /* Type badges */
    .type-badge {
      display: inline-flex;
      padding: 3px 8px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .type-hypertide { background: var(--hypertide-bg); color: var(--hypertide); }
    .type-google { background: var(--google-bg); color: var(--google); }

    /* Table */
    .table-container {
      background: var(--bg-card);
      border-radius: 8px;
      border: 1px solid var(--border);
      overflow: hidden;
      margin-bottom: 24px;
    }
    .table-header {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .table-title {
      font-size: 14px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .search-box {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--bg-dark);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 12px;
      width: 250px;
    }
    .search-box input {
      background: none;
      border: none;
      color: var(--text);
      font-size: 12px;
      width: 100%;
      outline: none;
    }
    .search-box input::placeholder { color: var(--text-dim); }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    th {
      background: rgba(0,0,0,0.3);
      padding: 12px 14px;
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    th:hover { color: var(--text); }
    th.sorted { color: var(--accent); }
    td {
      padding: 12px 14px;
      border-bottom: 1px solid var(--border);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }
    
    /* Rate colors */
    .rate-good { color: var(--green); }
    .rate-ok { color: var(--yellow); }
    .rate-bad { color: var(--red); }

    /* Trends */
    .trends-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 16px;
      margin-bottom: 24px;
    }
    .chart-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
    }
    .chart-wrap {
      position: relative;
      height: 280px;
    }
    .trend-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }
    .trend-up { background: var(--green-bg); color: var(--green); }
    .trend-down { background: var(--red-bg); color: var(--red); }
    .trend-flat { background: rgba(255,255,255,0.04); color: var(--text-muted); }

    /* Expandable rows */
    .expandable-row { cursor: pointer; }
    .expandable-row:hover td { background: rgba(255,255,255,0.04); }
    .expand-icon { 
      display: inline-block; 
      width: 16px; 
      transition: transform 0.2s; 
      font-size: 10px;
    }
    .expand-icon.expanded { transform: rotate(90deg); }
    .child-row { background: rgba(0,0,0,0.2); }
    .child-row td { padding: 8px 14px 8px 40px; font-size: 12px; }
    .child-row:hover td { background: rgba(0,0,0,0.3); }
    .hidden { display: none; }

    /* Comparison Section */
    .comparison-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 24px;
    }
    .comparison-panel {
      background: var(--bg-card);
      border-radius: 8px;
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .comparison-panel.hypertide { border-top: 3px solid var(--hypertide); }
    .comparison-panel.google { border-top: 3px solid var(--google); }
    .comparison-panel-header {
      padding: 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .comparison-panel-title {
      font-size: 16px;
      font-weight: 600;
    }
    .comparison-panel-stats {
      padding: 16px;
    }
    .stat-row {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }
    .stat-row:last-child { border-bottom: none; }
    .stat-label { color: var(--text-muted); font-size: 13px; }
    .stat-value { font-weight: 600; font-size: 14px; }
    .winner { color: var(--green); }
    .loser { color: var(--text-muted); }

    /* Summary comparison */
    .summary-comparison {
      background: var(--bg-card);
      border-radius: 8px;
      border: 1px solid var(--border);
      padding: 20px;
      margin-bottom: 24px;
    }
    .summary-comparison-title {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 16px;
      color: var(--text-muted);
    }
    .comparison-metrics {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 16px;
    }
    .comparison-metric {
      text-align: center;
      padding: 12px;
      background: rgba(0,0,0,0.2);
      border-radius: 6px;
    }
    .comparison-metric-label {
      font-size: 11px;
      color: var(--text-dim);
      margin-bottom: 8px;
    }
    .comparison-metric-values {
      display: flex;
      justify-content: center;
      gap: 16px;
    }
    .metric-value {
      font-size: 14px;
      font-weight: 600;
    }
    .metric-value.hypertide { color: var(--hypertide); }
    .metric-value.google { color: var(--google); }

    /* Time Comparison cards */
    .comparison-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }
    .comparison-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
    }
    .comparison-title {
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 12px;
      color: var(--text-muted);
    }
    .comparison-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
    }
    .comparison-row:last-child { border-bottom: none; }
    .comparison-label { color: var(--text-muted); font-size: 12px; }
    .comparison-value { font-weight: 600; font-size: 14px; }
    .change-badge {
      font-size: 11px;
      padding: 2px 6px;
      border-radius: 4px;
      font-weight: 600;
    }
    .change-up { background: var(--green-bg); color: var(--green); }
    .change-down { background: var(--red-bg); color: var(--red); }
    .change-neutral { background: rgba(136,136,136,0.2); color: var(--text-muted); }

    /* Insights cards */
    .insights-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .insight-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
    }
    .insight-card.good { border-left: 3px solid var(--green); }
    .insight-card.warning { border-left: 3px solid var(--yellow); }
    .insight-card.bad { border-left: 3px solid var(--red); }
    .insight-title {
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 12px;
    }
    .insight-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 6px 0;
      font-size: 12px;
    }
    .insight-name {
      color: var(--text-muted);
      max-width: 180px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* Loading */
    .loading-overlay {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 300px;
    }
    .spinner {
      width: 32px;
      height: 32px;
      border: 3px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes fadeOut { 0% { opacity: 1; } 70% { opacity: 1; } 100% { opacity: 0; } }

    /* Tabs */
    .tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 16px;
    }
    .tab {
      padding: 8px 16px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 12px;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.15s;
    }
    .tab:hover {
      background: var(--bg-card-hover);
      color: var(--text);
    }
    .tab.active {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }

    /* Responsive */
    @media (max-width: 1400px) {
      .summary-cards { grid-template-columns: repeat(3, 1fr); }
      .comparison-metrics { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 1200px) {
      .summary-cards { grid-template-columns: repeat(2, 1fr); }
      .comparison-grid { grid-template-columns: 1fr; }
      .comparison-section { grid-template-columns: 1fr; }
      .comparison-metrics { grid-template-columns: repeat(2, 1fr); }
      .insights-grid { grid-template-columns: 1fr; }
      .trends-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .summary-cards { grid-template-columns: 1fr; }
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
</head>
<body>
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon" onclick="showLandingPage()" title="Go to main menu"><img src="bull-logo.jpg?v=2" alt="BULL OS"></div>
      <span class="logo-text" onclick="showLandingPage()" style="cursor: pointer;" title="Go to main menu">BULL OS</span>
    </div>
    
    <div class="sidebar-section">
      <div class="sidebar-section-title">📍 Pipeline</div>
      <a class="nav-item active" data-view="responseTimes">
        <span class="nav-icon">⏱️</span> Response Times
      </a>
      <a class="nav-item" data-view="interestedLeads">
        <span class="nav-icon">🎯</span> Interested Leads
      </a>
      <a class="nav-item" data-view="imannBookings">
        <span class="nav-icon">📅</span> Bookings Tracker
      </a>
      <a class="nav-item" data-view="staleLeads">
        <span class="nav-icon">🔥</span> Stale Leads
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-section-title">📊 Campaigns</div>
      <a class="nav-item" data-view="campaignAnalytics">
        <span class="nav-icon">📈</span> Campaign Analytics
      </a>
      <a class="nav-item" data-view="campaigns">
        <span class="nav-icon">⚔️</span> HyperTide vs Google
      </a>
      <a class="nav-item" data-view="replies">
        <span class="nav-icon">💬</span> Positive Replies
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-section-title">🔧 Infrastructure</div>
      <a class="nav-item" data-view="domains">
        <span class="nav-icon">🌐</span> Domain Health
      </a>
      <a class="nav-item" data-view="warmup">
        <span class="nav-icon">🔥</span> Warmup Stats
      </a>
      <a class="nav-item" data-view="deliverability">
        <span class="nav-icon">📋</span> Eric's Benchmarks
      </a>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-section-title">🔧 Tools</div>
      <a class="nav-item" data-view="verify">
        <span class="nav-icon">🔒</span> Verify Data
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <div class="topbar">
      <div class="breadcrumb">
        <span>◇</span>
        <span id="currentView">Campaigns</span>
      </div>
      <div style="display: flex; gap: 8px; align-items: center;">
        <span id="cacheStatus" class="status-badge status-info" style="display: none;">
          ⚡ Cached
        </span>
        <span id="verifyStatus" class="status-badge" style="display: none;"></span>
        <button class="btn btn-default" id="refreshBtn" onclick="loadDashboard(true)">
          <span>↻</span> Force Refresh
        </button>
      </div>
    </div>

    <div class="content" id="mainContent">
      <div class="loading-overlay"><div class="spinner"></div></div>
    </div>
  </main>

  <script>
    let data = null;
    let warmupData = null;
    let sequenceData = null;
    let trendsData = null;
    let trendsChart = null;
    let responseTimesChart = null;
    let distributionChart = null;
    let currentView = 'responseTimes';
    let sortColumn = 'leads';
    let sortDir = -1;
    let searchFilter = '';
    let expandedDomains = new Set();
    let expandedCampaigns = new Set();

    const fmt = n => n?.toLocaleString() ?? '0';
    const pct = n => (parseFloat(n) || 0).toFixed(2) + '%';

    // Update ALL sections by month (global filter)
    window.updateAllByMonth = async function(month) {
      try {
        // Fetch both APIs with month filter
        const [bookingRes, statsRes] = await Promise.all([
          fetch('/api/imann/bookings?month=' + encodeURIComponent(month)),
          fetch('/api/response-times/stats?month=' + encodeURIComponent(month))
        ]);
        
        const bookingData = await bookingRes.json();
        const statsData = await statsRes.json();
        
        // Helper functions
        const formatTime = (seconds) => {
          if (!seconds || seconds === 0) return '0s';
          if (seconds < 60) return Math.round(seconds) + 's';
          if (seconds < 3600) return Math.round(seconds / 60) + 'm';
          if (seconds < 86400) return (seconds / 3600).toFixed(1) + 'h';
          return (seconds / 86400).toFixed(1) + 'd';
        };
        
        // 1. Update Booking Ratio
        const summary = bookingData.summary || {};
        const bookingRatioEl = document.getElementById('bookingRatioValue');
        const bookingDetailsEl = document.getElementById('bookingRatioDetails');
        const bookedCountEl = document.getElementById('bookedCount');
        const schedulingCountEl = document.getElementById('schedulingCount');
        const notBookedCountEl = document.getElementById('notBookedCount');
        
        if (bookingRatioEl) bookingRatioEl.textContent = summary.bookingRate + '%';
        if (bookingDetailsEl) bookingDetailsEl.textContent = summary.booked + ' booked / ' + summary.total + ' companies';
        if (bookedCountEl) bookedCountEl.textContent = summary.booked;
        if (schedulingCountEl) schedulingCountEl.textContent = summary.scheduling;
        if (notBookedCountEl) notBookedCountEl.textContent = summary.notBooked;
        
        // 2. Update Response Time Impact
        const correlation = bookingData.responseTimeCorrelation || [];
        const fast = correlation.filter(r => ['< 5 min', '5-15 min', '15-30 min', '30-60 min'].includes(r.bucket));
        const medium = correlation.filter(r => ['1-3 hours', '3-6 hours'].includes(r.bucket));
        const slow = correlation.filter(r => ['6-12 hours', '12-24 hours'].includes(r.bucket));
        const verySlow = correlation.filter(r => ['1-2 days', '> 2 days'].includes(r.bucket));
        
        const sum = (arr) => arr.reduce((a, r) => ({ total: a.total + (r.total || 0), booked: a.booked + (r.booked || 0) }), { total: 0, booked: 0 });
        const fastSum = sum(fast);
        const mediumSum = sum(medium);
        const slowSum = sum(slow);
        const verySlowSum = sum(verySlow);
        
        const rate = (s) => s.total > 0 ? Math.round((s.booked / s.total) * 100) : 0;
        
        const impactEl = document.getElementById('responseTimeImpactContent');
        if (impactEl) {
          impactEl.innerHTML = 
            '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(34, 197, 94, 0.15); border-radius: 8px;">' +
              '<div style="font-size: 24px; font-weight: 700; color: var(--green);">' + rate(fastSum) + '%</div>' +
              '<div style="font-size: 11px; color: var(--text-muted);">< 1 hour</div>' +
              '<div style="font-size: 10px; color: var(--text-dim);">' + fastSum.booked + '/' + fastSum.total + '</div>' +
            '</div>' +
            '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(251, 191, 36, 0.15); border-radius: 8px;">' +
              '<div style="font-size: 24px; font-weight: 700; color: var(--yellow);">' + rate(mediumSum) + '%</div>' +
              '<div style="font-size: 11px; color: var(--text-muted);">1-6 hours</div>' +
              '<div style="font-size: 10px; color: var(--text-dim);">' + mediumSum.booked + '/' + mediumSum.total + '</div>' +
            '</div>' +
            '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(249, 115, 22, 0.15); border-radius: 8px;">' +
              '<div style="font-size: 24px; font-weight: 700; color: #f97316;">' + rate(slowSum) + '%</div>' +
              '<div style="font-size: 11px; color: var(--text-muted);">6-24 hours</div>' +
              '<div style="font-size: 10px; color: var(--text-dim);">' + slowSum.booked + '/' + slowSum.total + '</div>' +
            '</div>' +
            '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(239, 68, 68, 0.15); border-radius: 8px;">' +
              '<div style="font-size: 24px; font-weight: 700; color: var(--red);">' + rate(verySlowSum) + '%</div>' +
              '<div style="font-size: 11px; color: var(--text-muted);">> 24 hours</div>' +
              '<div style="font-size: 10px; color: var(--text-dim);">' + verySlowSum.booked + '/' + verySlowSum.total + '</div>' +
            '</div>';
        }
        
        // 3. Update Mean/Median stats
        const overall = statsData.overall_response || {};
        const meanEl = document.getElementById('statsMeanValue');
        const medianEl = document.getElementById('statsMedianValue');
        const meanCountEl = document.getElementById('statsMeanCount');
        
        if (meanEl) meanEl.textContent = formatTime(overall.avg_seconds);
        if (medianEl) medianEl.textContent = formatTime(overall.median_seconds);
        if (meanCountEl) meanCountEl.textContent = overall.count || 0;
        
        // 4. Update Distribution bars
        const dist = statsData.all_time_distribution || {};
        const buckets = ['5m', '15m', '1h', '3h', '6h', '12h', '24h', 'over24h'];
        const distKeys = ['under_5min', 'under_15min', 'under_1hr', 'under_3hr', 'under_6hr', 'under_12hr', 'under_24hr', 'over_24hr'];
        const total = distKeys.reduce((s, k) => s + (dist[k] || 0), 0);
        const maxVal = Math.max(...distKeys.map(k => dist[k] || 0), 1);
        
        buckets.forEach((b, i) => {
          const val = dist[distKeys[i]] || 0;
          const pctVal = total > 0 ? Math.round(val / total * 100) : 0;
          const barEl = document.getElementById('distBar' + b);
          const numEl = document.getElementById('dist' + b);
          const pctEl = document.getElementById('dist' + b + 'Pct');
          
          if (barEl) barEl.style.height = (maxVal > 0 ? Math.max(8, (val / maxVal) * 100) : 8) + '%';
          if (numEl) numEl.textContent = val;
          if (pctEl) pctEl.textContent = pctVal + '%';
        });
        
        // Update total responses count
        const totalResponsesEl = document.getElementById('distTotalResponses');
        if (totalResponsesEl) totalResponsesEl.textContent = total + ' total responses';
        
        // Update the title to show selected month
        const monthLabel = month === 'all' ? 'All Months' : month.split('-')[1] + ' ' + month.split('-')[0];
        const titleEl = document.querySelector('.page-subtitle');
        if (titleEl && month !== 'all') {
          titleEl.innerHTML = 'Filtered: <strong>' + monthLabel + '</strong> — ' + summary.total + ' companies';
        }
        
      } catch (e) {
        console.error('Failed to update by month:', e);
      }
    };
    
    // Keep old function for backward compatibility
    async function updateResponseTimeImpact(month) {
      window.updateAllByMonth(month);
    }

    // Type detection functions
    function getDomainType(accountCount) {
      return accountCount >= 10 ? 'hypertide' : 'google';
    }
    
    function getCampaignType(campaignName) {
      return campaignName.toUpperCase().includes('HYPERTIDE') ? 'hypertide' : 'google';
    }

    function changeClass(val) {
      const n = parseFloat(val);
      return n > 0 ? 'change-up' : n < 0 ? 'change-down' : 'change-neutral';
    }
    function changeText(val, suffix = '') {
      const n = parseFloat(val);
      return n > 0 ? `+${n}${suffix}` : `${n}${suffix}`;
    }
    function rateClass(rate, thresholdGood = 2, thresholdOk = 0.5) {
      const r = parseFloat(rate);
      return r >= thresholdGood ? 'rate-good' : r >= thresholdOk ? 'rate-ok' : 'rate-bad';
    }
    function positiveRateClass(rate) {
      const r = parseFloat(rate);
      return r >= 40 ? 'rate-good' : r >= 20 ? 'rate-ok' : 'rate-bad';
    }
    function bounceRateClass(rate) {
      const r = parseFloat(rate);
      return r <= 2 ? 'rate-good' : r <= 5 ? 'rate-ok' : 'rate-bad';
    }
    function reputationClass(rep) {
      return rep >= 70 ? 'rate-good' : rep >= 50 ? 'rate-ok' : 'rate-bad';
    }

    // Split campaigns by type
    function splitCampaigns(campaigns) {
      const hypertide = campaigns.filter(c => getCampaignType(c.name) === 'hypertide');
      const google = campaigns.filter(c => getCampaignType(c.name) === 'google');
      return { hypertide, google };
    }

    // Split domains by type
    function splitDomains(domains) {
      const hypertide = domains.filter(d => getDomainType(d.accounts) === 'hypertide');
      const google = domains.filter(d => getDomainType(d.accounts) === 'google');
      return { hypertide, google };
    }

    // Calculate aggregate stats for a group
    function calcGroupStats(campaigns) {
      const totalLeads = campaigns.reduce((sum, c) => sum + (c.leads || 0), 0);
      const totalReplies = campaigns.reduce((sum, c) => sum + (c.replied || 0), 0);
      const totalInterested = campaigns.reduce((sum, c) => sum + (c.interested || 0), 0);
      const totalBounced = campaigns.reduce((sum, c) => sum + (c.bounced || 0), 0);
      const totalSent = campaigns.reduce((sum, c) => sum + (c.sent || 0), 0);
      
      return {
        campaigns: campaigns.length,
        leads: totalLeads,
        sent: totalSent,
        replies: totalReplies,
        interested: totalInterested,
        bounced: totalBounced,
        replyRate: totalLeads > 0 ? (totalReplies / totalLeads * 100) : 0,
        positiveRate: totalReplies > 0 ? (totalInterested / totalReplies * 100) : 0,
        bounceRate: totalLeads > 0 ? (totalBounced / totalLeads * 100) : 0
      };
    }

    // Calculate domain group stats
    function calcDomainGroupStats(domains) {
      const totalDomains = domains.length;
      const totalAccounts = domains.reduce((sum, d) => sum + (d.accounts || 0), 0);
      const reps = domains.filter(d => d.avgReputation > 0).map(d => d.avgReputation);
      const avgReputation = reps.length > 0 ? reps.reduce((a, b) => a + b, 0) / reps.length : 0;
      const activeWarmup = domains.reduce((sum, d) => sum + (d.activeWarmup || 0), 0);
      
      // NEW: Calculate campaign stats from mailbox statistics
      const totalSent = domains.reduce((sum, d) => sum + (d.sent || 0), 0);
      const totalReplies = domains.reduce((sum, d) => sum + (d.replies || 0), 0);
      const totalBounced = domains.reduce((sum, d) => sum + (d.bounced || 0), 0);
      
      return {
        domains: totalDomains,
        accounts: totalAccounts,
        avgReputation: Math.round(avgReputation),
        activeWarmup,
        healthy: domains.filter(d => d.status === 'healthy').length,
        warning: domains.filter(d => d.status === 'warning').length,
        critical: domains.filter(d => d.status === 'critical').length,
        // Campaign performance
        sent: totalSent,
        replies: totalReplies,
        bounced: totalBounced,
        replyRate: totalSent > 0 ? (totalReplies / totalSent * 100) : 0,
        bounceRate: totalSent > 0 ? (totalBounced / totalSent * 100) : 0
      };
    }

    // Render Campaign Analytics - unified view of all campaigns
    function renderCampaignAnalytics() {
      if (!data || !data.campaigns) {
        return '<div class="loading-overlay"><div class="spinner"></div></div>';
      }

      const campaigns = data.campaigns.filter(c => c.status === 'ACTIVE');
      const metrics = data.leadMetrics || {};
      
      // Sort campaigns by positive replies (best performing first)
      const sortedCampaigns = [...campaigns].sort((a, b) => {
        const aPositive = (a.lead_contacted_stats?.INTERESTED || 0) + (a.lead_contacted_stats?.MEETING_REQUEST || 0);
        const bPositive = (b.lead_contacted_stats?.INTERESTED || 0) + (b.lead_contacted_stats?.MEETING_REQUEST || 0);
        return bPositive - aPositive;
      });
      
      // Calculate totals
      const totalSent = campaigns.reduce((sum, c) => sum + (c.sent || 0), 0);
      const totalReplies = campaigns.reduce((sum, c) => sum + (c.replied || 0), 0);
      const totalPositive = campaigns.reduce((sum, c) => sum + (c.lead_contacted_stats?.INTERESTED || 0) + (c.lead_contacted_stats?.MEETING_REQUEST || 0), 0);
      const totalBounced = campaigns.reduce((sum, c) => sum + (c.bounced || 0), 0);
      const replyRate = totalSent > 0 ? (totalReplies / totalSent * 100) : 0;
      const positiveRate = totalSent > 0 ? (totalPositive / totalSent * 100) : 0;
      const bounceRate = totalSent > 0 ? (totalBounced / totalSent * 100) : 0;

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">📈 Campaign Analytics</h1>
            <p class="page-subtitle">All ${campaigns.length} active campaigns · Performance overview</p>
          </div>
          <div style="display: flex; gap: 12px; align-items: center;">
            <div style="font-size: 12px; color: var(--text-muted); padding: 8px 14px; border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 14px;">⚡</span>
              <span>SmartLead API · Live</span>
            </div>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards" style="grid-template-columns: repeat(5, 1fr);">
          <div class="summary-card">
            <div class="summary-card-header">📧 Total Sent</div>
            <div class="summary-value">${fmt(totalSent)}</div>
            <div class="summary-sub">${campaigns.length} campaigns</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">💬 Replies</div>
            <div class="summary-value">${fmt(totalReplies)}</div>
            <div class="summary-sub">${replyRate.toFixed(1)}% reply rate</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">✅ Positive</div>
            <div class="summary-value" style="color: var(--green)">${fmt(totalPositive)}</div>
            <div class="summary-sub">${positiveRate.toFixed(2)}% of sent</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">🎯 Positive/Sent</div>
            <div class="summary-value" style="color: var(--accent)">1:${totalPositive > 0 ? Math.round(totalSent / totalPositive) : '∞'}</div>
            <div class="summary-sub">Eric benchmark: 1:300</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">⚠️ Bounce Rate</div>
            <div class="summary-value" style="color: ${bounceRate > 3 ? 'var(--red)' : bounceRate > 2 ? 'var(--yellow)' : 'var(--green)'}">${bounceRate.toFixed(1)}%</div>
            <div class="summary-sub">Target: < 3%</div>
          </div>
        </div>

        <!-- All Campaigns Table -->
        <div class="table-container">
          <div class="table-header">
            <span class="table-title">📋 All Active Campaigns (sorted by performance)</span>
          </div>
          <table>
            <thead>
              <tr>
                <th>Campaign</th>
                <th>Leads</th>
                <th>Sent</th>
                <th>Replied</th>
                <th>Reply %</th>
                <th>Positive</th>
                <th>Positive %</th>
                <th>Ratio</th>
                <th>Bounce %</th>
              </tr>
            </thead>
            <tbody>
              ${sortedCampaigns.map(c => {
                const sent = c.sent || 0;
                const replied = c.replied || 0;
                const positive = (c.lead_contacted_stats?.INTERESTED || 0) + (c.lead_contacted_stats?.MEETING_REQUEST || 0);
                const bounced = c.bounced || 0;
                const replyPct = sent > 0 ? (replied / sent * 100) : 0;
                const positivePct = sent > 0 ? (positive / sent * 100) : 0;
                const ratio = positive > 0 ? Math.round(sent / positive) : 0;
                const bouncePct = sent > 0 ? (bounced / sent * 100) : 0;
                const isGood = ratio > 0 && ratio <= 300;
                const isKiller = ratio > 0 && ratio <= 100;
                
                return \`
                  <tr>
                    <td style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="\${c.name}">\${c.name}</td>
                    <td>\${fmt(c.total_leads || 0)}</td>
                    <td>\${fmt(sent)}</td>
                    <td>\${fmt(replied)}</td>
                    <td class="\${replyPct >= 1 ? 'rate-good' : replyPct >= 0.5 ? 'rate-ok' : 'rate-bad'}">\${replyPct.toFixed(1)}%</td>
                    <td style="color: var(--green); font-weight: 600;">\${positive}</td>
                    <td class="\${positivePct >= 0.5 ? 'rate-good' : positivePct >= 0.2 ? 'rate-ok' : ''}">\${positivePct.toFixed(2)}%</td>
                    <td style="font-weight: 600; color: \${isKiller ? 'var(--green)' : isGood ? 'var(--accent)' : 'var(--text-muted)'}">\${ratio > 0 ? '1:' + ratio : '-'}\${isKiller ? ' 🔥' : isGood ? ' ✓' : ''}</td>
                    <td class="\${bouncePct > 3 ? 'rate-bad' : bouncePct > 2 ? 'rate-ok' : ''}">\${bouncePct.toFixed(1)}%</td>
                  </tr>
                \`;
              }).join('')}
            </tbody>
          </table>
        </div>

        <!-- Performance Legend -->
        <div style="margin-top: 16px; padding: 12px 16px; background: var(--bg-card); border-radius: 8px; border: 1px solid var(--border);">
          <span style="font-size: 12px; color: var(--text-muted);">
            <strong>Ratio Guide (per Eric):</strong>
            <span style="color: var(--green); margin-left: 12px;">🔥 1:100 or better = KILLER</span>
            <span style="color: var(--accent); margin-left: 12px;">✓ 1:300 or better = SCALE IT</span>
            <span style="margin-left: 12px;">Above 1:300 = needs optimization</span>
          </span>
        </div>
      `;
    }

    // Render Campaigns view - split by HyperTide vs Google
    function renderCampaigns() {
      if (!data || !data.campaigns) {
        return '<div class="loading-overlay"><div class="spinner"></div></div>';
      }

      const metrics = data.leadMetrics || {};
      let campaigns = [...data.campaigns];
      
      // Apply search filter
      if (searchFilter) {
        const s = searchFilter.toLowerCase();
        campaigns = campaigns.filter(c => c.name.toLowerCase().includes(s));
      }

      // Sort
      campaigns.sort((a, b) => {
        let aVal = a[sortColumn] ?? 0;
        let bVal = b[sortColumn] ?? 0;
        if (typeof aVal === 'string') aVal = parseFloat(aVal) || 0;
        if (typeof bVal === 'string') bVal = parseFloat(bVal) || 0;
        return (bVal - aVal) * sortDir;
      });

      // Split by type
      const { hypertide, google } = splitCampaigns(campaigns);
      const hypertideStats = calcGroupStats(hypertide);
      const googleStats = calcGroupStats(google);

      const sortIcon = col => sortColumn === col ? (sortDir === -1 ? ' ↓' : ' ↑') : '';

      // Helper for completion rate color
      const completionClass = (rate) => {
        const r = parseFloat(rate);
        return r >= 80 ? 'rate-good' : r >= 50 ? 'rate-ok' : 'rate-bad';
      };

      const renderCampaignTable = (campaignList, type, stats) => `
        <div class="table-container">
          <div class="table-header">
            <span class="table-title">
              <span class="type-badge type-${type}">${type === 'hypertide' ? '🌊 HyperTide' : '🔍 Google'}</span>
              ${campaignList.length} Campaigns · ${fmt(stats.leads)} Leads · ${pct(stats.replyRate)} Reply · ${pct(stats.positiveRate)} Positive
            </span>
          </div>
          <table>
            <thead>
              <tr>
                <th onclick="sortBy('name')" style="min-width: 200px">Campaign${sortIcon('name')}</th>
                <th onclick="sortBy('leads')">Leads${sortIcon('leads')}</th>
                <th onclick="sortBy('replyRate')">Reply Ratio${sortIcon('replyRate')}</th>
                <th onclick="sortBy('positiveReplyRate')">Positive Rate${sortIcon('positiveReplyRate')}</th>
                <th onclick="sortBy('bounceRate')">Bounce Rate${sortIcon('bounceRate')}</th>
              </tr>
            </thead>
            <tbody>
              ${campaignList.map(c => `
                <tr>
                  <td style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${c.name}">${c.name}</td>
                  <td>${fmt(c.leads)}</td>
                  <td class="${rateClass(c.replyRate)}">${pct(c.replyRate)}</td>
                  <td class="${positiveRateClass(c.positiveReplyRate)}">${pct(c.positiveReplyRate)}</td>
                  <td class="${bounceRateClass(c.bounceRate)}">${pct(c.bounceRate)}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">⚔️ HyperTide vs Google</h1>
            <p class="page-subtitle">Campaign comparison by infrastructure provider</p>
          </div>
          <div style="display: flex; gap: 12px; align-items: center;">
            <div style="font-size: 12px; color: var(--text-muted); padding: 8px 14px; border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 14px;">⚡</span>
              <span>SmartLead API · Live</span>
            </div>
            <div class="search-box">
              <span>🔍</span>
              <input type="text" id="searchInput" placeholder="Search campaigns..." value="${searchFilter}" oninput="handleSearch(this.value)">
            </div>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards" style="grid-template-columns: repeat(2, 1fr);">
          <div class="summary-card">
            <div class="summary-card-header">📊 Total Leads</div>
            <div class="summary-value">${fmt(metrics.totalLeads)}</div>
            <div class="summary-sub">${fmt(metrics.totalCampaigns)} campaigns</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">✅ Positive Rate</div>
            <div class="summary-value" style="color: var(--green)">${pct(metrics.positiveReplyRate)}</div>
            <div class="summary-sub">${fmt(metrics.totalInterested)} interested</div>
          </div>
        </div>

        <!-- HyperTide Campaigns -->
        ${renderCampaignTable(hypertide, 'hypertide', hypertideStats)}
        
        <!-- Google Campaigns -->
        ${renderCampaignTable(google, 'google', googleStats)}

        <div style="margin-top: 12px; font-size: 11px; color: var(--text-dim);">
          Type detection: "HYPERTIDE" in name = HyperTide.
        </div>
      `;
    }

    // Render HyperTide vs Google Comparison
    function renderComparison() {
      if (!data || !data.campaigns) {
        return '<div class="loading-overlay"><div class="spinner"></div></div>';
      }

      const { hypertide, google } = splitCampaigns(data.campaigns);
      const htStats = calcGroupStats(hypertide);
      const gStats = calcGroupStats(google);

      // Also get domain stats if available
      let htDomainStats = { domains: 0, accounts: 0, avgReputation: 0 };
      let gDomainStats = { domains: 0, accounts: 0, avgReputation: 0 };
      
      if (warmupData && warmupData.domainHealth) {
        const { hypertide: htDomains, google: gDomains } = splitDomains(warmupData.domainHealth);
        htDomainStats = calcDomainGroupStats(htDomains);
        gDomainStats = calcDomainGroupStats(gDomains);
      }

      const isWinner = (a, b, higherBetter = true) => {
        if (higherBetter) return a > b ? 'winner' : a < b ? 'loser' : '';
        return a < b ? 'winner' : a > b ? 'loser' : '';
      };

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">⚔️ HyperTide vs Google</h1>
            <p class="page-subtitle">Head-to-head comparison of campaign performance</p>
          </div>
        </div>

        <!-- Quick Comparison -->
        <div class="summary-comparison">
          <div class="summary-comparison-title">📊 Quick Comparison</div>
          <div class="comparison-metrics">
            <div class="comparison-metric">
              <div class="comparison-metric-label">Campaigns</div>
              <div class="comparison-metric-values">
                <span class="metric-value hypertide">${htStats.campaigns}</span>
                <span style="color: var(--text-dim)">vs</span>
                <span class="metric-value google">${gStats.campaigns}</span>
              </div>
            </div>
            <div class="comparison-metric">
              <div class="comparison-metric-label">Total Leads</div>
              <div class="comparison-metric-values">
                <span class="metric-value hypertide">${fmt(htStats.leads)}</span>
                <span style="color: var(--text-dim)">vs</span>
                <span class="metric-value google">${fmt(gStats.leads)}</span>
              </div>
            </div>
            <div class="comparison-metric">
              <div class="comparison-metric-label">Reply Rate</div>
              <div class="comparison-metric-values">
                <span class="metric-value hypertide ${isWinner(htStats.replyRate, gStats.replyRate)}">${pct(htStats.replyRate)}</span>
                <span style="color: var(--text-dim)">vs</span>
                <span class="metric-value google ${isWinner(gStats.replyRate, htStats.replyRate)}">${pct(gStats.replyRate)}</span>
              </div>
            </div>
            <div class="comparison-metric">
              <div class="comparison-metric-label">Positive Rate</div>
              <div class="comparison-metric-values">
                <span class="metric-value hypertide ${isWinner(htStats.positiveRate, gStats.positiveRate)}">${pct(htStats.positiveRate)}</span>
                <span style="color: var(--text-dim)">vs</span>
                <span class="metric-value google ${isWinner(gStats.positiveRate, htStats.positiveRate)}">${pct(gStats.positiveRate)}</span>
              </div>
            </div>
            <div class="comparison-metric">
              <div class="comparison-metric-label">Bounce Rate</div>
              <div class="comparison-metric-values">
                <span class="metric-value hypertide ${isWinner(htStats.bounceRate, gStats.bounceRate, false)}">${pct(htStats.bounceRate)}</span>
                <span style="color: var(--text-dim)">vs</span>
                <span class="metric-value google ${isWinner(gStats.bounceRate, htStats.bounceRate, false)}">${pct(gStats.bounceRate)}</span>
              </div>
            </div>
            <div class="comparison-metric">
              <div class="comparison-metric-label">Avg Reputation</div>
              <div class="comparison-metric-values">
                <span class="metric-value hypertide ${isWinner(htDomainStats.avgReputation, gDomainStats.avgReputation)}">${htDomainStats.avgReputation}%</span>
                <span style="color: var(--text-dim)">vs</span>
                <span class="metric-value google ${isWinner(gDomainStats.avgReputation, htDomainStats.avgReputation)}">${gDomainStats.avgReputation}%</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Detailed Side-by-Side -->
        <div class="comparison-section">
          <div class="comparison-panel hypertide">
            <div class="comparison-panel-header">
              <span class="type-badge type-hypertide">🌊 HyperTide</span>
              <span class="comparison-panel-title">Campaign Performance</span>
            </div>
            <div class="comparison-panel-stats">
              <div class="stat-row">
                <span class="stat-label">Total Campaigns</span>
                <span class="stat-value">${htStats.campaigns}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Total Leads</span>
                <span class="stat-value">${fmt(htStats.leads)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Total Sent</span>
                <span class="stat-value">${fmt(htStats.sent)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Replies</span>
                <span class="stat-value">${fmt(htStats.replies)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Reply Rate</span>
                <span class="stat-value ${isWinner(htStats.replyRate, gStats.replyRate)}">${pct(htStats.replyRate)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Interested</span>
                <span class="stat-value" style="color: var(--green)">${fmt(htStats.interested)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Positive Rate</span>
                <span class="stat-value ${isWinner(htStats.positiveRate, gStats.positiveRate)}">${pct(htStats.positiveRate)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Bounce Rate</span>
                <span class="stat-value ${isWinner(htStats.bounceRate, gStats.bounceRate, false)}">${pct(htStats.bounceRate)}</span>
              </div>
            </div>
          </div>

          <div class="comparison-panel google">
            <div class="comparison-panel-header">
              <span class="type-badge type-google">🔍 Google</span>
              <span class="comparison-panel-title">Campaign Performance</span>
            </div>
            <div class="comparison-panel-stats">
              <div class="stat-row">
                <span class="stat-label">Total Campaigns</span>
                <span class="stat-value">${gStats.campaigns}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Total Leads</span>
                <span class="stat-value">${fmt(gStats.leads)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Total Sent</span>
                <span class="stat-value">${fmt(gStats.sent)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Replies</span>
                <span class="stat-value">${fmt(gStats.replies)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Reply Rate</span>
                <span class="stat-value ${isWinner(gStats.replyRate, htStats.replyRate)}">${pct(gStats.replyRate)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Interested</span>
                <span class="stat-value" style="color: var(--green)">${fmt(gStats.interested)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Positive Rate</span>
                <span class="stat-value ${isWinner(gStats.positiveRate, htStats.positiveRate)}">${pct(gStats.positiveRate)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Bounce Rate</span>
                <span class="stat-value ${isWinner(gStats.bounceRate, htStats.bounceRate, false)}">${pct(gStats.bounceRate)}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Domain Health Comparison -->
        <div class="comparison-section">
          <div class="comparison-panel hypertide">
            <div class="comparison-panel-header">
              <span class="type-badge type-hypertide">🌊 HyperTide</span>
              <span class="comparison-panel-title">Domain Health & Performance</span>
            </div>
            <div class="comparison-panel-stats">
              <div class="stat-row">
                <span class="stat-label">Domains</span>
                <span class="stat-value">${htDomainStats.domains}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Email Accounts</span>
                <span class="stat-value">${fmt(htDomainStats.accounts)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Avg Reputation</span>
                <span class="stat-value ${isWinner(htDomainStats.avgReputation, gDomainStats.avgReputation)}">${htDomainStats.avgReputation}%</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Emails Sent</span>
                <span class="stat-value ${isWinner(htDomainStats.sent, gDomainStats.sent)}">${fmt(htDomainStats.sent)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Replies</span>
                <span class="stat-value">${fmt(htDomainStats.replies)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Domain Reply Rate</span>
                <span class="stat-value ${isWinner(htDomainStats.replyRate, gDomainStats.replyRate)}">${pct(htDomainStats.replyRate)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Healthy Domains</span>
                <span class="stat-value" style="color: var(--green)">${htDomainStats.healthy}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Critical Domains</span>
                <span class="stat-value" style="color: var(--red)">${htDomainStats.critical}</span>
              </div>
            </div>
          </div>

          <div class="comparison-panel google">
            <div class="comparison-panel-header">
              <span class="type-badge type-google">🔍 Google</span>
              <span class="comparison-panel-title">Domain Health & Performance</span>
            </div>
            <div class="comparison-panel-stats">
              <div class="stat-row">
                <span class="stat-label">Domains</span>
                <span class="stat-value">${gDomainStats.domains}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Email Accounts</span>
                <span class="stat-value">${fmt(gDomainStats.accounts)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Avg Reputation</span>
                <span class="stat-value ${isWinner(gDomainStats.avgReputation, htDomainStats.avgReputation)}">${gDomainStats.avgReputation}%</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Emails Sent</span>
                <span class="stat-value ${isWinner(gDomainStats.sent, htDomainStats.sent)}">${fmt(gDomainStats.sent)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Replies</span>
                <span class="stat-value">${fmt(gDomainStats.replies)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Domain Reply Rate</span>
                <span class="stat-value ${isWinner(gDomainStats.replyRate, htDomainStats.replyRate)}">${pct(gDomainStats.replyRate)}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Healthy Domains</span>
                <span class="stat-value" style="color: var(--green)">${gDomainStats.healthy}</span>
              </div>
              <div class="stat-row">
                <span class="stat-label">Critical Domains</span>
                <span class="stat-value" style="color: var(--red)">${gDomainStats.critical}</span>
              </div>
            </div>
          </div>
        </div>

        <div style="padding: 12px 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; font-size: 12px; color: var(--text-muted);">
          <strong>🏷️ Type Detection:</strong><br>
          • <span style="color: var(--hypertide)">HyperTide</span>: Campaigns with "HYPERTIDE" in name · Domains with ≥10 accounts<br>
          • <span style="color: var(--google)">Google</span>: Other campaigns · Domains with &lt;10 accounts<br><br>
          <strong>🏆 Winner Highlighting:</strong> Green text = better metric for that group
        </div>
      `;
    }

    // Render Time Comparisons view
    function renderComparisons() {
      if (!data) return '<div class="loading-overlay"><div class="spinner"></div></div>';
      
      const { daily, weekly, monthly, replyBreakdown } = data;

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">Time Comparisons</h1>
            <p class="page-subtitle">Compare performance across different time periods</p>
          </div>
        </div>

        <div class="comparison-grid">
          <div class="comparison-card">
            <div class="comparison-title">📅 Today vs Yesterday</div>
            <div class="comparison-row">
              <span class="comparison-label">Sent</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(daily.today.sent)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(daily.yesterday.sent)}</span>
                <span class="change-badge ${changeClass(daily.change.sentPct)}">${changeText(daily.change.sentPct, '%')}</span>
              </div>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Replies</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(daily.today.replied)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(daily.yesterday.replied)}</span>
                <span class="change-badge ${changeClass(daily.change.repliedPct)}">${changeText(daily.change.repliedPct, '%')}</span>
              </div>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Bounced</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(daily.today.bounced)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(daily.yesterday.bounced)}</span>
              </div>
            </div>
          </div>

          <div class="comparison-card">
            <div class="comparison-title">📆 This Week vs Last Week</div>
            <div class="comparison-row">
              <span class="comparison-label">Sent</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(weekly.thisWeek.sent)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(weekly.lastWeek.sent)}</span>
                <span class="change-badge ${changeClass(weekly.change.sentPct)}">${changeText(weekly.change.sentPct, '%')}</span>
              </div>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Replies</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(weekly.thisWeek.replied)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(weekly.lastWeek.replied)}</span>
                <span class="change-badge ${changeClass(weekly.change.repliedPct)}">${changeText(weekly.change.repliedPct, '%')}</span>
              </div>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Bounced</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(weekly.thisWeek.bounced)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(weekly.lastWeek.bounced)}</span>
              </div>
            </div>
          </div>

          <div class="comparison-card">
            <div class="comparison-title">📅 This Month vs Last Month</div>
            <div class="comparison-row">
              <span class="comparison-label">Sent</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(monthly.thisMonth.sent)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(monthly.lastMonth.sent)}</span>
                <span class="change-badge ${changeClass(monthly.change.sentPct)}">${changeText(monthly.change.sentPct, '%')}</span>
              </div>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Replies</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(monthly.thisMonth.replied)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(monthly.lastMonth.replied)}</span>
                <span class="change-badge ${changeClass(monthly.change.repliedPct)}">${changeText(monthly.change.repliedPct, '%')}</span>
              </div>
            </div>
            <div class="comparison-row">
              <span class="comparison-label">Bounced</span>
              <div style="display: flex; align-items: center; gap: 8px;">
                <span class="comparison-value">${fmt(monthly.thisMonth.bounced)}</span>
                <span style="color: var(--text-muted); font-size: 11px;">vs ${fmt(monthly.lastMonth.bounced)}</span>
              </div>
            </div>
          </div>
        </div>

        <h3 style="font-size: 14px; margin: 24px 0 12px; color: var(--text-muted);">📊 Reply Breakdown (All Time)</h3>
        <div class="summary-cards" style="grid-template-columns: repeat(4, 1fr);">
          <div class="summary-card">
            <div class="summary-card-header">✅ Interested</div>
            <div class="summary-value" style="color: var(--green)">${fmt(replyBreakdown.interested)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">❌ Not Interested</div>
            <div class="summary-value" style="color: var(--red)">${fmt(replyBreakdown.notInterested)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">🏖️ Out of Office</div>
            <div class="summary-value" style="color: var(--yellow)">${fmt(replyBreakdown.outOfOffice)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">🚫 Wrong Person</div>
            <div class="summary-value" style="color: var(--orange)">${fmt(replyBreakdown.wrongPerson)}</div>
          </div>
        </div>
      `;
    }

    // Render Insights view
    function renderInsights() {
      if (!data || !data.insights) return '<div class="loading-overlay"><div class="spinner"></div></div>';

      const { insights, leadMetrics } = data;

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">Insights</h1>
            <p class="page-subtitle">Best and worst performing campaigns</p>
          </div>
        </div>

        <div class="insights-grid">
          <div class="insight-card good">
            <div class="insight-title">✅ Best Performing (Positive Rate)</div>
            ${insights.bestCampaigns.length === 0 ? '<p style="color: var(--text-muted); font-size: 12px;">No campaigns with 10+ leads</p>' : ''}
            ${insights.bestCampaigns.map(c => `
              <div class="insight-item">
                <span class="insight-name" title="${c.name}">${c.name}</span>
                <span class="rate-good">${pct(c.positiveReplyRate)}</span>
              </div>
            `).join('')}
          </div>

          <div class="insight-card bad">
            <div class="insight-title">⚠️ Needs Attention</div>
            ${insights.worstCampaigns.length === 0 ? '<p style="color: var(--text-muted); font-size: 12px;">No campaigns with issues</p>' : ''}
            ${insights.worstCampaigns.map(c => `
              <div class="insight-item">
                <span class="insight-name" title="${c.name}">${c.name}</span>
                <div>
                  <span class="rate-bad">${pct(c.positiveReplyRate)}</span>
                  <span style="color: var(--text-dim); font-size: 10px; margin-left: 4px;">${c.issue}</span>
                </div>
              </div>
            `).join('')}
          </div>

          <div class="insight-card warning">
            <div class="insight-title">📧 High Bounce Rate</div>
            ${insights.highBounce.length === 0 ? '<p style="color: var(--text-muted); font-size: 12px;">No campaigns with high bounce</p>' : ''}
            ${insights.highBounce.map(c => `
              <div class="insight-item">
                <span class="insight-name" title="${c.name}">${c.name}</span>
                <span class="rate-bad">${pct(c.bounceRate)}</span>
              </div>
            `).join('')}
          </div>
        </div>

        <h3 style="font-size: 14px; margin: 24px 0 12px; color: var(--text-muted);">📊 Overall Performance</h3>
        <div class="summary-cards" style="grid-template-columns: repeat(4, 1fr);">
          <div class="summary-card">
            <div class="summary-card-header">Total Leads</div>
            <div class="summary-value">${fmt(leadMetrics.totalLeads)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">Reply Rate</div>
            <div class="summary-value" class="${rateClass(leadMetrics.replyRate)}">${pct(leadMetrics.replyRate)}</div>
            <div class="summary-sub">${fmt(leadMetrics.totalReplies)} replies</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">Positive Rate</div>
            <div class="summary-value" style="color: var(--green)">${pct(leadMetrics.positiveReplyRate)}</div>
            <div class="summary-sub">${fmt(leadMetrics.totalInterested)} interested</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">Bounce Rate</div>
            <div class="summary-value" style="color: ${parseFloat(leadMetrics.bounceRate) > 3 ? 'var(--red)' : 'var(--green)'}">${pct(leadMetrics.bounceRate)}</div>
            <div class="summary-sub">${fmt(leadMetrics.totalBounced)} bounced</div>
          </div>
        </div>
      `;
    }

    // Render Sequence Analysis view
    function renderSequenceAnalysis() {
      if (!sequenceData) {
        return `
          <div class="page-header">
            <div>
              <h1 class="page-title">📊 Sequence Analysis</h1>
              <p class="page-subtitle">Analyze which email step gets the most replies</p>
            </div>
            <button class="btn btn-primary" onclick="loadSequenceData()">
              <span>📊</span> Load Sequence Data
            </button>
          </div>
          <div style="padding: 40px; text-align: center; color: var(--text-muted);">
            <p style="font-size: 48px; margin-bottom: 16px;">📧</p>
            <p>Click "Load Sequence Data" to analyze which email step performs best.</p>
            <p style="font-size: 12px; margin-top: 8px;">This may take a minute as we fetch statistics for all campaigns.</p>
          </div>
        `;
      }

      const { aggregate, byType, campaigns } = sequenceData;

      // Helper to render sequence table
      const renderSequenceTable = (sequences, title, typeClass = '') => {
        if (!sequences || sequences.length === 0) {
          return `<div style="padding: 16px; color: var(--text-muted);">No sequence data available</div>`;
        }

        return `
          <table>
            <thead>
              <tr>
                <th>Email Step</th>
                <th>Leads at Step</th>
                <th>Replies</th>
                <th>Reply Rate</th>
                <th>Interested</th>
                <th>Positive Rate</th>
              </tr>
            </thead>
            <tbody>
              ${sequences.map(s => `
                <tr>
                  <td><strong>Email ${s.sequenceNumber}</strong></td>
                  <td>${fmt(s.sent)}</td>
                  <td>${fmt(s.replied)}</td>
                  <td class="${rateClass(s.replyRate)}">${(Number(s.replyRate) || 0).toFixed(2)}%</td>
                  <td style="color: var(--green)">${fmt(s.interested)}</td>
                  <td class="${positiveRateClass(s.positiveRate)}">${(Number(s.positiveRate) || 0).toFixed(2)}%</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        `;
      };

      // Helper to render analysis box
      const renderAnalysis = (analysis, title = '') => {
        if (!analysis) return '';
        
        return `
          <div style="background: rgba(0,0,0,0.3); border-radius: 8px; padding: 16px; margin-top: 16px;">
            <div style="font-size: 13px; font-weight: 600; margin-bottom: 12px; color: var(--text-muted);">🤖 AI Analysis ${title}</div>
            
            ${analysis.bestPerformer ? `
              <div style="padding: 8px 12px; background: var(--green-bg); border-radius: 6px; margin-bottom: 8px;">
                <span style="color: var(--green); font-weight: 600;">🏆 Best Performer:</span>
                <span style="color: var(--green);">Email ${analysis.bestPerformer.sequenceNumber} (${analysis.bestPerformer.replyRate}% reply rate)</span>
              </div>
            ` : ''}
            
            ${analysis.underperformer ? `
              <div style="padding: 8px 12px; background: var(--yellow-bg); border-radius: 6px; margin-bottom: 8px;">
                <span style="color: var(--yellow); font-weight: 600;">⚠️ Underperformer:</span>
                <span style="color: var(--yellow);">Email ${analysis.underperformer.sequenceNumber} (${analysis.underperformer.replyRate}% reply rate)</span>
              </div>
            ` : ''}
            
            ${analysis.bestByPositive ? `
              <div style="padding: 8px 12px; background: var(--purple-bg); border-radius: 6px; margin-bottom: 8px;">
                <span style="color: var(--purple); font-weight: 600;">⭐ Highest Quality:</span>
                <span style="color: var(--purple);">Email ${analysis.bestByPositive.sequenceNumber} (${analysis.bestByPositive.positiveRate}% positive rate)</span>
              </div>
            ` : ''}
            
            ${analysis.insights && analysis.insights.length > 0 ? `
              <div style="margin-top: 12px;">
                ${analysis.insights.map(insight => `
                  <div style="padding: 8px 12px; background: var(--blue-bg); border-radius: 6px; margin-bottom: 6px; font-size: 12px;">
                    <span style="color: var(--blue);">💡</span>
                    <span style="color: var(--blue);">${insight}</span>
                  </div>
                `).join('')}
              </div>
            ` : ''}
          </div>
        `;
      };

      // Render per-campaign breakdown with expandable rows
      const renderCampaignBreakdown = (campaignList, type) => {
        if (!campaignList || campaignList.length === 0) return '';
        
        return campaignList.map(c => {
          const isExpanded = expandedCampaigns.has(c.id);
          const verifyClass = c.verification?.match ? 'status-success' : 'status-warning';
          
          let detailsHtml = '';
          if (isExpanded) {
            detailsHtml = `
              <tr class="child-row" data-parent="campaign_${c.id}">
                <td colspan="6" style="padding: 16px 40px;">
                  ${renderSequenceTable(c.sequences)}
                  ${renderAnalysis(c.analysis)}
                  <div style="margin-top: 12px; font-size: 11px; color: var(--text-dim);">
                    Verification: ${c.verification?.totalRepliesFromSequences} replies from sequences vs ${c.verification?.expectedReplies} expected
                    <span class="status-badge ${verifyClass}" style="margin-left: 8px;">
                      ${c.verification?.match ? '✓ Match' : '⚠ Variance'}
                    </span>
                  </div>
                </td>
              </tr>
            `;
          }
          
          // Calculate totals for summary row
          const totalReplies = c.sequences?.reduce((sum, s) => sum + s.replied, 0) || 0;
          const totalInterested = c.sequences?.reduce((sum, s) => sum + s.interested, 0) || 0;
          const avgReplyRate = c.sequences?.length > 0 
            ? (c.sequences.reduce((sum, s) => sum + s.replyRate, 0) / c.sequences.length) 
            : 0;
          
          return `
            <tr class="expandable-row" onclick="toggleCampaign(${c.id})">
              <td>
                <span class="expand-icon ${isExpanded ? 'expanded' : ''}">▶</span>
                <span style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: inline-block; vertical-align: middle;" title="${c.name}">${c.name}</span>
              </td>
              <td>${fmt(c.totalLeads)}</td>
              <td>${c.sequenceCount}</td>
              <td>${fmt(totalReplies)}</td>
              <td style="color: var(--green)">${fmt(totalInterested)}</td>
              <td>
                ${c.analysis?.bestPerformer ? `
                  <span style="color: var(--green);">Email ${c.analysis.bestPerformer.sequenceNumber}</span>
                  <span style="color: var(--text-dim); font-size: 11px;">(${c.analysis.bestPerformer.replyRate}%)</span>
                ` : '-'}
              </td>
            </tr>
            ${detailsHtml}
          `;
        }).join('');
      };

      // Filter campaigns by type
      const htCampaigns = campaigns.filter(c => c.name.toUpperCase().includes('HYPERTIDE'));
      const gCampaigns = campaigns.filter(c => !c.name.toUpperCase().includes('HYPERTIDE'));

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">📊 Sequence Analysis</h1>
            <p class="page-subtitle">Which email step gets the most replies?</p>
          </div>
          <div class="header-actions">
            <button class="btn btn-default" onclick="loadSequenceData(true)">
              <span>↻</span> Refresh
            </button>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards" style="grid-template-columns: repeat(4, 1fr);">
          <div class="summary-card">
            <div class="summary-card-header">📊 Total Campaigns</div>
            <div class="summary-value">${fmt(aggregate.totalCampaigns)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">👥 Total Leads</div>
            <div class="summary-value">${fmt(aggregate.totalLeads)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">🏆 Best Performer</div>
            <div class="summary-value" style="color: var(--green)">
              ${aggregate.analysis?.bestPerformer ? `Email ${aggregate.analysis.bestPerformer.sequenceNumber}` : '-'}
            </div>
            <div class="summary-sub">${aggregate.analysis?.bestPerformer ? `${aggregate.analysis.bestPerformer.replyRate}% reply rate` : ''}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">⚠️ Needs Work</div>
            <div class="summary-value" style="color: var(--yellow)">
              ${aggregate.analysis?.underperformer ? `Email ${aggregate.analysis.underperformer.sequenceNumber}` : '-'}
            </div>
            <div class="summary-sub">${aggregate.analysis?.underperformer ? `${aggregate.analysis.underperformer.replyRate}% reply rate` : ''}</div>
          </div>
        </div>

        <!-- Aggregate Analysis -->
        <div class="table-container">
          <div class="table-header">
            <span class="table-title">📈 Overall Sequence Performance (All Campaigns)</span>
          </div>
          ${renderSequenceTable(aggregate.sequences)}
          ${renderAnalysis(aggregate.analysis)}
        </div>

        <!-- Split by Type -->
        <div class="comparison-section">
          <div class="comparison-panel hypertide">
            <div class="comparison-panel-header">
              <span class="type-badge type-hypertide">🌊 HyperTide</span>
              <span class="comparison-panel-title">${byType.hypertide.campaigns} Campaigns</span>
            </div>
            <div style="padding: 0;">
              ${renderSequenceTable(byType.hypertide.sequences)}
              ${renderAnalysis(byType.hypertide.analysis)}
            </div>
          </div>

          <div class="comparison-panel google">
            <div class="comparison-panel-header">
              <span class="type-badge type-google">🔍 Google</span>
              <span class="comparison-panel-title">${byType.google.campaigns} Campaigns</span>
            </div>
            <div style="padding: 0;">
              ${renderSequenceTable(byType.google.sequences)}
              ${renderAnalysis(byType.google.analysis)}
            </div>
          </div>
        </div>

        <!-- Per-Campaign Breakdown: HyperTide -->
        <div class="table-container">
          <div class="table-header">
            <span class="table-title">
              <span class="type-badge type-hypertide">🌊 HyperTide</span>
              Per-Campaign Breakdown (click to expand)
            </span>
          </div>
          <table>
            <thead>
              <tr>
                <th style="min-width: 250px">Campaign</th>
                <th>Leads</th>
                <th>Sequences</th>
                <th>Total Replies</th>
                <th>Interested</th>
                <th>Best Step</th>
              </tr>
            </thead>
            <tbody>
              ${renderCampaignBreakdown(htCampaigns, 'hypertide')}
            </tbody>
          </table>
        </div>

        <!-- Per-Campaign Breakdown: Google -->
        <div class="table-container">
          <div class="table-header">
            <span class="table-title">
              <span class="type-badge type-google">🔍 Google</span>
              Per-Campaign Breakdown (click to expand)
            </span>
          </div>
          <table>
            <thead>
              <tr>
                <th style="min-width: 250px">Campaign</th>
                <th>Leads</th>
                <th>Sequences</th>
                <th>Total Replies</th>
                <th>Interested</th>
                <th>Best Step</th>
              </tr>
            </thead>
            <tbody>
              ${renderCampaignBreakdown(gCampaigns, 'google')}
            </tbody>
          </table>
        </div>

        <div style="margin-top: 16px; padding: 12px 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; font-size: 12px; color: var(--text-muted);">
          <strong>📐 How it works:</strong><br>
          • "Leads at Step" = how many leads reached that sequence step<br>
          • "Reply Rate" = Replies at that step ÷ Leads at that step<br>
          • "Positive Rate" = Interested replies ÷ Total replies at that step<br><br>
          <strong>🔍 Verification:</strong> Total replies across steps should match campaign reply_count from SmartLead
        </div>
      `;
    }

    // Toggle campaign expansion
    function toggleCampaign(campaignId) {
      if (expandedCampaigns.has(campaignId)) {
        expandedCampaigns.delete(campaignId);
      } else {
        expandedCampaigns.add(campaignId);
      }
      render();
    }

    // Render Domain Health view - split by HyperTide vs Google with expandable rows
    function renderDomains() {
      if (!warmupData || !warmupData.domainHealth) {
        return '<div class="loading-overlay"><div class="spinner"></div></div>';
      }

      const domains = warmupData.domainHealth || [];
      const { hypertide, google } = splitDomains(domains);
      const htStats = calcDomainGroupStats(hypertide);
      const gStats = calcDomainGroupStats(google);
      
      // Campaign stats from mailbox statistics
      const campaignStats = warmupData.campaignStats || { totalSent: 0, totalReplies: 0, totalBounced: 0, overallReplyRate: 0 };

      // Get accounts by domain for expandable rows
      const accountsByDomain = warmupData.accountsByDomain || {};

      const renderDomainTable = (domainList, type, stats) => {
        // Calculate totals for this group
        const groupSent = domainList.reduce((sum, d) => sum + (d.sent || 0), 0);
        const groupReplies = domainList.reduce((sum, d) => sum + (d.replies || 0), 0);
        const groupBounced = domainList.reduce((sum, d) => sum + (d.bounced || 0), 0);
        const groupReplyRate = groupSent > 0 ? (groupReplies / groupSent * 100) : 0;
        
        const rows = domainList.map(d => {
          const isExpanded = expandedDomains.has(d.domain);
          const domainAccounts = accountsByDomain[d.domain] || [];
          
          let childRows = '';
          if (isExpanded && domainAccounts.length > 0) {
            childRows = domainAccounts.map(acc => `
              <tr class="child-row" data-parent="${d.domain}">
                <td></td>
                <td style="color: var(--text-muted)">${acc.email}</td>
                <td class="${rateClass(acc.replyRate || 0)}">${pct(acc.replyRate || 0)}</td>
                <td>${fmt(acc.bounced || 0)}</td>
                <td>
                  <span class="status-badge ${acc.warmupStatus === 'ACTIVE' ? 'status-success' : 'status-warning'}">
                    ${acc.warmupStatus || 'N/A'}
                  </span>
                  <span style="margin-left: 4px; color: var(--text-dim); font-size: 10px;">${acc.warmupReputation || 0}%</span>
                </td>
              </tr>
            `).join('');
          }

          return `
            <tr class="expandable-row" onclick="toggleDomain('${d.domain}')">
              <td>
                <span class="expand-icon ${isExpanded ? 'expanded' : ''}">▶</span>
                ${d.domain}
              </td>
              <td>${d.accounts}</td>
              <td class="${rateClass(d.replyRate || 0)}">${pct(d.replyRate || 0)}</td>
              <td>${fmt(d.bounced || 0)}</td>
              <td>
                <span class="status-badge ${d.status === 'healthy' ? 'status-success' : d.status === 'warning' ? 'status-warning' : 'status-error'}">
                  ${d.status}
                </span>
                <span style="margin-left: 4px; color: var(--text-dim); font-size: 10px;">${d.avgReputation}%</span>
              </td>
            </tr>
            ${childRows}
          `;
        }).join('');

        return `
          <div class="table-container">
            <div class="table-header">
              <span class="table-title">
                <span class="type-badge type-${type}">${type === 'hypertide' ? '🌊 HyperTide' : '🔍 Google'}</span>
                ${domainList.length} Domains · ${fmt(stats.accounts)} Accounts · ${pct(groupReplyRate)} Reply Rate
              </span>
            </div>
            <table>
              <thead>
                <tr>
                  <th style="min-width: 180px">Domain</th>
                  <th>Accounts</th>
                  <th>Reply Rate</th>
                  <th>Bounced</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                ${rows}
              </tbody>
            </table>
          </div>
        `;
      };

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">Domain Health</h1>
            <p class="page-subtitle">Campaign performance metrics by domain - click rows to expand</p>
          </div>
          <div style="display: flex; gap: 12px; align-items: center;">
            <div style="font-size: 12px; color: var(--text-muted); padding: 8px 14px; border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 14px;">⚡</span>
              <span>SmartLead API · Live</span>
            </div>
            <button class="btn btn-default" onclick="loadWarmup(true)">
              <span>↻</span> Refresh
            </button>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="summary-cards" style="grid-template-columns: repeat(4, 1fr);">
          <div class="summary-card">
            <div class="summary-card-header">💬 Reply Rate</div>
            <div class="summary-value">${pct(campaignStats.overallReplyRate)}</div>
            <div class="summary-sub">${fmt(campaignStats.totalReplies)} replies</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">⚠️ Bounce Rate</div>
            <div class="summary-value" style="color: ${campaignStats.overallBounceRate > 3 ? 'var(--red)' : 'var(--text)'}">${pct(campaignStats.overallBounceRate)}</div>
            <div class="summary-sub">${fmt(campaignStats.totalBounced)} bounced</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">✅ Healthy</div>
            <div class="summary-value" style="color: var(--green)">${htStats.healthy + gStats.healthy}</div>
            <div class="summary-sub">≥70% reputation</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">🚨 Critical</div>
            <div class="summary-value" style="color: var(--red)">${htStats.critical + gStats.critical}</div>
            <div class="summary-sub">&lt;50% reputation</div>
          </div>
        </div>

        <!-- HyperTide Domains -->
        ${renderDomainTable(hypertide, 'hypertide', htStats)}
        
        <!-- Google Domains -->
        ${renderDomainTable(google, 'google', gStats)}

        <div style="margin-top: 12px; font-size: 11px; color: var(--text-dim);">
          Type detection: ≥10 accounts = HyperTide.
        </div>
      `;
    }

    // Render Warmup Stats view - focused on warmup-specific metrics
    function renderWarmup() {
      if (!warmupData || !warmupData.domainHealth) {
        return '<div class="loading-overlay"><div class="spinner"></div></div>';
      }

      const domains = warmupData.domainHealth || [];
      const { hypertide, google } = splitDomains(domains);
      const accountsByDomain = warmupData.accountsByDomain || {};
      const capacity = warmupData.capacity || {};
      const dataIssues = warmupData.dataIssues || [];
      const warmupBuckets = warmupData.byWarmupReplyRate || {};
      const warmupHealthy = (warmupBuckets.excellent || 0) + (warmupBuckets.good || 0);
      const warmupWatch = warmupBuckets.fair || 0;
      const warmupRisk = warmupBuckets.poor || 0;

      // Helper for warmup reply rate color
      const warmupRateClass = (rate) => rate >= 90 ? 'rate-good' : rate >= 70 ? 'rate-ok' : 'rate-bad';

      const renderWarmupTable = (domainList, type) => {
        const rows = domainList.map(d => {
          const isExpanded = expandedDomains.has('warmup_' + d.domain);
          const domainAccounts = accountsByDomain[d.domain] || [];
          const hasFlags = d.flags && d.flags.length > 0;
          
          let childRows = '';
          if (isExpanded && domainAccounts.length > 0) {
            childRows = domainAccounts.map(acc => `
              <tr class="child-row" data-parent="warmup_${d.domain}">
                <td></td>
                <td style="color: var(--text-muted); font-size: 11px;">${acc.email}</td>
                <td class="${warmupRateClass(acc.warmupReplyRate || 0)}">${acc.warmupReplyRate || 0}%</td>
                <td class="${reputationClass(acc.warmupReputation || 0)}">${acc.warmupReputation || 0}%</td>
                <td class="${(acc.utilization || 0) > 50 ? 'rate-good' : 'rate-ok'}">${(acc.utilization || 0).toFixed(0)}%</td>
              </tr>
            `).join('');
          }

          return `
            <tr class="expandable-row" onclick="toggleDomain('warmup_${d.domain}')" ${hasFlags ? 'style="background: rgba(239, 68, 68, 0.05);"' : ''}>
              <td>
                <span class="expand-icon ${isExpanded ? 'expanded' : ''}">▶</span>
                ${d.domain}
                ${hasFlags ? `<span style="color: var(--red); font-size: 10px; margin-left: 4px;">⚠️</span>` : ''}
              </td>
              <td>${d.accounts}</td>
              <td class="${warmupRateClass(d.avgWarmupReplyRate || 0)}">${d.avgWarmupReplyRate || 0}%</td>
              <td class="${reputationClass(d.avgReputation)}">${d.avgReputation}%</td>
              <td class="${(d.utilization || 0) > 50 ? 'rate-good' : 'rate-ok'}">${(d.utilization || 0).toFixed(1)}%</td>
            </tr>
            ${childRows}
          `;
        }).join('');

        return `
          <div class="table-container">
            <div class="table-header">
              <span class="table-title">
                <span class="type-badge type-${type}">${type === 'hypertide' ? '🌊 HyperTide' : '🔍 Google'}</span>
                ${domainList.length} Domains
              </span>
            </div>
            <table>
              <thead>
                <tr>
                  <th style="min-width: 180px">Domain</th>
                  <th>Accounts</th>
                  <th>Warmup Rate</th>
                  <th>Reputation</th>
                  <th>Utilization</th>
                </tr>
              </thead>
              <tbody>
                ${rows}
              </tbody>
            </table>
          </div>
        `;
      };

      const htStats = calcDomainGroupStats(hypertide);
      const gStats = calcDomainGroupStats(google);

      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">🔥 Warmup & Capacity Stats</h1>
            <p class="page-subtitle">Warmup health, sending capacity, and utilization - click rows to expand</p>
          </div>
          <div style="display: flex; gap: 12px; align-items: center;">
            <div style="font-size: 12px; color: var(--text-muted); padding: 8px 14px; border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 14px;">⚡</span>
              <span>SmartLead API · Live</span>
            </div>
            <button class="btn btn-default" onclick="loadWarmup(true)">
              <span>↻</span> Refresh
            </button>
          </div>
        </div>

        <!-- Capacity Cards -->
        <div class="summary-cards" style="grid-template-columns: repeat(3, 1fr);">
          <div class="summary-card">
            <div class="summary-card-header">📧 Total Accounts</div>
            <div class="summary-value">${fmt(warmupData.totalAccounts)}</div>
            <div class="summary-sub">${fmt(warmupData.active)} active warmup</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">📤 Daily Capacity</div>
            <div class="summary-value">${fmt(capacity.dailyCapacity || 0)}</div>
            <div class="summary-sub">${fmt(capacity.dailySent || 0)} sent today</div>
          </div>
          <div class="summary-card" style="${(capacity.dailyUtilization || 0) < 30 ? 'border-color: var(--yellow);' : ''}">
            <div class="summary-card-header">⚡ Utilization</div>
            <div class="summary-value" style="color: ${(capacity.dailyUtilization || 0) > 50 ? 'var(--green)' : 'var(--yellow)'}">${(capacity.dailyUtilization || 0).toFixed(1)}%</div>
            <div class="summary-sub">${(capacity.dailyUtilization || 0) < 30 ? '⚠️ Low usage' : 'of daily capacity'}</div>
          </div>
        </div>

        <!-- Warmup Health -->
        <h3 style="font-size: 14px; margin: 24px 0 12px; color: var(--text-muted);">🔥 Warmup Health</h3>
        <div class="summary-cards" style="grid-template-columns: repeat(3, 1fr); margin-bottom: 24px;">
          <div class="summary-card">
            <div class="summary-card-header">✅ Healthy (≥70%)</div>
            <div class="summary-value" style="color: var(--green)">${fmt(warmupHealthy)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">⚠️ Watch (50-69%)</div>
            <div class="summary-value" style="color: var(--yellow)">${fmt(warmupWatch)}</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-header">🚨 Risk (&lt;50%)</div>
            <div class="summary-value" style="color: var(--red)">${fmt(warmupRisk)}</div>
          </div>
        </div>

        <!-- Data Issues (NEW!) -->
        ${dataIssues.length > 0 ? `
          <div style="margin-bottom: 24px; padding: 12px 16px; background: var(--red-bg); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px;">
            <h3 style="font-size: 13px; margin-bottom: 8px; color: var(--red);">🚨 ${dataIssues.length} Data Issues</h3>
            ${dataIssues.slice(0, 3).map(issue => `
              <div style="display: flex; justify-content: space-between; padding: 6px 0; font-size: 12px;">
                <span style="color: var(--text);">${issue.domain}</span>
                <span style="color: ${issue.severity === 'high' ? 'var(--red)' : 'var(--yellow)'};">${issue.issue}</span>
              </div>
            `).join('')}
            ${dataIssues.length > 3 ? `<div style="color: var(--text-dim); font-size: 11px; margin-top: 6px;">...and ${dataIssues.length - 3} more</div>` : ''}
          </div>
        ` : ''}

        <!-- HyperTide Warmup -->
        ${renderWarmupTable(hypertide, 'hypertide')}
        
        <!-- Google Warmup -->
        ${renderWarmupTable(google, 'google')}

        <!-- Bottlenecks -->
        ${warmupData.bottlenecks && warmupData.bottlenecks.length > 0 ? `
          <div style="margin-top: 24px;">
            <h3 style="font-size: 14px; margin-bottom: 12px; color: var(--text-muted);">🚨 Bottlenecks</h3>
            ${warmupData.bottlenecks.map(b => `
              <div style="padding: 12px 16px; background: ${b.severity === 'high' || b.severity === 'critical' ? 'var(--red-bg)' : 'var(--yellow-bg)'}; border-radius: 8px; margin-bottom: 8px;">
                <strong style="color: ${b.severity === 'high' || b.severity === 'critical' ? 'var(--red)' : 'var(--yellow)'}">${b.issue}</strong>
                <p style="margin-top: 4px; font-size: 12px; color: var(--text-muted)">${b.action}</p>
              </div>
            `).join('')}
          </div>
        ` : ''}

        
      `;
    }

    // Render Verify view
    function renderVerify() {
      return `
        <div class="page-header">
          <div>
            <h1 class="page-title">Verify Data</h1>
            <p class="page-subtitle">Verify dashboard data against SmartLead API</p>
          </div>
          <div style="font-size: 12px; color: var(--text-muted); padding: 8px 14px; border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 14px;">⚡</span>
            <span>SmartLead API · Live</span>
          </div>
        </div>

        <div class="summary-card" style="max-width: 500px;">
          <p style="margin-bottom: 16px; color: var(--text-muted);">
            Click verify to check that our cached data matches the SmartLead API exactly.
          </p>
          <button class="btn btn-primary" onclick="runVerify()">
            <span>🔒</span> Run Verification
          </button>
          <div id="verifyResults" style="margin-top: 16px;"></div>
        </div>
      `;
    }

    // Toggle domain expansion
    function toggleDomain(domain) {
      if (expandedDomains.has(domain)) {
        expandedDomains.delete(domain);
      } else {
        expandedDomains.add(domain);
      }
      render();
    }

    // Render Trends view with historical data from Supabase
    async function renderTrends() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `
        <div class="page-header">
          <div>
            <h1 class="page-title">📈 Historical Trends</h1>
            <p class="page-subtitle">Domain health and campaign performance over time</p>
          </div>
        </div>
        <div class="summary-card" style="margin-bottom: 24px;">
          <p style="color: var(--text-muted);">Loading historical data...</p>
        </div>
      `;
      
      try {
        // Fetch data from Supabase history endpoints
        const [aggRes, domRes, campRes] = await Promise.all([
          fetch('/api/history/aggregate'),
          fetch('/api/history/domains'),
          fetch('/api/history/campaigns')
        ]);
        
        const aggData = await aggRes.json();
        const domData = await domRes.json();
        const campData = await campRes.json();
        
        trendsData = { 
          aggregate: aggData.data || [], 
          domains: domData.data || {},
          campaigns: campData.data || {}
        };
        
        const agg = trendsData.aggregate;
        const domains = Object.entries(trendsData.domains);
        const campaigns = Object.entries(trendsData.campaigns);
        const daysOfData = agg.length;
        
        // Build domain trend table
        const domainRows = domains.map(([domain, snapshots]) => {
          const latest = snapshots[snapshots.length - 1] || {};
          const first = snapshots[0] || {};
          const warmupChange = (latest.warmup_reply_rate || 0) - (first.warmup_reply_rate || 0);
          const trend = warmupChange > 1 ? 'up' : warmupChange < -1 ? 'down' : 'flat';
          const trendIcon = trend === 'up' ? '↑' : trend === 'down' ? '↓' : '→';
          return `
            <tr>
              <td><strong>${domain}</strong></td>
              <td>${(latest.warmup_reply_rate || 0).toFixed(1)}%</td>
              <td>${latest.active_accounts || 0}</td>
              <td>${latest.daily_capacity || 0}</td>
              <td><span class="trend-pill trend-${trend}">${trendIcon} ${Math.abs(warmupChange).toFixed(1)}%</span></td>
            </tr>
          `;
        }).join('');
        
        // Build campaign trend table
        const campaignRows = campaigns.map(([campaignId, snapshots]) => {
          const latest = snapshots[snapshots.length - 1] || {};
          const first = snapshots[0] || {};
          const replyRateChange = (latest.reply_rate || 0) - (first.reply_rate || 0);
          const sentChange = (latest.sent || 0) - (first.sent || 0);
          const trend = replyRateChange > 0.5 ? 'up' : replyRateChange < -0.5 ? 'down' : 'flat';
          const trendIcon = trend === 'up' ? '↑' : trend === 'down' ? '↓' : '→';
          const name = (latest.campaign_name || 'Unknown').substring(0, 50) + ((latest.campaign_name || '').length > 50 ? '...' : '');
          return `
            <tr>
              <td title="${latest.campaign_name || ''}">${name}</td>
              <td>${(latest.sent || 0).toLocaleString()}</td>
              <td>${latest.replied || 0}</td>
              <td>${(latest.reply_rate || 0).toFixed(2)}%</td>
              <td>${latest.interested || 0}</td>
              <td><span class="trend-pill trend-${trend}">${trendIcon} ${Math.abs(replyRateChange).toFixed(2)}%</span></td>
            </tr>
          `;
        }).join('');
        
        // Latest aggregate stats
        const latestAgg = agg[agg.length - 1] || {};
        
        // Calculate 7-day and 30-day summaries
        const sevenDayData = agg.slice(-7);
        const thirtyDayData = agg.slice(-30);
        
        const calcTotals = (data) => ({
          leads: data.reduce((sum, d) => Math.max(sum, d.total_leads || 0), 0),
          replied: data.reduce((sum, d) => Math.max(sum, d.total_replied || 0), 0),
          interested: data.reduce((sum, d) => Math.max(sum, d.total_interested || 0), 0),
          avgWarmup: data.length > 0 ? (data.reduce((sum, d) => sum + (d.avg_warmup_rate || 0), 0) / data.length) : 0
        });
        
        const sevenDay = calcTotals(sevenDayData);
        const thirtyDay = calcTotals(thirtyDayData);
        
        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">📈 Historical Trends</h1>
              <p class="page-subtitle">Domain health and campaign performance over time (${daysOfData} day${daysOfData !== 1 ? 's' : ''} of data)</p>
            </div>
          </div>
          
          <!-- Period Summary Cards -->
          <div class="summary-cards" style="margin-bottom: 24px;">
            <div class="summary-card">
              <div class="card-label">📅 7-Day Summary</div>
              ${daysOfData >= 7 ? `
                <div class="card-value">${sevenDay.replied} replies</div>
                <div class="card-sub">${sevenDay.interested} interested • ${sevenDay.avgWarmup.toFixed(1)}% warmup avg</div>
              ` : `
                <div class="card-value" style="font-size: 16px; color: var(--text-muted);">Need ${7 - daysOfData} more days</div>
                <div class="card-sub">Currently ${daysOfData} day(s) of data</div>
              `}
            </div>
            <div class="summary-card">
              <div class="card-label">📆 30-Day Summary</div>
              ${daysOfData >= 30 ? `
                <div class="card-value">${thirtyDay.replied} replies</div>
                <div class="card-sub">${thirtyDay.interested} interested • ${thirtyDay.avgWarmup.toFixed(1)}% warmup avg</div>
              ` : `
                <div class="card-value" style="font-size: 16px; color: var(--text-muted);">Need ${30 - daysOfData} more days</div>
                <div class="card-sub">Currently ${daysOfData} day(s) of data</div>
              `}
            </div>
            <div class="summary-card">
              <div class="card-label">📊 Current Totals</div>
              <div class="card-value">${(latestAgg.total_leads || 0).toLocaleString()} leads</div>
              <div class="card-sub">${latestAgg.total_replied || 0} replied • ${latestAgg.total_interested || 0} interested</div>
            </div>
          </div>
          
          <div class="trends-grid">
            <div class="chart-card">
              <h3 style="margin-bottom: 16px;">Aggregate Stats Over Time</h3>
              <div class="chart-wrap">
                <canvas id="trendsChart"></canvas>
              </div>
            </div>
            
            <div class="chart-card">
              <h3 style="margin-bottom: 16px;">Latest Snapshot</h3>
              <div style="font-size: 14px; color: var(--text-muted);">
                <p><strong>Date:</strong> ${latestAgg.snapshot_date || 'N/A'}</p>
                <p><strong>Domains:</strong> ${latestAgg.total_domains || 0}</p>
                <p><strong>Accounts:</strong> ${latestAgg.total_accounts || 0} (${latestAgg.active_accounts || 0} active)</p>
                <p><strong>Avg Warmup Rate:</strong> ${(latestAgg.avg_warmup_rate || 0).toFixed(1)}%</p>
                <p><strong>Daily Capacity:</strong> ${latestAgg.daily_capacity || 0}</p>
                <p><strong>Total Leads:</strong> ${(latestAgg.total_leads || 0).toLocaleString()}</p>
                <p><strong>Total Replied:</strong> ${latestAgg.total_replied || 0}</p>
                <p><strong>Interested:</strong> ${latestAgg.total_interested || 0}</p>
              </div>
            </div>
          </div>
          
          <!-- Campaign Trends Table -->
          <div class="table-container" style="margin-bottom: 24px;">
            <div class="table-header">
              <span class="table-title">📧 Campaign Performance Trends (${campaigns.length} campaigns)</span>
            </div>
            <table>
              <thead>
                <tr>
                  <th>Campaign</th>
                  <th>Sent</th>
                  <th>Replied</th>
                  <th>Reply Rate</th>
                  <th>Interested</th>
                  <th>Trend</th>
                </tr>
              </thead>
              <tbody>
                ${campaignRows || '<tr><td colspan="6" style="text-align:center; color: var(--text-muted);">No campaign data yet</td></tr>'}
              </tbody>
            </table>
          </div>
          
          <!-- Domain Trends Table -->
          <div class="table-container">
            <div class="table-header">
              <span class="table-title">🌐 Domain Health Trends (${domains.length} domains)</span>
            </div>
            <table>
              <thead>
                <tr>
                  <th>Domain</th>
                  <th>Warmup Rate</th>
                  <th>Active Accounts</th>
                  <th>Daily Capacity</th>
                  <th>Trend</th>
                </tr>
              </thead>
              <tbody>
                ${domainRows || '<tr><td colspan="5" style="text-align:center; color: var(--text-muted);">No domain data yet</td></tr>'}
              </tbody>
            </table>
          </div>
          
          <div class="summary-card" style="margin-top: 24px; padding: 16px; background: var(--bg-card);">
            <p style="color: var(--text-muted); font-size: 13px;">
              💡 <strong>Note:</strong> Data is captured daily at 6 AM via cron job. 
              7-day and 30-day summaries unlock as more data accumulates. Currently tracking ${daysOfData} day(s).
            </p>
          </div>
        `;
        
        // Draw chart if we have data
        if (agg.length > 0 && typeof Chart !== 'undefined') {
          const ctx = document.getElementById('trendsChart').getContext('2d');
          if (trendsChart) trendsChart.destroy();
          trendsChart = new Chart(ctx, {
            type: 'line',
            data: {
              labels: agg.map(d => d.snapshot_date),
              datasets: [
                {
                  label: 'Avg Warmup Rate %',
                  data: agg.map(d => d.avg_warmup_rate || 0),
                  borderColor: '#22c55e',
                  backgroundColor: 'rgba(34, 197, 94, 0.1)',
                  tension: 0.3,
                  fill: true
                },
                {
                  label: 'Total Replied',
                  data: agg.map(d => d.total_replied || 0),
                  borderColor: '#8b5cf6',
                  backgroundColor: 'rgba(139, 92, 246, 0.1)',
                  tension: 0.3,
                  yAxisID: 'y1'
                }
              ]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              interaction: { intersect: false, mode: 'index' },
              scales: {
                y: { beginAtZero: false, title: { display: true, text: 'Warmup Rate %' } },
                y1: { position: 'right', beginAtZero: true, title: { display: true, text: 'Total Replied' }, grid: { drawOnChartArea: false } }
              }
            }
          });
        }
        
      } catch (err) {
        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">📈 Historical Trends</h1>
              <p class="page-subtitle">Error loading data</p>
            </div>
          </div>
          <div style="padding: 20px; background: var(--red-bg); border: 1px solid var(--red); border-radius: 8px; color: var(--red);">
            <strong>Error:</strong> ${err.message}
          </div>
        `;
      }
    }

    // Render Reply Analytics view
    async function renderReplyAnalytics() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `
        <div class="page-header">
          <div>
            <h1 class="page-title">📊 Reply Analytics</h1>
            <p class="page-subtitle">Campaign performance and reply insights</p>
          </div>
        </div>
        <div class="summary-card" style="margin-bottom: 24px;">
          <p style="color: var(--text-muted);">Loading analytics...</p>
        </div>
      `;

      try {
        const [campaignsRes, summaryRes, funnelRes] = await Promise.all([
          fetch('/api/analytics/campaigns'),
          fetch('/api/replies/summary'),
          fetch('/api/replies/funnel')
        ]);

        if (!campaignsRes.ok) throw new Error('Failed to load campaigns');
        if (!summaryRes.ok) throw new Error('Failed to load summary');

        const campaigns = (await campaignsRes.json()).data || [];
        const summary = await summaryRes.json();
        const funnel = funnelRes.ok ? await funnelRes.json() : { pending: 0, contacted: 0, meeting_scheduled: 0, closed: 0, lost: 0 };

        // Calculate totals
        const totalReplies = campaigns.reduce((sum, c) => sum + c.totalReplies, 0);
        const totalPositive = campaigns.reduce((sum, c) => sum + c.positive, 0);
        const overallRate = totalReplies > 0 ? (totalPositive / totalReplies * 100).toFixed(1) : 0;

        // Group by type
        const hypertide = campaigns.filter(c => c.type === 'hypertide');
        const google = campaigns.filter(c => c.type === 'google');
        const other = campaigns.filter(c => c.type === 'other');

        const htReplies = hypertide.reduce((s, c) => s + c.totalReplies, 0);
        const htPositive = hypertide.reduce((s, c) => s + c.positive, 0);
        const htRate = htReplies > 0 ? (htPositive / htReplies * 100).toFixed(1) : 0;

        const gReplies = google.reduce((s, c) => s + c.totalReplies, 0);
        const gPositive = google.reduce((s, c) => s + c.positive, 0);
        const gRate = gReplies > 0 ? (gPositive / gReplies * 100).toFixed(1) : 0;

        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">📊 Reply Analytics</h1>
              <p class="page-subtitle">Campaign performance and reply insights</p>
            </div>
          </div>

          <!-- Overall Stats -->
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 32px;">
            <div class="summary-card">
              <div class="summary-label">Total Replies</div>
              <div class="summary-value" style="color: var(--blue);">${totalReplies}</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">Positive Rate</div>
              <div class="summary-value" style="color: var(--green);">${overallRate}%</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">Campaigns</div>
              <div class="summary-value">${campaigns.length}</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">Pending Follow-up</div>
              <div class="summary-value" style="color: var(--yellow);">${summary.byStatus?.pending || 0}</div>
            </div>
          </div>

          <!-- Sales Funnel -->
          <h2 style="margin-bottom: 16px; font-size: 18px;">📈 Sales Funnel</h2>
          <div style="display: flex; gap: 8px; margin-bottom: 32px; align-items: flex-end;">
            <div style="flex: 1; text-align: center;">
              <div style="background: var(--yellow-bg); border: 2px solid var(--yellow); height: ${Math.max(40, funnel.pending * 2)}px; border-radius: 8px 8px 0 0; display: flex; align-items: center; justify-content: center; min-height: 60px;">
                <span style="font-size: 20px; font-weight: bold; color: var(--yellow);">${funnel.pending}</span>
              </div>
              <div style="padding: 8px; background: var(--bg-card); font-size: 12px;">⏳ Pending</div>
            </div>
            <div style="flex: 1; text-align: center;">
              <div style="background: var(--blue-bg); border: 2px solid var(--blue); height: ${Math.max(40, funnel.contacted * 3)}px; border-radius: 8px 8px 0 0; display: flex; align-items: center; justify-content: center; min-height: 60px;">
                <span style="font-size: 20px; font-weight: bold; color: var(--blue);">${funnel.contacted}</span>
              </div>
              <div style="padding: 8px; background: var(--bg-card); font-size: 12px;">📞 Contacted</div>
            </div>
            <div style="flex: 1; text-align: center;">
              <div style="background: var(--purple-bg); border: 2px solid var(--purple); height: ${Math.max(40, funnel.meeting_scheduled * 5)}px; border-radius: 8px 8px 0 0; display: flex; align-items: center; justify-content: center; min-height: 60px;">
                <span style="font-size: 20px; font-weight: bold; color: var(--purple);">${funnel.meeting_scheduled}</span>
              </div>
              <div style="padding: 8px; background: var(--bg-card); font-size: 12px;">📅 Meeting</div>
            </div>
            <div style="flex: 1; text-align: center;">
              <div style="background: var(--green-bg); border: 2px solid var(--green); height: ${Math.max(40, funnel.closed * 10)}px; border-radius: 8px 8px 0 0; display: flex; align-items: center; justify-content: center; min-height: 60px;">
                <span style="font-size: 20px; font-weight: bold; color: var(--green);">${funnel.closed}</span>
              </div>
              <div style="padding: 8px; background: var(--bg-card); font-size: 12px;">🎉 Closed</div>
            </div>
            <div style="flex: 1; text-align: center;">
              <div style="background: var(--bg-card); border: 2px solid var(--border); height: ${Math.max(40, funnel.lost * 5)}px; border-radius: 8px 8px 0 0; display: flex; align-items: center; justify-content: center; min-height: 60px;">
                <span style="font-size: 20px; font-weight: bold; color: var(--text-dim);">${funnel.lost}</span>
              </div>
              <div style="padding: 8px; background: var(--bg-card); font-size: 12px;">❌ Lost</div>
            </div>
          </div>

          <!-- HyperTide vs Google Comparison -->
          <h2 style="margin-bottom: 16px; font-size: 18px;">⚔️ HyperTide vs Google</h2>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px;">
            <div style="background: var(--bg-card); border-radius: 12px; padding: 24px; border-top: 3px solid var(--cyan);">
              <h3 style="color: var(--cyan); margin-bottom: 16px;">🌊 HyperTide</h3>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Total Replies</div>
                  <div style="font-size: 24px; font-weight: bold;">${htReplies}</div>
                </div>
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Positive Rate</div>
                  <div style="font-size: 24px; font-weight: bold; color: var(--green);">${htRate}%</div>
                </div>
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Positive</div>
                  <div style="font-size: 20px; font-weight: bold; color: var(--green);">${htPositive}</div>
                </div>
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Campaigns</div>
                  <div style="font-size: 20px;">${hypertide.length}</div>
                </div>
              </div>
              <!-- Progress bar -->
              <div style="margin-top: 16px; background: var(--bg-main); border-radius: 8px; height: 12px; overflow: hidden;">
                <div style="height: 100%; width: ${htRate}%; background: linear-gradient(90deg, var(--cyan), var(--green));"></div>
              </div>
            </div>

            <div style="background: var(--bg-card); border-radius: 12px; padding: 24px; border-top: 3px solid var(--purple);">
              <h3 style="color: var(--purple); margin-bottom: 16px;">🔮 Google</h3>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Total Replies</div>
                  <div style="font-size: 24px; font-weight: bold;">${gReplies}</div>
                </div>
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Positive Rate</div>
                  <div style="font-size: 24px; font-weight: bold; color: var(--green);">${gRate}%</div>
                </div>
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Positive</div>
                  <div style="font-size: 20px; font-weight: bold; color: var(--green);">${gPositive}</div>
                </div>
                <div>
                  <div style="font-size: 13px; color: var(--text-muted);">Campaigns</div>
                  <div style="font-size: 20px;">${google.length}</div>
                </div>
              </div>
              <!-- Progress bar -->
              <div style="margin-top: 16px; background: var(--bg-main); border-radius: 8px; height: 12px; overflow: hidden;">
                <div style="height: 100%; width: ${gRate}%; background: linear-gradient(90deg, var(--purple), var(--green));"></div>
              </div>
            </div>
          </div>

          <!-- Top Campaigns by Positive Rate -->
          <h2 style="margin-bottom: 16px; font-size: 18px;">🏆 Top Campaigns by Positive Rate</h2>
          <div class="data-table">
            <table>
              <thead>
                <tr>
                  <th>Campaign</th>
                  <th>Type</th>
                  <th>Replies</th>
                  <th>Positive</th>
                  <th>Rate</th>
                  <th>Meetings</th>
                  <th>Booked</th>
                </tr>
              </thead>
              <tbody>
                ${campaigns
                  .filter(c => c.totalReplies >= 10)
                  .sort((a, b) => parseFloat(b.positiveRate) - parseFloat(a.positiveRate))
                  .slice(0, 15)
                  .map(c => {
                    const typeColor = c.type === 'hypertide' ? 'var(--cyan)' : c.type === 'google' ? 'var(--purple)' : 'var(--text-muted)';
                    const rateColor = parseFloat(c.positiveRate) >= 30 ? 'var(--green)' : parseFloat(c.positiveRate) >= 15 ? 'var(--yellow)' : 'var(--text-muted)';
                    return `
                      <tr>
                        <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${c.name}</td>
                        <td><span style="color: ${typeColor}; font-size: 12px; font-weight: 500;">${c.type.toUpperCase()}</span></td>
                        <td>${c.totalReplies}</td>
                        <td style="color: var(--green);">${c.positive}</td>
                        <td style="color: ${rateColor}; font-weight: 600;">${c.positiveRate}%</td>
                        <td>${c.meetingRequests}</td>
                        <td style="color: var(--accent);">${c.booked}</td>
                      </tr>
                    `;
                  }).join('')}
              </tbody>
            </table>
          </div>

          <!-- Category Breakdown -->
          <h2 style="margin-top: 32px; margin-bottom: 16px; font-size: 18px;">📋 Reply Category Breakdown</h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px;">
            ${Object.entries(summary.byCategory || {})
              .sort((a, b) => b[1] - a[1])
              .map(([cat, count]) => {
                const emoji = cat === 'Booked' ? '🎉' :
                              cat === 'Meeting Request' ? '📅' :
                              cat === 'Information Request' ? '❓' :
                              cat === 'Interested' ? '✨' :
                              cat === 'Not Interested' ? '❌' :
                              cat === 'Out Of Office' ? '🏖️' : '📧';
                const isPositive = ['Booked', 'Meeting Request', 'Information Request', 'Interested'].includes(cat);
                return `
                  <div class="summary-card" style="${isPositive ? 'border-left: 3px solid var(--green);' : ''}">
                    <div style="font-size: 24px; margin-bottom: 8px;">${emoji}</div>
                    <div class="summary-label">${cat}</div>
                    <div class="summary-value" style="color: ${isPositive ? 'var(--green)' : 'var(--text-muted)'};">${count}</div>
                  </div>
                `;
              }).join('')}
          </div>
        `;

      } catch (err) {
        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">📊 Reply Analytics</h1>
              <p class="page-subtitle">Error loading data</p>
            </div>
          </div>
          <div style="padding: 20px; background: var(--red-bg); border: 1px solid var(--red); border-radius: 8px; color: var(--red);">
            <strong>Error:</strong> ${err.message}
          </div>
        `;
      }
    }

    // Render Positive Replies view
    async function renderReplies() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `
        <div class="page-header">
          <div>
            <h1 class="page-title">💬 Positive Replies</h1>
            <p class="page-subtitle">Leads showing interest - follow up!</p>
          </div>
        </div>
        <div class="summary-card" style="margin-bottom: 24px;">
          <p style="color: var(--text-muted);">Loading reply data...</p>
        </div>
      `;

      try {
        // Load summary and positive replies
        const statusFilter = window.replyFilter || 'pending';
        const statusParam = statusFilter ? `&status=${statusFilter}` : '';
        const [summaryRes, repliesRes] = await Promise.all([
          fetch('/api/replies/summary'),
          fetch(`/api/replies/positive?limit=100&days=90${statusParam}`)
        ]);

        if (!summaryRes.ok) throw new Error('Failed to load summary');
        if (!repliesRes.ok) throw new Error('Failed to load replies');

        const summary = await summaryRes.json();
        const repliesData = await repliesRes.json();
        const replies = repliesData.data || [];

        // Group by category
        const byCategory = {};
        replies.forEach(r => {
          const cat = r.reply_category || 'Unknown';
          if (!byCategory[cat]) byCategory[cat] = [];
          byCategory[cat].push(r);
        });

        content.innerHTML = `
          <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
              <h1 class="page-title">💬 Positive Replies</h1>
              <p class="page-subtitle">Leads showing interest - follow up!</p>
            </div>
            <div style="display: flex; gap: 12px; align-items: center;">
              <a href="https://supabase.com/dashboard/project/rwhqshjmngkyremwandx/editor/29275" target="_blank" style="font-size: 12px; color: var(--green); text-decoration: none; padding: 8px 14px; border: 1px solid var(--green); border-radius: 6px; display: flex; align-items: center; gap: 8px;" title="View imann_positive_replies table in Supabase">
                <span style="font-size: 14px;">📊</span>
                <span style="display: flex; flex-direction: column; line-height: 1.3;">
                  <span style="font-weight: 600;">imann_positive_replies</span>
                  <span style="font-size: 10px; opacity: 0.7;">${summary.positiveReplies} rows · Supabase</span>
                </span>
              </a>
              <a href="/api/replies/export?status=pending" 
                 style="background: var(--accent); color: white; padding: 10px 16px; border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: 500;">
                📥 Export Pending (CSV)
              </a>
              <button onclick="renderReplies()" 
                      style="background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border); padding: 10px 16px; border-radius: 8px; cursor: pointer; font-size: 13px;">
                ↻ Refresh
              </button>
            </div>
          </div>

          <!-- Summary Cards -->
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card">
              <div class="summary-label">Positive Replies</div>
              <div class="summary-value" style="color: var(--green);">${summary.positiveReplies}</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">Meeting Requests</div>
              <div class="summary-value" style="color: var(--purple);">${summary.byCategory?.['Meeting Request'] || 0}</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">Booked</div>
              <div class="summary-value" style="color: var(--accent);">${summary.byCategory?.['Booked'] || 0}</div>
            </div>
          </div>

          <!-- Status Filter -->
          <div style="display: flex; gap: 12px; margin-bottom: 16px; align-items: center;">
            <span style="color: var(--text-muted); font-size: 13px;">Filter:</span>
            <button onclick="filterReplies('pending')" class="filter-btn ${!window.replyFilter || window.replyFilter === 'pending' ? 'active' : ''}"
                    style="background: ${!window.replyFilter || window.replyFilter === 'pending' ? 'var(--yellow-bg)' : 'var(--bg-card)'}; color: ${!window.replyFilter || window.replyFilter === 'pending' ? 'var(--yellow)' : 'var(--text-muted)'}; border: 1px solid ${!window.replyFilter || window.replyFilter === 'pending' ? 'var(--yellow)' : 'var(--border)'}; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px;">
              ⏳ Pending
            </button>
            <button onclick="filterReplies('contacted')" class="filter-btn ${window.replyFilter === 'contacted' ? 'active' : ''}"
                    style="background: ${window.replyFilter === 'contacted' ? 'var(--blue-bg)' : 'var(--bg-card)'}; color: ${window.replyFilter === 'contacted' ? 'var(--blue)' : 'var(--text-muted)'}; border: 1px solid ${window.replyFilter === 'contacted' ? 'var(--blue)' : 'var(--border)'}; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px;">
              📞 Contacted
            </button>
            <button onclick="filterReplies('done')" class="filter-btn ${window.replyFilter === 'done' ? 'active' : ''}"
                    style="background: ${window.replyFilter === 'done' ? 'var(--green-bg)' : 'var(--bg-card)'}; color: ${window.replyFilter === 'done' ? 'var(--green)' : 'var(--text-muted)'}; border: 1px solid ${window.replyFilter === 'done' ? 'var(--green)' : 'var(--border)'}; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px;">
              ✅ Done
            </button>
            <button onclick="filterReplies('snoozed')" class="filter-btn ${window.replyFilter === 'snoozed' ? 'active' : ''}"
                    style="background: ${window.replyFilter === 'snoozed' ? 'var(--purple-bg)' : 'var(--bg-card)'}; color: ${window.replyFilter === 'snoozed' ? 'var(--purple)' : 'var(--text-muted)'}; border: 1px solid ${window.replyFilter === 'snoozed' ? 'var(--purple)' : 'var(--border)'}; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px;">
              😴 Show Snoozed
            </button>
            <button onclick="filterReplies(null)" class="filter-btn ${window.replyFilter === null ? 'active' : ''}"
                    style="background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px;">
              All
            </button>
          </div>

          <!-- Replies Table -->
          <div class="data-table">
            <table>
              <thead>
                <tr>
                  <th>Priority</th>
                  <th>Lead</th>
                  <th>Category</th>
                  <th>Replied</th>
                  <th>Response Time</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                ${replies
                  .map(r => ({ ...r, score: getLeadScore(r) }))
                  .sort((a, b) => b.score - a.score)
                  .map(r => {
                  const scoreLabel = getScoreLabel(r.score);
                  const responseTime = r.response_time_seconds ? formatResponseTime(r.response_time_seconds) : 'N/A';
                  const repliedDate = new Date(r.replied_at);
                  const daysAgo = Math.floor((Date.now() - repliedDate) / (1000 * 60 * 60 * 24));
                  const snoozeUntilDate = r.snooze_until ? new Date(r.snooze_until) : null;
                  const snoozeUntilText = snoozeUntilDate ? snoozeUntilDate.toLocaleDateString() : '';
                  const statusColor = r.follow_up_status === 'pending' ? 'var(--yellow)' : 
                                     r.follow_up_status === 'contacted' ? 'var(--blue)' : 'var(--green)';
                  return `
                    <tr data-reply-id="${r.id}">
                      <td style="text-align: center;">
                        <span style="color: ${scoreLabel.color}; font-weight: 600; font-size: 11px;">${scoreLabel.text}</span>
                        <div style="font-size: 10px; color: var(--text-dim);">${r.score}</div>
                      </td>
                      <td>
                        <div style="font-weight: 500;">${r.lead_name || 'Unknown'}</div>
                        <div style="font-size: 12px; color: var(--text-muted); display: flex; align-items: center; gap: 6px;">
                          ${r.lead_email || ''}
                          ${r.lead_email ? `<button onclick="copyEmail('${r.lead_email}')" style="background: none; border: none; cursor: pointer; font-size: 10px;" title="Copy email">📋</button>` : ''}
                        </div>
                        ${r.lead_company ? `<div style="font-size: 11px; color: var(--text-dim);">${r.lead_company}</div>` : ''}
                      </td>
                      <td>
                        <span style="background: var(--green-bg); color: var(--green); padding: 4px 8px; border-radius: 4px; font-size: 12px;">
                          ${r.reply_category}
                        </span>
                      </td>
                      <td style="font-size: 12px; color: var(--text-muted);">${daysAgo === 0 ? 'Today' : daysAgo === 1 ? 'Yesterday' : daysAgo + 'd ago'}</td>
                      <td style="font-size: 12px;">${responseTime}</td>
                      <td>
                        <div style="display: flex; gap: 6px; align-items: center;">
                          ${r.follow_up_status === 'pending' ? `
                            <button onclick="updateReplyStatus(${r.id}, 'contacted')" 
                                    style="background: var(--blue-bg); color: var(--blue); border: 1px solid var(--blue); padding: 4px 8px; border-radius: 4px; font-size: 11px; cursor: pointer;">
                              📞 Contacted
                            </button>
                            <div class="snooze-wrap">
                              <button onclick="toggleSnoozeMenu(${r.id})" 
                                      style="background: var(--orange-bg); color: var(--orange); border: 1px solid var(--orange); padding: 4px 8px; border-radius: 4px; font-size: 11px; cursor: pointer;">
                                😴 Snooze
                              </button>
                              <div id="snooze-menu-${r.id}" class="snooze-menu" onclick="event.stopPropagation()">
                                <select id="snooze-select-${r.id}" onchange="handleSnoozeOptionChange(${r.id})">
                                  <option value="1">Tomorrow</option>
                                  <option value="3">3 days</option>
                                  <option value="7">1 week</option>
                                  <option value="custom">Custom date</option>
                                </select>
                                <div id="snooze-custom-${r.id}" style="display: none; margin-top: 6px;">
                                  <input type="date" id="snooze-date-${r.id}" />
                                </div>
                                <button onclick="applySnooze(${r.id})"
                                        style="background: var(--orange-bg); color: var(--orange); border: 1px solid var(--orange); padding: 6px 8px; border-radius: 6px; font-size: 11px; cursor: pointer;">
                                  ⏰ Snooze
                                </button>
                              </div>
                            </div>
                          ` : r.follow_up_status === 'contacted' ? `
                            <span style="color: var(--blue); font-size: 11px; margin-right: 4px;">📞</span>
                            <button onclick="updateReplyStatus(${r.id}, 'meeting_scheduled')" 
                                    style="background: var(--purple-bg); color: var(--purple); border: 1px solid var(--purple); padding: 4px 8px; border-radius: 4px; font-size: 11px; cursor: pointer;">
                              📅 Meeting
                            </button>
                            <button onclick="updateReplyStatus(${r.id}, 'lost')" 
                                    style="background: var(--bg-card); color: var(--text-dim); border: 1px solid var(--border); padding: 4px 8px; border-radius: 4px; font-size: 11px; cursor: pointer;">
                              ❌
                            </button>
                          ` : r.follow_up_status === 'meeting_scheduled' ? `
                            <span style="color: var(--purple); font-size: 11px; margin-right: 4px;">📅 Meeting</span>
                            <button onclick="updateReplyStatus(${r.id}, 'closed')" 
                                    style="background: var(--green-bg); color: var(--green); border: 1px solid var(--green); padding: 4px 8px; border-radius: 4px; font-size: 11px; cursor: pointer;">
                              🎉 Closed
                            </button>
                          ` : r.follow_up_status === 'snoozed' ? `
                            <span style="color: var(--orange); font-size: 11px; margin-right: 4px;">😴 Snoozed</span>
                            <span style="color: var(--text-muted); font-size: 11px;">${snoozeUntilText ? `until ${snoozeUntilText}` : ''}</span>
                            <button onclick="updateReplyStatus(${r.id}, 'pending')" 
                                    style="background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border); padding: 4px 8px; border-radius: 4px; font-size: 11px; cursor: pointer;">
                              🔔 Resume
                            </button>
                          ` : r.follow_up_status === 'closed' ? `
                            <span style="color: var(--green); font-size: 12px;">🎉 Closed!</span>
                          ` : r.follow_up_status === 'lost' ? `
                            <span style="color: var(--text-dim); font-size: 12px;">❌ Lost</span>
                          ` : `
                            <span style="color: var(--green); font-size: 12px;">✅ Done</span>
                          `}
                        </div>
                      </td>
                    </tr>
                  `;
                }).join('')}
              </tbody>
            </table>
          </div>
        `;
      } catch (err) {
        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">💬 Positive Replies</h1>
              <p class="page-subtitle">Error loading data</p>
            </div>
          </div>
          <div style="padding: 20px; background: var(--red-bg); border: 1px solid var(--red); border-radius: 8px; color: var(--red);">
            <strong>Error:</strong> ${err.message}
          </div>
        `;
      }
    }

    function formatResponseTime(seconds) {
      if (!seconds || seconds <= 0) return 'N/A';
      if (seconds < 60) return seconds + 's';
      if (seconds < 3600) return Math.round(seconds / 60) + 'm';
      if (seconds < 86400) return (seconds / 3600).toFixed(1) + 'h';
      return (seconds / 86400).toFixed(1) + 'd';
    }

    // Update reply follow-up status
    async function updateReplyStatus(id, status, snoozeUntil = null) {
      try {
        const res = await fetch(`/api/replies/positive/${id}/status`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status, snooze_until: snoozeUntil })
        });
        if (!res.ok) throw new Error('Failed to update status');
        
        // Re-render the view
        renderReplies();
      } catch (err) {
        alert('Error updating status: ' + err.message);
      }
    }

    function toggleSnoozeMenu(id) {
      const menu = document.getElementById(`snooze-menu-${id}`);
      if (!menu) return;
      const isOpen = menu.style.display === 'block';
      closeAllSnoozeMenus();
      menu.style.display = isOpen ? 'none' : 'block';
    }

    function closeAllSnoozeMenus() {
      document.querySelectorAll('.snooze-menu').forEach(menu => {
        menu.style.display = 'none';
      });
    }

    function handleSnoozeOptionChange(id) {
      const select = document.getElementById(`snooze-select-${id}`);
      const customWrap = document.getElementById(`snooze-custom-${id}`);
      if (!select || !customWrap) return;
      customWrap.style.display = select.value === 'custom' ? 'block' : 'none';
    }

    function applySnooze(id) {
      const select = document.getElementById(`snooze-select-${id}`);
      if (!select) return;
      let snoozeDate = new Date();
      if (select.value === 'custom') {
        const dateInput = document.getElementById(`snooze-date-${id}`);
        if (!dateInput || !dateInput.value) {
          alert('Please select a custom date.');
          return;
        }
        snoozeDate = new Date(dateInput.value);
      } else {
        const days = parseInt(select.value, 10);
        snoozeDate.setDate(snoozeDate.getDate() + days);
      }
      updateReplyStatus(id, 'snoozed', snoozeDate.toISOString());
    }

    document.addEventListener('click', (event) => {
      if (!event.target.closest('.snooze-wrap')) {
        closeAllSnoozeMenus();
      }
    });

    // Copy email to clipboard
    function copyEmail(email) {
      navigator.clipboard.writeText(email);
      // Show quick toast
      const toast = document.createElement('div');
      toast.textContent = '📋 Email copied!';
      toast.style.cssText = 'position: fixed; bottom: 20px; right: 20px; background: var(--green); color: white; padding: 12px 20px; border-radius: 8px; z-index: 9999;';
      document.body.appendChild(toast);
      setTimeout(() => toast.remove(), 2000);
    }

    // Filter replies by status
    function filterReplies(status) {
      window.replyFilter = status;
      renderReplies();
    }

    // Calculate lead priority score (higher = more urgent)
    function getLeadScore(reply) {
      let score = 0;
      
      // Category scoring (higher = more interested)
      const categoryScores = {
        'Booked': 100,
        'Meeting Request': 80,
        'Meeting Booked': 80,
        'Demo Request': 70,
        'Information Request': 50,
        'Interested': 40
      };
      score += categoryScores[reply.reply_category] || 20;
      
      // WAITING URGENCY (older pending = needs attention NOW)
      // This is the key change - prioritize leads waiting too long
      if (reply.follow_up_status === 'pending') {
        const hoursWaiting = (Date.now() - new Date(reply.replied_at)) / (1000 * 60 * 60);
        if (hoursWaiting > 72) score += 40;       // 3+ days - CRITICAL
        else if (hoursWaiting > 48) score += 30;  // 2-3 days - urgent
        else if (hoursWaiting > 24) score += 25;  // 1-2 days - high
        else if (hoursWaiting > 12) score += 15;  // 12-24h - medium
        else if (hoursWaiting > 4) score += 5;    // 4-12h - normal
        // <4h = fresh, no urgency bonus
      }
      
      // Fast response bonus (they replied quickly = more engaged)
      if (reply.response_time_seconds) {
        if (reply.response_time_seconds < 3600) score += 15;      // < 1 hour
        else if (reply.response_time_seconds < 14400) score += 10; // < 4 hours
        else if (reply.response_time_seconds < 86400) score += 5;  // < 1 day
      }
      
      // Company bonus
      if (reply.lead_company) score += 5;
      
      return score;
    }

    function getScoreLabel(score) {
      if (score >= 130) return { text: '🔴 CRITICAL', color: 'var(--red)' };
      if (score >= 100) return { text: '🟠 HIGH', color: 'var(--accent)' };
      if (score >= 70) return { text: '🟡 MEDIUM', color: 'var(--yellow)' };
      if (score >= 40) return { text: '🟢 LOW', color: 'var(--green)' };
      return { text: '⚪ SKIP', color: 'var(--text-muted)' };
    }

    // Global variable for response time days filter
    let responseTimeDays = 365;
    let hoursMode = 'all'; // 'all' or 'business'
    
    // Global function for date range change
    window.loadResponseTimes = function(days) {
      responseTimeDays = parseInt(days) || 365;
      renderResponseTimes();
    };
    
    // Global function for hours mode toggle
    window.toggleHoursMode = function(mode) {
      hoursMode = mode;
      const data = window.responseTimeData;
      if (!data) return;
      
      const allBtn = document.getElementById('allHoursBtn');
      const businessBtn = document.getElementById('businessHoursBtn');
      
      if (mode === 'all') {
        allBtn.style.background = 'var(--accent)';
        allBtn.style.color = 'white';
        businessBtn.style.background = 'transparent';
        businessBtn.style.color = 'var(--text-muted)';
        updateStatsDisplay(data.overallStats, data.allTime, data.firstStats, data.followUpStats, 'Overall');
        updateMonthlyCards(data.monthlyCards);
        // Response Time Impact on Booking stays the same - it's about correlation, not filtered by hours
      } else {
        businessBtn.style.background = 'var(--accent)';
        businessBtn.style.color = 'white';
        allBtn.style.background = 'transparent';
        allBtn.style.color = 'var(--text-muted)';
        updateStatsDisplay(data.bhStats, data.bhDist, data.bhFirstStats, data.bhFollowUpStats, 'Business Hours');
        updateMonthlyCards(data.bhMonthly);
        // Response Time Impact on Booking stays the same - correlation doesn't change by hours filter
      }
    };
    
    function updateResponseTimeImpact(correlation, summary) {
      // Aggregate into 4 buckets matching the UI
      const fast = correlation.filter(r => ['< 5 min', '5-15 min', '15-30 min', '30-60 min'].includes(r.bucket));
      const medium = correlation.filter(r => ['1-3 hours', '3-6 hours'].includes(r.bucket));
      const slow = correlation.filter(r => ['6-12 hours', '12-24 hours'].includes(r.bucket));
      const verySlow = correlation.filter(r => ['1-2 days', '> 2 days'].includes(r.bucket));
      
      const sum = (arr) => arr.reduce((a, r) => ({ total: a.total + (r.total || 0), booked: a.booked + (r.booked || 0) }), { total: 0, booked: 0 });
      const fastSum = sum(fast);
      const mediumSum = sum(medium);
      const slowSum = sum(slow);
      const verySlowSum = sum(verySlow);
      
      const rate = (s) => s.total > 0 ? Math.round((s.booked / s.total) * 100) : 0;
      
      const impactEl = document.getElementById('responseTimeImpactContent');
      if (impactEl) {
        impactEl.innerHTML = 
          '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(34, 197, 94, 0.15); border-radius: 8px;">' +
            '<div style="font-size: 24px; font-weight: 700; color: var(--green);">' + rate(fastSum) + '%</div>' +
            '<div style="font-size: 11px; color: var(--text-muted);">< 1 hour</div>' +
            '<div style="font-size: 10px; color: var(--text-dim);">' + fastSum.booked + '/' + fastSum.total + '</div>' +
          '</div>' +
          '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(251, 191, 36, 0.15); border-radius: 8px;">' +
            '<div style="font-size: 24px; font-weight: 700; color: var(--yellow);">' + rate(mediumSum) + '%</div>' +
            '<div style="font-size: 11px; color: var(--text-muted);">1-6 hours</div>' +
            '<div style="font-size: 10px; color: var(--text-dim);">' + mediumSum.booked + '/' + mediumSum.total + '</div>' +
          '</div>' +
          '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(249, 115, 22, 0.15); border-radius: 8px;">' +
            '<div style="font-size: 24px; font-weight: 700; color: #f97316;">' + rate(slowSum) + '%</div>' +
            '<div style="font-size: 11px; color: var(--text-muted);">6-24 hours</div>' +
            '<div style="font-size: 10px; color: var(--text-dim);">' + slowSum.booked + '/' + slowSum.total + '</div>' +
          '</div>' +
          '<div style="flex: 1; text-align: center; padding: 12px; background: rgba(239, 68, 68, 0.15); border-radius: 8px;">' +
            '<div style="font-size: 24px; font-weight: 700; color: var(--red);">' + rate(verySlowSum) + '%</div>' +
            '<div style="font-size: 11px; color: var(--text-muted);">> 24 hours</div>' +
            '<div style="font-size: 10px; color: var(--text-dim);">' + verySlowSum.booked + '/' + verySlowSum.total + '</div>' +
          '</div>';
      }
      
      // Also update the booking ratio section if summary is provided
      if (summary) {
        const bookingRatioEl = document.getElementById('bookingRatioValue');
        const bookingDetailsEl = document.getElementById('bookingRatioDetails');
        const bookedCountEl = document.getElementById('bookedCount');
        const schedulingCountEl = document.getElementById('schedulingCount');
        const notBookedCountEl = document.getElementById('notBookedCount');
        
        if (bookingRatioEl) bookingRatioEl.textContent = summary.bookingRate + '%';
        if (bookingDetailsEl) bookingDetailsEl.textContent = summary.booked + ' booked / ' + summary.total + ' companies';
        if (bookedCountEl) bookedCountEl.textContent = summary.booked;
        if (schedulingCountEl) schedulingCountEl.textContent = summary.scheduling;
        if (notBookedCountEl) notBookedCountEl.textContent = summary.notBooked;
      }
    }
    
    function updateStatsDisplay(stats, dist, firstStats, followUpStats, label) {
      const data = window.responseTimeData;
      const formatTime = data.formatTime;
      const getRateClass = data.getRateClass;
      
      // Update labels
      document.getElementById('statsMeanLabel').textContent = label;
      document.getElementById('statsMedianLabel').textContent = label;
      
      // Update stats values (handle both 'count' and 'total' property names)
      document.getElementById('statsMeanValue').textContent = formatTime(stats.avg_seconds);
      document.getElementById('statsMeanCount').textContent = stats.count || stats.total || 0;
      document.getElementById('statsMedianValue').textContent = formatTime(stats.median_seconds || stats.avg_seconds);
      
      // Update first response stats (handle both 'count' and 'total')
      const firstEl = document.getElementById('statsFirstValue');
      if (firstEl) {
        firstEl.textContent = formatTime(firstStats.avg_seconds);
        firstEl.className = 'card-value ' + getRateClass(firstStats.avg_seconds);
      }
      const firstCountEl = document.getElementById('statsFirstCount');
      if (firstCountEl) firstCountEl.textContent = firstStats.count || firstStats.total || 0;
      
      // Update follow-up stats (handle both 'count' and 'total')
      const followupEl = document.getElementById('statsFollowupValue');
      if (followupEl) {
        followupEl.textContent = formatTime(followUpStats.avg_seconds);
        followupEl.className = 'card-value ' + getRateClass(followUpStats.avg_seconds);
      }
      const followupCountEl = document.getElementById('statsFollowupCount');
      if (followupCountEl) followupCountEl.textContent = followUpStats.count || followUpStats.total || 0;
      
      // Calculate percentage helper
      const total = (dist.under_5min||0) + (dist.under_15min||0) + (dist.under_1hr||0) + 
                    (dist.under_3hr||0) + (dist.under_6hr||0) + (dist.under_12hr||0) + 
                    (dist.under_24hr||0) + (dist.over_24hr||0);
      const pct = (v) => total > 0 ? Math.round(v / total * 100) : 0;
      
      // Update distribution counts
      document.getElementById('dist5m').textContent = dist.under_5min || 0;
      document.getElementById('dist15m').textContent = dist.under_15min || 0;
      document.getElementById('dist1h').textContent = dist.under_1hr || 0;
      document.getElementById('dist3h').textContent = dist.under_3hr || 0;
      document.getElementById('dist6h').textContent = dist.under_6hr || 0;
      document.getElementById('dist12h').textContent = dist.under_12hr || 0;
      document.getElementById('dist24h').textContent = dist.under_24hr || 0;
      document.getElementById('distover24h').textContent = dist.over_24hr || 0;
      
      // Update distribution percentages
      document.getElementById('dist5mPct').textContent = pct(dist.under_5min||0) + '%';
      document.getElementById('dist15mPct').textContent = pct(dist.under_15min||0) + '%';
      document.getElementById('dist1hPct').textContent = pct(dist.under_1hr||0) + '%';
      document.getElementById('dist3hPct').textContent = pct(dist.under_3hr||0) + '%';
      document.getElementById('dist6hPct').textContent = pct(dist.under_6hr||0) + '%';
      document.getElementById('dist12hPct').textContent = pct(dist.under_12hr||0) + '%';
      document.getElementById('dist24hPct').textContent = pct(dist.under_24hr||0) + '%';
      document.getElementById('distover24hPct').textContent = pct(dist.over_24hr||0) + '%';
      
      // Update distribution bar heights
      const maxVal = Math.max(
        dist.under_5min||0, dist.under_15min||0, dist.under_1hr||0, dist.under_3hr||0,
        dist.under_6hr||0, dist.under_12hr||0, dist.under_24hr||0, dist.over_24hr||0, 1
      );
      const barHeight = (v) => Math.max(8, ((v||0) / maxVal) * 100) + '%';
      
      const bar5m = document.getElementById('distBar5m');
      const bar15m = document.getElementById('distBar15m');
      const bar1h = document.getElementById('distBar1h');
      const bar3h = document.getElementById('distBar3h');
      const bar6h = document.getElementById('distBar6h');
      const bar12h = document.getElementById('distBar12h');
      const bar24h = document.getElementById('distBar24h');
      const barOver24h = document.getElementById('distBarover24h');
      
      if (bar5m) bar5m.style.height = barHeight(dist.under_5min);
      if (bar15m) bar15m.style.height = barHeight(dist.under_15min);
      if (bar1h) bar1h.style.height = barHeight(dist.under_1hr);
      if (bar3h) bar3h.style.height = barHeight(dist.under_3hr);
      if (bar6h) bar6h.style.height = barHeight(dist.under_6hr);
      if (bar12h) bar12h.style.height = barHeight(dist.under_12hr);
      if (bar24h) bar24h.style.height = barHeight(dist.under_24hr);
      if (barOver24h) barOver24h.style.height = barHeight(dist.over_24hr);
      
      // Update total responses text
      const totalEl = document.getElementById('distTotalResponses');
      if (totalEl) totalEl.textContent = total + ' total responses';
    };
    
    function updateMonthlyCards(cards) {
      const data = window.responseTimeData;
      const formatTime = data.formatTime;
      const monthName = data.monthName;
      const container = document.getElementById('monthlyCardsContainer');
      if (!container || !cards) return;
      
      // Handle empty array - show message instead of blank
      if (cards.length === 0) {
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: var(--text-muted); font-size: 13px;"><p>📊 Monthly breakdown not available for this view.</p><p style="font-size: 12px; margin-top: 8px;">Use "All Hours" to see monthly data, or check the overall stats above.</p></div>';
        return;
      }
      
      container.innerHTML = cards.map(mc => {
        const pct = (v) => mc.total > 0 ? Math.round(v / mc.total * 100) : 0;
        const name = monthName(mc.month);
        return `
        <div class="summary-card" style="margin-bottom: 16px; padding: 16px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <div class="card-label" style="margin: 0;">
              📅 ${name} — ${mc.total} responses
            </div>
            <div style="font-size: 13px; color: var(--text-muted);">Avg: ${formatTime(mc.avgSeconds)}</div>
          </div>
          <table style="width: 100%; text-align: center; border-collapse: collapse;">
            <thead>
              <tr>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 5m</th>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 15m</th>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 1h</th>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 3h</th>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 6h</th>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 12h</th>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 24h</th>
                <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">over 24h</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td style="font-size: 20px; font-weight: 700; color: #22c55e; padding: 2px; text-align: center;">${mc.under_5min || 0}</td>
                <td style="font-size: 20px; font-weight: 700; color: #4ade80; padding: 2px; text-align: center;">${mc.under_15min || 0}</td>
                <td style="font-size: 20px; font-weight: 700; color: #86efac; padding: 2px; text-align: center;">${mc.under_1hr || 0}</td>
                <td style="font-size: 20px; font-weight: 700; color: #bef264; padding: 2px; text-align: center;">${mc.under_3hr || 0}</td>
                <td style="font-size: 20px; font-weight: 700; color: #fde047; padding: 2px; text-align: center;">${mc.under_6hr || 0}</td>
                <td style="font-size: 20px; font-weight: 700; color: #fbbf24; padding: 2px; text-align: center;">${mc.under_12hr || 0}</td>
                <td style="font-size: 20px; font-weight: 700; color: #f97316; padding: 2px; text-align: center;">${mc.under_24hr || 0}</td>
                <td style="font-size: 20px; font-weight: 700; color: #ef4444; padding: 2px; text-align: center;">${mc.over_24hr || 0}</td>
              </tr>
              <tr>
                <td style="font-size: 20px; font-weight: 700; color: #22c55e; padding: 2px; text-align: center;">${pct(mc.under_5min)}%</td>
                <td style="font-size: 20px; font-weight: 700; color: #4ade80; padding: 2px; text-align: center;">${pct(mc.under_15min)}%</td>
                <td style="font-size: 20px; font-weight: 700; color: #86efac; padding: 2px; text-align: center;">${pct(mc.under_1hr)}%</td>
                <td style="font-size: 20px; font-weight: 700; color: #bef264; padding: 2px; text-align: center;">${pct(mc.under_3hr)}%</td>
                <td style="font-size: 20px; font-weight: 700; color: #fde047; padding: 2px; text-align: center;">${pct(mc.under_6hr)}%</td>
                <td style="font-size: 20px; font-weight: 700; color: #fbbf24; padding: 2px; text-align: center;">${pct(mc.under_12hr)}%</td>
                <td style="font-size: 20px; font-weight: 700; color: #f97316; padding: 2px; text-align: center;">${pct(mc.under_24hr)}%</td>
                <td style="font-size: 20px; font-weight: 700; color: #ef4444; padding: 2px; text-align: center;">${pct(mc.over_24hr)}%</td>
              </tr>
            </tbody>
          </table>
        </div>`;
      }).join('');
    };

    // Render Response Times view
    async function renderResponseTimes() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `
        <div class="page-header">
          <div>
            <h1 class="page-title">⏱️ Response Times</h1>
            <p class="page-subtitle">Track how fast we reply to leads</p>
          </div>
        </div>
        <div class="summary-card" style="margin-bottom: 24px;">
          <p style="color: var(--text-muted);">Loading response time data...</p>
        </div>
      `;
      
      try {
        // Fetch response time data AND booking data
        const [statsRes, threadsRes, bookingRes] = await Promise.all([
          fetch('/api/response-times/stats?days=' + responseTimeDays),
          fetch('/api/response-times/threads?limit=1000'),
          fetch('/api/imann/bookings')
        ]);
        
        if (!statsRes.ok) throw new Error('Failed to load response time stats');
        if (!threadsRes.ok) throw new Error('Failed to load response time threads');
        
        const statsData = await statsRes.json();
        const threadsData = await threadsRes.json();
        const bookingData = bookingRes.ok ? await bookingRes.json() : null;
        window.bookingData = bookingData; // Store globally for hours mode toggle
        
        const daily = statsData.daily || [];
        const weekly = statsData.weekly || {};
        const monthly = statsData.monthly || [];
        const firstStats = statsData.first_response || {};
        const followUpStats = statsData.follow_up_response || {};
        const overallStats = statsData.overall_response || {};
        const allTime = statsData.all_time_distribution || {};
        const heatmap = statsData.lead_reply_heatmap || statsData.response_heatmap || {};
        const perCampaign = statsData.per_campaign || [];
        const alerts = statsData.alerts || {};
        const threads = threadsData.data || [];
        
        // Calculate today's stats or show placeholder
        const today = daily.find(d => d.snapshot_date === new Date().toISOString().split('T')[0]) || {};
        const hasData = daily.length > 0;
        
        // Format time helper
        const formatTime = (seconds) => {
          if (seconds === 0) return '0m';
          if (!seconds && seconds !== 0) return 'N/A';
          if (seconds < 60) return seconds + 's';
          if (seconds < 3600) return Math.floor(seconds / 60) + 'm';
          if (seconds < 86400) return Math.floor(seconds / 3600) + 'h ' + Math.floor((seconds % 3600) / 60) + 'm';
          return Math.floor(seconds / 86400) + 'd ' + Math.floor((seconds % 86400) / 3600) + 'h';
        };
        
        const getRateClass = (seconds) => {
          if (!seconds) return '';
          if (seconds < 3600) return 'rate-good';
          if (seconds < 14400) return 'rate-ok';
          return 'rate-bad';
        };
        
        const alertBanner = ''; // Removed alert banner
        
        const monthKeys = Object.keys(weekly).sort();
        const monthName = (monthKey) => {
          const [year, month] = monthKey.split('-').map(Number);
          const d = new Date(year, month - 1, 1);
          return `${d.toLocaleString('default', { month: 'long' })} ${year}`;
        };
        
        // Build monthly cards with aggregated distribution data
        const monthlyCards = monthKeys.filter(m => {
          const weeks = weekly[m] || [];
          return weeks.some(w => w.total_responses > 0);
        }).map(month => {
          const weeks = weekly[month] || [];
          // Aggregate distribution for the month
          const agg = { under_5min: 0, under_15min: 0, under_1hr: 0, under_3hr: 0, under_6hr: 0, under_12hr: 0, under_24hr: 0, over_24hr: 0, totalSeconds: 0, count: 0 };
          for (const w of weeks) {
            agg.under_5min += w.under_5min || 0;
            agg.under_15min += w.under_15min || 0;
            agg.under_1hr += w.under_1hr || 0;
            agg.under_3hr += w.under_3hr || 0;
            agg.under_6hr += w.under_6hr || 0;
            agg.under_12hr += w.under_12hr || 0;
            agg.under_24hr += w.under_24hr || 0;
            agg.over_24hr += w.over_24hr || 0;
            if (w.avg_response_seconds && w.total_responses) {
              agg.totalSeconds += w.avg_response_seconds * w.total_responses;
              agg.count += w.total_responses;
            }
          }
          const total = agg.under_5min + agg.under_15min + agg.under_1hr + agg.under_3hr + agg.under_6hr + agg.under_12hr + agg.under_24hr + agg.over_24hr;
          const avgSeconds = agg.count > 0 ? Math.round(agg.totalSeconds / agg.count) : 0;
          return { month, monthName: monthName(month), total, avgSeconds, ...agg };
        });
        
        const monthlyRows = (monthly || []).map(m => `
          <tr>
            <td>${monthName(m.month)}</td>
            <td>${m.total_responses || 0}</td>
            <td class="${getRateClass(m.avg_response_seconds)}">${formatTime(m.avg_response_seconds)}</td>
          </tr>
        `).join('');
        
        // Build threads table with expandable details
        let threadsRows = '';
        for (const thread of threads) {
          const messages = thread.thread_messages || [];
          const responseMsg = messages.find(m => m.is_our_response);
          const respTime = responseMsg?.response_time_seconds;
          
          threadsRows += `
            <tr class="expandable-row" onclick="toggleThread('${thread.id}')">
              <td>${thread.lead_email}</td>
              <td>${thread.campaign_name?.substring(0, 30) || 'Unknown'}...</td>
              <td>${thread.status || 'N/A'}</td>
              <td>${thread.their_messages || 0}</td>
              <td class="${respTime ? (respTime <= 900 ? 'rate-good' : respTime <= 3600 ? 'rate-ok' : 'rate-bad') : ''}">
                ${formatTime(respTime)}
              </td>
              <td>${thread.last_activity_at ? new Date(thread.last_activity_at).toLocaleDateString() : 'N/A'}</td>
            </tr>
            <tr id="thread-${thread.id}" style="display: none;">
              <td colspan="6" style="padding: 16px; background: var(--bg-darker);">
                <div style="font-size: 12px; color: var(--text-muted);">
                  <strong>Conversation Timeline:</strong><br>
                  ${messages.map(m => `
                    <div style="margin: 4px 0; padding: 4px 8px; border-left: 2px solid ${m.type === 'SENT' ? 'var(--blue)' : 'var(--green)'};">
                      <span style="color: ${m.type === 'SENT' ? 'var(--blue)' : 'var(--green)'}">${m.type === 'SENT' ? '→ We sent' : '← They replied'}</span>
                      @ ${new Date(m.sent_at).toLocaleString()}
                      ${m.is_our_response ? '<span style="color: var(--yellow);"> (Response: ' + formatTime(m.response_time_seconds) + ')</span>' : ''}
                    </div>
                  `).join('')}
                </div>
              </td>
            </tr>
          `;
        }
        
        // Calculate week-over-week comparison
        const getWeekData = (weeksAgo) => {
          const targetDate = new Date();
          targetDate.setDate(targetDate.getDate() - (weeksAgo * 7));
          const weekStart = new Date(targetDate);
          weekStart.setDate(targetDate.getDate() - targetDate.getDay());
          const weekEnd = new Date(weekStart);
          weekEnd.setDate(weekStart.getDate() + 6);
          
          const weekData = daily.filter(d => {
            const date = new Date(d.snapshot_date);
            return date >= weekStart && date <= weekEnd;
          });
          
          if (weekData.length === 0) return null;
          
          let totalSeconds = 0;
          let totalResponses = 0;
          for (const d of weekData) {
            if (d.avg_response_seconds && d.total_responses) {
              totalSeconds += d.avg_response_seconds * d.total_responses;
              totalResponses += d.total_responses;
            }
          }
          return totalResponses > 0 ? Math.round(totalSeconds / totalResponses) : null;
        };
        
        const thisWeekAvg = getWeekData(0);
        const lastWeekAvg = getWeekData(1);
        const weekChange = (thisWeekAvg && lastWeekAvg) ? Math.round(((lastWeekAvg - thisWeekAvg) / lastWeekAvg) * 100) : null;
        const weekChangeText = weekChange !== null ? (weekChange > 0 ? `↓${weekChange}% faster` : weekChange < 0 ? `↑${Math.abs(weekChange)}% slower` : '→ same') : '';
        const weekChangeClass = weekChange !== null ? (weekChange > 0 ? 'rate-good' : weekChange < 0 ? 'rate-bad' : '') : '';
        
        // Weekend vs Weekday calculation
        let weekdayTotal = 0, weekdaySeconds = 0, weekendTotal = 0, weekendSeconds = 0;
        for (const d of daily) {
          const date = new Date(d.snapshot_date);
          const dayOfWeek = date.getDay();
          const isWeekend = (dayOfWeek === 0 || dayOfWeek === 6);
          const responses = d.total_responses || 1;
          const seconds = d.avg_response_seconds || 0;
          if (isWeekend) {
            weekendTotal += responses;
            weekendSeconds += seconds * responses;
          } else {
            weekdayTotal += responses;
            weekdaySeconds += seconds * responses;
          }
        }
        const weekdayAvg = weekdayTotal > 0 ? Math.round(weekdaySeconds / weekdayTotal) : 0;
        const weekendAvg = weekendTotal > 0 ? Math.round(weekendSeconds / weekendTotal) : 0;

        // Store data for toggle switching
        // Business hours data - check both nested and flat structure
        const bh = statsData.business_hours || {};
        const bhDist = statsData.bhDist || bh.distribution || {};
        const bhStats = statsData.bhStats || bh.stats || {};
        const bhFirstStats = statsData.bhFirstStats || bh.first_response || {};
        const bhFollowUpStats = statsData.bhFollowUpStats || bh.follow_up_response || {};
        const bhWeekly = bh.weekly || {};
        
        const bhMonthly = bh.monthly || [];
        
        // Store in window for toggle access
        window.responseTimeData = {
          allTime,
          overallStats,
          firstStats,
          followUpStats,
          bhDist,
          bhStats,
          bhFirstStats,
          bhFollowUpStats,
          bhWeekly,
          bhMonthly,
          weekly,
          monthlyCards,
          formatTime,
          getRateClass,
          monthName: (monthKey) => {
            const [year, month] = monthKey.split('-').map(Number);
            const d = new Date(year, month - 1, 1);
            return d.toLocaleString('default', { month: 'long' }) + ' ' + year;
          }
        };

        content.innerHTML = `
          <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px;">
            <div>
              <h1 class="page-title">⏱️ Response Times</h1>
              <p class="page-subtitle">Track how fast we reply to leads (${hasData ? daily.length + ' days of data' : 'No data yet - run sync-reply-times.js'})</p>
            </div>
            <div style="display: flex; gap: 12px; align-items: center;">
              <select id="globalMonthFilter" onchange="window.updateAllByMonth(this.value)" style="padding: 8px 12px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 13px; cursor: pointer; font-weight: 600;">
                <option value="all">📅 All Time</option>
                ${(bookingData?.availableMonths || []).map(m => '<option value="' + m + '">' + m.split('-')[1] + ' ' + m.split('-')[0] + '</option>').join('')}
              </select>
              <div id="hoursToggle" style="display: flex; background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; overflow: hidden;">
                <button id="allHoursBtn" onclick="window.toggleHoursMode('all')" style="padding: 8px 14px; background: var(--accent); color: white; border: none; font-size: 13px; cursor: pointer; transition: all 0.2s;">All Hours</button>
                <button id="businessHoursBtn" onclick="window.toggleHoursMode('business')" style="padding: 8px 14px; background: transparent; color: var(--text-muted); border: none; font-size: 13px; cursor: pointer; transition: all 0.2s;">Business Hours</button>
              </div>
              <a href="https://supabase.com/dashboard/project/rwhqshjmngkyremwandx/editor/29369" target="_blank" style="font-size: 12px; color: var(--green); text-decoration: none; padding: 8px 14px; border: 1px solid var(--green); border-radius: 6px; display: flex; align-items: center; gap: 8px;" title="View curated_leads table in Supabase">
                <span style="font-size: 14px;">📊</span>
                <span style="display: flex; flex-direction: column; line-height: 1.3;">
                  <span style="font-weight: 600;">curated_leads</span>
                  <span style="font-size: 10px; opacity: 0.7;">${bookingData?.summary?.total || 0} rows · Supabase</span>
                </span>
              </a>
            </div>
          </div>
          
          ${alertBanner}
          
          <!-- BOOKING RATIO - Main Stat + Correlation Table -->
          ${bookingData && bookingData.summary ? `
          ${(() => {
            // Simplified correlation - group into 4 buckets (handle missing data)
            const correlation = bookingData.responseTimeCorrelation || [];
            const fast = correlation.filter(r => ['< 5 min', '5-15 min', '15-30 min', '30-60 min'].includes(r.bucket));
            const medium = correlation.filter(r => ['1-3 hours', '3-6 hours'].includes(r.bucket));
            const slow = correlation.filter(r => ['6-12 hours', '12-24 hours'].includes(r.bucket));
            const verySlow = correlation.filter(r => ['1-2 days', '> 2 days'].includes(r.bucket));
            
            const sum = (arr) => arr.reduce((a, r) => ({ total: a.total + (r.total || 0), booked: a.booked + (r.booked || 0) }), { total: 0, booked: 0 });
            const fastSum = sum(fast);
            const mediumSum = sum(medium);
            const slowSum = sum(slow);
            const verySlowSum = sum(verySlow);
            
            const rate = (s) => s.total > 0 ? ((s.booked / s.total) * 100).toFixed(0) : '0';
            
            return `
          <div class="summary-card" style="margin-bottom: 24px; background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(34, 197, 94, 0.05));">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 32px;">
              <div>
                <div class="card-label" style="font-size: 14px;">📊 BOOKING RATIO</div>
                <div id="bookingRatioValue" style="font-size: 72px; font-weight: 800; color: var(--green);">${bookingData.summary.bookingRate}%</div>
                <div id="bookingRatioDetails" style="font-size: 14px; color: var(--text-muted);">${bookingData.summary.booked} booked / ${bookingData.summary.total} companies</div>
              </div>
              <div style="display: flex; gap: 12px; padding-top: 8px;">
                <div style="text-align: center; padding: 16px 24px; background: rgba(0,0,0,0.2); border-radius: 8px;">
                  <div id="bookedCount" style="font-size: 32px; font-weight: 700; color: var(--green);">${bookingData.summary.booked}</div>
                  <div style="font-size: 12px; color: var(--text-muted);">Booked</div>
                </div>
                <div style="text-align: center; padding: 16px 24px; background: rgba(0,0,0,0.2); border-radius: 8px;">
                  <div id="schedulingCount" style="font-size: 32px; font-weight: 700; color: var(--yellow);">${bookingData.summary.scheduling}</div>
                  <div style="font-size: 12px; color: var(--text-muted);">Scheduling</div>
                </div>
                <div style="text-align: center; padding: 16px 24px; background: rgba(0,0,0,0.2); border-radius: 8px;">
                  <div id="notBookedCount" style="font-size: 32px; font-weight: 700; color: var(--red);">${bookingData.summary.notBooked}</div>
                  <div style="font-size: 12px; color: var(--text-muted);">Not Booked</div>
                </div>
              </div>
            </div>
            <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1);">
              <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px;">⚡ Response Time Impact on Booking</div>
              <div id="responseTimeImpactContent" style="display: flex; gap: 12px;">
                <div style="flex: 1; text-align: center; padding: 12px; background: rgba(34, 197, 94, 0.15); border-radius: 8px;">
                  <div style="font-size: 24px; font-weight: 700; color: var(--green);">${rate(fastSum)}%</div>
                  <div style="font-size: 11px; color: var(--text-muted);">< 1 hour</div>
                  <div style="font-size: 10px; color: var(--text-dim);">${fastSum.booked}/${fastSum.total}</div>
                </div>
                <div style="flex: 1; text-align: center; padding: 12px; background: rgba(251, 191, 36, 0.15); border-radius: 8px;">
                  <div style="font-size: 24px; font-weight: 700; color: var(--yellow);">${rate(mediumSum)}%</div>
                  <div style="font-size: 11px; color: var(--text-muted);">1-6 hours</div>
                  <div style="font-size: 10px; color: var(--text-dim);">${mediumSum.booked}/${mediumSum.total}</div>
                </div>
                <div style="flex: 1; text-align: center; padding: 12px; background: rgba(249, 115, 22, 0.15); border-radius: 8px;">
                  <div style="font-size: 24px; font-weight: 700; color: #f97316;">${rate(slowSum)}%</div>
                  <div style="font-size: 11px; color: var(--text-muted);">6-24 hours</div>
                  <div style="font-size: 10px; color: var(--text-dim);">${slowSum.booked}/${slowSum.total}</div>
                </div>
                <div style="flex: 1; text-align: center; padding: 12px; background: rgba(239, 68, 68, 0.15); border-radius: 8px;">
                  <div style="font-size: 24px; font-weight: 700; color: var(--red);">${rate(verySlowSum)}%</div>
                  <div style="font-size: 11px; color: var(--text-muted);">> 24 hours</div>
                  <div style="font-size: 10px; color: var(--text-dim);">${verySlowSum.booked}/${verySlowSum.total}</div>
                </div>
              </div>
            </div>
          </div>`;
          })()}
          ` : ''}
          
          <!-- Response Time Stats Row (4 cards) -->
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card" style="text-align: center; padding: 24px 16px; cursor: help;" title="MEAN (Average): Add up all response times and divide by the number of responses. Can be skewed by very slow responses.">
              <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 8px;">📈 <span id="statsMeanLabel">Overall</span> Mean</div>
              <div id="statsMeanValue" class="card-value" style="font-size: 32px; font-weight: 700; margin-bottom: 4px;">${formatTime(overallStats.avg_seconds)}</div>
              <div style="font-size: 12px; color: var(--text-dim);"><span id="statsMeanCount">${overallStats.count || 0}</span> responses</div>
            </div>
            <div class="summary-card" style="text-align: center; padding: 24px 16px; cursor: help;" title="MEDIAN (Middle Value): Sort all response times and pick the middle one. Better shows typical performance - not affected by outliers.">
              <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 8px;">📊 <span id="statsMedianLabel">Overall</span> Median</div>
              <div id="statsMedianValue" class="card-value" style="font-size: 32px; font-weight: 700; margin-bottom: 4px;">${formatTime(overallStats.median_seconds)}</div>
              <div style="font-size: 12px; color: var(--text-dim);">Middle value (more reliable)</div>
            </div>
            <div class="summary-card" style="text-align: center; padding: 24px 16px; border-left: 3px solid var(--green); cursor: help;" title="FIRST RESPONSE: How fast we reply when a lead first contacts us. This is the most important response - it sets the tone.">
              <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 8px;">📥 First Response (Avg)</div>
              <div id="statsFirstValue" class="card-value ${getRateClass(firstStats.avg_seconds)}" style="font-size: 32px; font-weight: 700; margin-bottom: 4px;">${formatTime(firstStats.avg_seconds)}</div>
              <div style="font-size: 12px; color: var(--text-dim);"><span id="statsFirstCount">${firstStats.count || firstStats.total || 0}</span> first replies</div>
            </div>
            <div class="summary-card" style="text-align: center; padding: 24px 16px; cursor: help;" title="FOLLOW-UP AVERAGE: How fast we reply to their 2nd, 3rd, etc. messages in a thread. Measures ongoing conversation speed.">
              <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 8px;">🔁 Follow-up Avg</div>
              <div id="statsFollowupValue" class="card-value ${getRateClass(followUpStats.avg_seconds)}" style="font-size: 32px; font-weight: 700; margin-bottom: 4px;">${followUpStats.avg_seconds ? formatTime(followUpStats.avg_seconds) : '<span style="font-size: 14px; color: var(--text-dim);">Not tracked yet</span>'}</div>
              <div style="font-size: 12px; color: var(--text-dim);"><span id="statsFollowupCount">${followUpStats.count || followUpStats.total || 0}</span> follow-ups</div>
            </div>
          </div>
          
          <!-- Distribution Row - Visual Bar Style -->
          ${(() => {
            const total = (allTime.under_5min||0) + (allTime.under_15min||0) + (allTime.under_1hr||0) + 
                          (allTime.under_3hr||0) + (allTime.under_6hr||0) + (allTime.under_12hr||0) + 
                          (allTime.under_24hr||0) + (allTime.over_24hr||0);
            const pct = (v) => total > 0 ? Math.round(v / total * 100) : 0;
            const maxVal = Math.max(allTime.under_5min||0, allTime.under_15min||0, allTime.under_1hr||0, allTime.under_3hr||0, allTime.under_6hr||0, allTime.under_12hr||0, allTime.under_24hr||0, allTime.over_24hr||0);
            const barHeight = (v) => maxVal > 0 ? Math.max(8, (v / maxVal) * 100) : 8;
            
            const buckets = [
              { label: '< 5m', value: allTime.under_5min || 0, color: '#22c55e', id: '5m' },
              { label: '< 15m', value: allTime.under_15min || 0, color: '#4ade80', id: '15m' },
              { label: '< 1h', value: allTime.under_1hr || 0, color: '#86efac', id: '1h' },
              { label: '< 3h', value: allTime.under_3hr || 0, color: '#bef264', id: '3h' },
              { label: '< 6h', value: allTime.under_6hr || 0, color: '#fde047', id: '6h' },
              { label: '< 12h', value: allTime.under_12hr || 0, color: '#fbbf24', id: '12h' },
              { label: '< 24h', value: allTime.under_24hr || 0, color: '#f97316', id: '24h' },
              { label: '> 24h', value: allTime.over_24hr || 0, color: '#ef4444', id: 'over24h' }
            ];
            
            return `
          <div class="summary-card" style="margin-bottom: 24px; padding: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
              <div class="card-label" style="margin: 0; font-size: 14px;">📊 Response Time Distribution</div>
              <div id="distTotalResponses" style="font-size: 13px; color: var(--text-muted);">${total} total responses</div>
            </div>
            <div style="display: flex; gap: 8px; align-items: flex-end; height: 140px; padding-bottom: 8px;">
              ${buckets.map(b => `
                <div style="flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%;">
                  <div style="flex: 1; display: flex; flex-direction: column; justify-content: flex-end; width: 100%;">
                    <div id="distBar${b.id}" style="width: 100%; height: ${barHeight(b.value)}%; background: ${b.color}; border-radius: 4px 4px 0 0; min-height: 8px; transition: height 0.3s ease;"></div>
                  </div>
                </div>
              `).join('')}
            </div>
            <div style="display: flex; gap: 8px; border-top: 1px solid var(--border); padding-top: 12px;">
              ${buckets.map(b => `
                <div style="flex: 1; text-align: center;">
                  <div id="dist${b.id}" style="font-size: 20px; font-weight: 700; color: ${b.color};">${b.value}</div>
                  <div id="dist${b.id}Pct" style="font-size: 13px; color: ${b.color}; opacity: 0.8;">${pct(b.value)}%</div>
                  <div style="font-size: 10px; color: var(--text-muted); margin-top: 4px;">${b.label}</div>
                </div>
              `).join('')}
            </div>
          </div>`;
          })()}
          
          <!-- Monthly Breakdown (Card Style) - HIDDEN -->
          <div style="display: none; align-items: center; gap: 16px; margin: 32px 0 20px 0;">
            <div style="font-size: 16px; font-weight: 600; color: var(--text);">📅 Monthly Breakdown</div>
            <div style="flex: 1; height: 1px; background: var(--border);"></div>
          </div>
          <div id="monthlyCardsContainer" style="display: none;">
          ${monthlyCards.map(mc => {
            const pct = (v) => mc.total > 0 ? Math.round(v / mc.total * 100) : 0;
            // Find matching booking data for this month
            const bookingMonth = bookingData?.monthlyBreakdown?.find(b => mc.monthName.includes(b.month.split(' ')[0]));
            return `
          <div class="summary-card" style="margin-bottom: 16px; padding: 16px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
              <div class="card-label" style="margin: 0; cursor: pointer;" onclick="document.getElementById('leads-${mc.month}').style.display = document.getElementById('leads-${mc.month}').style.display === 'none' ? 'block' : 'none';">
                📅 ${mc.monthName} — ${mc.total} responses ▼
              </div>
              <div style="display: flex; gap: 16px; align-items: center;">
                ${bookingMonth ? `<div style="font-size: 14px;"><span style="color: var(--text-muted);">Booking:</span> <span style="font-weight: 700; color: ${parseFloat(bookingMonth.rate) >= 40 ? 'var(--green)' : parseFloat(bookingMonth.rate) >= 30 ? 'var(--yellow)' : 'var(--red)'};">${bookingMonth.rate}%</span> <span style="color: var(--text-dim); font-size: 12px;">(${bookingMonth.booked}/${bookingMonth.total})</span></div>` : ''}
                <div style="font-size: 13px; color: var(--text-muted);">Avg: ${formatTime(mc.avgSeconds)}</div>
              </div>
            </div>
            <table style="width: 100%; text-align: center; border-collapse: collapse;">
              <thead>
                <tr>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 5m</th>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 15m</th>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 1h</th>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 3h</th>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 6h</th>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 12h</th>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">under 24h</th>
                  <th style="font-size: 10px; color: #fff; padding: 4px 2px; font-weight: 500; text-align: center;">over 24h</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td style="font-size: 20px; font-weight: 700; color: #22c55e; padding: 2px; text-align: center;">${mc.under_5min}</td>
                  <td style="font-size: 20px; font-weight: 700; color: #4ade80; padding: 2px; text-align: center;">${mc.under_15min}</td>
                  <td style="font-size: 20px; font-weight: 700; color: #86efac; padding: 2px; text-align: center;">${mc.under_1hr}</td>
                  <td style="font-size: 20px; font-weight: 700; color: #bef264; padding: 2px; text-align: center;">${mc.under_3hr}</td>
                  <td style="font-size: 20px; font-weight: 700; color: #fde047; padding: 2px; text-align: center;">${mc.under_6hr}</td>
                  <td style="font-size: 20px; font-weight: 700; color: #fbbf24; padding: 2px; text-align: center;">${mc.under_12hr}</td>
                  <td style="font-size: 20px; font-weight: 700; color: #f97316; padding: 2px; text-align: center;">${mc.under_24hr}</td>
                  <td style="font-size: 20px; font-weight: 700; color: #ef4444; padding: 2px; text-align: center;">${mc.over_24hr}</td>
                </tr>
                <tr>
                  <td style="font-size: 20px; font-weight: 700; color: #22c55e; padding: 2px; text-align: center;">${pct(mc.under_5min)}%</td>
                  <td style="font-size: 20px; font-weight: 700; color: #4ade80; padding: 2px; text-align: center;">${pct(mc.under_15min)}%</td>
                  <td style="font-size: 20px; font-weight: 700; color: #86efac; padding: 2px; text-align: center;">${pct(mc.under_1hr)}%</td>
                  <td style="font-size: 20px; font-weight: 700; color: #bef264; padding: 2px; text-align: center;">${pct(mc.under_3hr)}%</td>
                  <td style="font-size: 20px; font-weight: 700; color: #fde047; padding: 2px; text-align: center;">${pct(mc.under_6hr)}%</td>
                  <td style="font-size: 20px; font-weight: 700; color: #fbbf24; padding: 2px; text-align: center;">${pct(mc.under_12hr)}%</td>
                  <td style="font-size: 20px; font-weight: 700; color: #f97316; padding: 2px; text-align: center;">${pct(mc.under_24hr)}%</td>
                  <td style="font-size: 20px; font-weight: 700; color: #ef4444; padding: 2px; text-align: center;">${pct(mc.over_24hr)}%</td>
                </tr>
              </tbody>
            </table>
            <div id="leads-${mc.month}" style="display: none; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border);">
              ${(() => {
                // Filter threads for this month (use first_reply_at or last_activity_at)
                const monthThreads = threads.filter(t => {
                  const dateStr = t.first_reply_at || t.last_activity_at;
                  if (!dateStr) return false;
                  const d = new Date(dateStr);
                  const threadMonth = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
                  return threadMonth === mc.month;
                });
                
                // Sort by status priority
                const statusPriority = (s) => {
                  const status = (s || '').toLowerCase();
                  if (!s || s.trim() === '') return 99; // Blank at bottom
                  if (status === 'booked' || status === 'meeting booked') return 1;
                  if (status === 'meeting request') return 2;
                  if (status === 'interested') return 3;
                  if (status === 'information request') return 4;
                  if (status.includes('wrong') || status.includes('person')) return 5;
                  if (status.includes('not interested')) return 6;
                  if (status.includes('do not contact') || status.includes('dnc')) return 7;
                  if (status.includes('out of office') || status.includes('ooo')) return 8;
                  if (status.includes('subsequent')) return 9;
                  return 10; // Unknown statuses
                };
                monthThreads.sort((a, b) => statusPriority(a.status) - statusPriority(b.status));
                
                if (monthThreads.length === 0) {
                  return '<div style="font-size: 12px; color: var(--text-muted);">No lead data available for this month</div>';
                }
                
                const statusColor = (s) => {
                  const status = (s || '').toLowerCase();
                  if (['interested', 'meeting request', 'booked', 'meeting booked', 'information request'].includes(status)) return '#22c55e';
                  if (status.includes('not interested')) return '#ef4444';
                  if (status.includes('do not contact') || status.includes('dnc')) return '#ef4444';
                  if (status.includes('wrong') || status.includes('person')) return '#f97316';
                  if (status.includes('out of office') || status.includes('ooo')) return '#fbbf24';
                  if (status.includes('subsequent')) return '#a78bfa';
                  return 'var(--text-muted)';
                };
                
                return '<div style="max-height: 400px; overflow-y: auto;"><table style="width: 100%; font-size: 12px;"><thead><tr><th style="text-align: left; padding: 6px;">Lead</th><th style="text-align: left; padding: 6px;">Campaign</th><th style="text-align: center; padding: 6px;">Status</th></tr></thead><tbody>' +
                  monthThreads.map(t => {
                    return '<tr style="border-bottom: 1px solid var(--border);"><td style="padding: 6px;">' + (t.lead_email || 'Unknown') + '</td><td style="padding: 6px; color: var(--text-muted); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">' + (t.campaign_name?.substring(0, 30) || 'N/A') + '</td><td style="padding: 6px; text-align: center; color: ' + statusColor(t.status) + ';">' + (t.status || '-') + '</td></tr>';
                  }).join('') +
                  '</tbody></table></div>';
              })()}
            </div>
          </div>`;
          }).join('')}
          </div>
          
          <!-- Conversation Threads (Collapsed by default) - HIDDEN -->
          <div class="table-container" style="display: none; margin-top: 24px;">
            <div class="table-header" style="cursor: pointer;" onclick="document.getElementById('conversationsTable').style.display = document.getElementById('conversationsTable').style.display === 'none' ? 'table' : 'none';">
              <span class="table-title">💬 Recent Conversations (${threads.length} threads) — Click to expand ▼</span>
            </div>
            <table id="conversationsTable" style="display: none;">
              <thead>
                <tr>
                  <th>Lead Email</th>
                  <th>Campaign</th>
                  <th>Category</th>
                  <th>Replies</th>
                  <th>Our Response</th>
                  <th>Last Activity</th>
                </tr>
              </thead>
              <tbody>
                ${threadsRows || '<tr><td colspan="6" style="text-align:center; color: var(--text-muted);">No conversation data yet</td></tr>'}
              </tbody>
            </table>
          </div>
          
          <!-- Monthly Booking Ratio -->
          ${bookingData && bookingData.monthlyBreakdown && bookingData.monthlyBreakdown.length > 0 ? `
          <div class="summary-card" style="margin-top: 24px;">
            <div class="card-label">📅 Monthly Booking Ratio</div>
            <div style="margin-top: 16px;">
              ${(() => {
                const months = bookingData.monthlyBreakdown
                  .map(m => ({
                    ...m,
                    rate: m.total > 0 ? Math.round((m.booked / m.total) * 100) : 0,
                    sortKey: m.month.replace(/(\d{4})-(\w+)/, (_, y, mo) => {
                      const monthOrder = { Jan: '01', Feb: '02', Mar: '03', Apr: '04', May: '05', Jun: '06', Jul: '07', Aug: '08', Sep: '09', Oct: '10', Nov: '11', Dec: '12' };
                      return y + '-' + (monthOrder[mo] || '00');
                    })
                  }))
                  .sort((a, b) => a.sortKey.localeCompare(b.sortKey));
                
                const maxTotal = Math.max(...months.map(m => m.total), 1);
                
                return '<div style="display: flex; gap: 12px; align-items: flex-end; height: 180px; padding: 0 8px;">' +
                  months.map(m => {
                    const barHeight = Math.max(20, (m.total / maxTotal) * 140);
                    const rateColor = m.rate >= 30 ? '#22c55e' : m.rate >= 20 ? '#eab308' : '#ef4444';
                    const rateColorFade = m.rate >= 30 ? 'rgba(34,197,94,0.5)' : m.rate >= 20 ? 'rgba(234,179,8,0.5)' : 'rgba(239,68,68,0.5)';
                    const monthName = m.month.split('-')[1] + ' ' + m.month.split('-')[0];
                    return '<div style="flex: 1; display: flex; flex-direction: column; align-items: center;">' +
                      '<div style="font-size: 24px; font-weight: 700; color: ' + rateColor + ';">' + m.rate + '%</div>' +
                      '<div style="font-size: 11px; color: #888; margin-bottom: 4px;">' + m.booked + '/' + m.total + '</div>' +
                      '<div style="width: 100%; max-width: 80px; height: ' + barHeight + 'px; background: linear-gradient(to top, ' + rateColor + ', ' + rateColorFade + '); border-radius: 4px 4px 0 0;"></div>' +
                      '<div style="font-size: 12px; font-weight: 600; margin-top: 8px; color: #fff;">' + monthName + '</div>' +
                    '</div>';
                  }).join('') +
                '</div>';
              })()}
            </div>
            <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted);">
              <span>Total: ${bookingData.monthlyBreakdown.reduce((s, m) => s + m.total, 0)} companies</span>
              <span>Booked: ${bookingData.monthlyBreakdown.reduce((s, m) => s + m.booked, 0)} deals</span>
              <span>Overall: ${bookingData.summary.bookingRate}%</span>
            </div>
          </div>
          ` : ''}
          
          <!-- Response Time Heatmap -->
          <div class="summary-card" style="margin-top: 24px;">
            <div class="card-label" style="cursor: pointer;" onclick="document.getElementById('heatmap-content').style.display = document.getElementById('heatmap-content').style.display === 'none' ? 'block' : 'none'; this.querySelector('.expand-arrow').textContent = document.getElementById('heatmap-content').style.display === 'none' ? '▶' : '▼';">
              📥 When Leads Reply (ET - New York) <span class="expand-arrow" style="font-size: 10px; margin-left: 6px;">▼</span>
            </div>
            <div id="heatmap-content">
              <div style="display: flex; justify-content: space-between; align-items: center; margin: 12px 0 16px 0;">
                <div style="font-size: 12px; color: var(--text-muted);">Shows when leads send replies by day & hour. Darker = more replies.</div>
                <div style="display: flex; gap: 8px; align-items: center; font-size: 11px;">
                  <span style="color: var(--text-muted);">Less</span>
                  <span style="width: 20px; height: 20px; background: rgba(34, 197, 94, 0.15); border-radius: 3px;"></span>
                  <span style="width: 20px; height: 20px; background: rgba(34, 197, 94, 0.4); border-radius: 3px;"></span>
                  <span style="width: 20px; height: 20px; background: rgba(34, 197, 94, 0.7); border-radius: 3px;"></span>
                  <span style="width: 20px; height: 20px; background: rgba(34, 197, 94, 1); border-radius: 3px;"></span>
                  <span style="color: var(--text-muted);">More</span>
                </div>
              </div>
              <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: separate; border-spacing: 3px;">
                  <thead>
                    <tr>
                      <th style="width: 60px; text-align: left; font-size: 12px; padding: 8px;"></th>
                      ${Array.from({length: 24}, (_, h) => {
                        const ampm = h < 12 ? 'AM' : 'PM';
                        const h12 = h === 0 ? 12 : (h > 12 ? h - 12 : h);
                        return '<th style="font-size: 10px; padding: 4px 1px; color: var(--text-muted);">' + h12 + '<br>' + ampm + '</th>';
                      }).join('')}
                    </tr>
                  </thead>
                  <tbody>
                    ${(() => {
                      // Find max count for scaling
                      let maxCount = 0;
                      ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].forEach(day => {
                        const dayData = heatmap[day] || {};
                        for (let h = 0; h < 24; h++) {
                          const cell = dayData[h] || { count: 0 };
                          if (cell.count > maxCount) maxCount = cell.count;
                        }
                      });
                      
                      return ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map(day => {
                        const dayData = heatmap[day] || {};
                        return '<tr><td style="font-weight: 600; font-size: 13px; padding: 8px;">' + day + '</td>' + 
                          Array.from({length: 24}, (_, h) => {
                            const cell = dayData[h] || { count: 0, percent: 0 };
                            const intensity = maxCount > 0 ? cell.count / maxCount : 0;
                            const alpha = cell.count > 0 ? 0.15 + intensity * 0.85 : 0.05;
                            const textColor = intensity > 0.5 ? '#fff' : (cell.count > 0 ? '#22c55e' : '#555');
                            return '<td style="background: rgba(34, 197, 94, ' + alpha + '); padding: 8px 4px; border-radius: 4px; text-align: center; font-size: 13px; font-weight: ' + (cell.count > 0 ? '600' : '400') + '; color: ' + textColor + ';">' + 
                              (cell.count > 0 ? cell.count : '') + 
                              '</td>';
                          }).join('') + '</tr>';
                      }).join('');
                    })()}
                  </tbody>
                </table>
              </div>
              <div style="margin-top: 12px; font-size: 12px; color: var(--text-muted);">
                💡 Times in ET (Eastern Time / New York). Be ready to reply during peak hours.
              </div>
            </div>
          </div>
          
          <div class="summary-card" style="margin-top: 24px; padding: 16px; background: var(--bg-card);">
            <p style="color: var(--text-muted); font-size: 13px;">
              ${hasData ? '✅ Data synced. Run <code>node sync-reply-times.js</code> to update.' : '⚠️ <strong>Setup needed:</strong> Create Supabase tables (see REPLY_TRACKING_SCHEMA.sql), then run <code>node sync-reply-times.js</code>'}
            </p>
          </div>
          
        `;
        
      } catch (err) {
        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">⏱️ Response Times</h1>
              <p class="page-subtitle">Error loading data</p>
            </div>
          </div>
          <div style="padding: 20px; background: var(--red-bg); border: 1px solid var(--red); border-radius: 8px; color: var(--red);">
            <strong>Error:</strong> ${err.message}<br><br>
            <strong>Setup:</strong> Create tables in Supabase using REPLY_TRACKING_SCHEMA.sql, then run sync-reply-times.js
          </div>
        `;
      }
    }
    
    // Load booking correlation data for Response Times view
    async function loadBookingCorrelation() {
      const container = document.getElementById('bookingCorrelationSection');
      if (!container) return;
      
      try {
        const res = await fetch('/api/imann/bookings');
        if (!res.ok) throw new Error('Failed to load booking data');
        const data = await res.json();
        
        const { summary, monthlyBreakdown, responseTimeCorrelation } = data;
        
        container.innerHTML = `
          <div class="summary-card" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
              <div class="card-label" style="margin: 0;">📊 BOOKING RATIO (Imann)</div>
              <div style="font-size: 24px; font-weight: 700; color: var(--green);">${summary.bookingRate}%</div>
            </div>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 16px;">
              <div style="text-align: center; padding: 12px; background: var(--bg-card); border-radius: 8px;">
                <div style="font-size: 28px; font-weight: 700; color: var(--green);">${summary.booked}</div>
                <div style="font-size: 11px; color: var(--text-muted);">Booked</div>
              </div>
              <div style="text-align: center; padding: 12px; background: var(--bg-card); border-radius: 8px;">
                <div style="font-size: 28px; font-weight: 700; color: var(--yellow);">${summary.scheduling}</div>
                <div style="font-size: 11px; color: var(--text-muted);">Scheduling</div>
              </div>
              <div style="text-align: center; padding: 12px; background: var(--bg-card); border-radius: 8px;">
                <div style="font-size: 28px; font-weight: 700; color: var(--red);">${summary.notBooked}</div>
                <div style="font-size: 11px; color: var(--text-muted);">Not Booked</div>
              </div>
              <div style="text-align: center; padding: 12px; background: var(--bg-card); border-radius: 8px;">
                <div style="font-size: 28px; font-weight: 700; color: var(--text-muted);">${summary.total}</div>
                <div style="font-size: 11px; color: var(--text-muted);">Total</div>
              </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <!-- Monthly Breakdown -->
              <div>
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">📅 Monthly</div>
                <table style="width: 100%; font-size: 12px;">
                  <tbody>
                    ${monthlyBreakdown.slice(0, 4).map(m => `
                      <tr>
                        <td style="padding: 4px 0;">${m.month}</td>
                        <td style="text-align: right; color: var(--green);">${m.booked}/${m.total}</td>
                        <td style="text-align: right; font-weight: 600; color: ${parseFloat(m.rate) >= 40 ? 'var(--green)' : parseFloat(m.rate) >= 30 ? 'var(--yellow)' : 'var(--red)'};">${m.rate}%</td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
              </div>
              
              <!-- Response Time Correlation -->
              <div>
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">⚡ Response Time → Booking %</div>
                <table style="width: 100%; font-size: 12px;">
                  <tbody>
                    ${responseTimeCorrelation.slice(0, 6).map(r => `
                      <tr>
                        <td style="padding: 4px 0;">${r.bucket}</td>
                        <td style="text-align: right;">${r.booked}/${r.total}</td>
                        <td style="text-align: right; font-weight: 600; color: ${parseFloat(r.rate) >= 50 ? 'var(--green)' : parseFloat(r.rate) >= 25 ? 'var(--yellow)' : 'var(--red)'};">${r.rate}%</td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        `;
      } catch (err) {
        container.innerHTML = `
          <div class="summary-card" style="margin-top: 24px; background: var(--yellow-bg);">
            <p style="color: var(--yellow); font-size: 13px;">⚠️ Booking data not available: ${err.message}</p>
          </div>
        `;
      }
    }
    
    // Toggle thread expansion
    function toggleThread(threadId) {
      const row = document.getElementById('thread-' + threadId);
      if (row) {
        row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
      }
    }

    // Render Eric's Deliverability Benchmarks view
    async function renderDeliverability() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `
        <div class="page-header">
          <div>
            <h1 class="page-title">📋 Eric's Deliverability Benchmarks</h1>
            <p class="page-subtitle">Infrastructure health based on GEX Deliverability Guide</p>
          </div>
          <div style="font-size: 12px; color: var(--text-muted); padding: 8px 14px; border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; gap: 8px;">
            <span style="font-size: 14px;">⚡</span>
            <span>SmartLead API · Live</span>
          </div>
        </div>
        <div class="summary-card" style="margin-bottom: 24px;">
          <p style="color: var(--text-muted);">Loading deliverability analysis...</p>
        </div>
      `;

      try {
        const [healthRes, providerRes] = await Promise.all([
          fetch('/api/deliverability/health'),
          fetch('/api/deliverability/provider-split').catch(() => ({ ok: false }))
        ]);
        
        if (!healthRes.ok) throw new Error('Failed to load deliverability data');
        const data = await healthRes.json();
        const providerData = providerRes.ok ? await providerRes.json() : null;

        // Add defaults for all expected properties
        const summary = data.summary || { totalDomains: 0, healthyDomains: 0, warningDomains: 0, criticalDomains: 0, totalInboxes: 0, activeInboxes: 0, dailyCapacity: 0, inboxesBelow98: 0 };
        const capacity = data.capacity || { current: 0, target: 1000, issues: [], inboxesNeeded: 0, total: 0, estimatedADV: 0, headroom: 0, backupRatio: 0 };
        const alerts = data.alerts || { inboxes: [], domainsToKill: [], bottom10Domains: [] };
        const benchmarks = data.benchmarks || { replyRate: { target: 1, current: 0 }, bounceRate: { target: 3, current: 0 } };
        const domains = data.domains || [];

        // Build alerts section
        let alertsHtml = '';
        
        if (alerts.inboxes.length > 0) {
          alertsHtml += `
            <div style="background: var(--red-bg); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
              <h3 style="color: var(--red); margin: 0 0 12px 0;">🚨 ${alerts.inboxes.length} Inboxes Below 98% Reputation</h3>
              <div style="max-height: 200px; overflow-y: auto;">
                ${alerts.inboxes.slice(0, 20).map(i => `
                  <div style="display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--border);">
                    <span style="color: var(--text);">${i.email}</span>
                    <span style="color: var(--red); font-weight: 600;">${i.reputation}%</span>
                  </div>
                `).join('')}
                ${alerts.inboxes.length > 20 ? `<p style="color: var(--text-muted); margin-top: 8px;">...and ${alerts.inboxes.length - 20} more</p>` : ''}
              </div>
            </div>
          `;
        }

        if (alerts.domainsToKill.length > 0) {
          alertsHtml += `
            <div style="background: var(--red-bg); border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
              <h3 style="color: var(--red); margin: 0 0 12px 0;">💀 ${alerts.domainsToKill.length} Domains to Cancel</h3>
              ${alerts.domainsToKill.map(d => `
                <div style="padding: 8px 0; border-bottom: 1px solid var(--border);">
                  <div style="font-weight: 600; color: var(--text);">${d.domain}</div>
                  <div style="color: var(--red); font-size: 12px;">${d.issues.map(i => i.message).join(' • ')}</div>
                </div>
              `).join('')}
            </div>
          `;
        }

        if (capacity.issues.length > 0) {
          alertsHtml += `
            <div style="background: var(--yellow-bg); border: 1px solid rgba(234, 179, 8, 0.3); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
              <h3 style="color: var(--yellow); margin: 0 0 12px 0;">⚠️ Capacity Issues</h3>
              ${capacity.issues.map(i => `
                <div style="padding: 4px 0; color: var(--text);">${i.message}</div>
              `).join('')}
            </div>
          `;
        }

        if (alerts.bottom10Domains.length > 0) {
          alertsHtml += `
            <div style="background: var(--orange-bg); border: 1px solid rgba(249, 115, 22, 0.3); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
              <h3 style="color: var(--orange); margin: 0 0 12px 0;">📉 Bottom 10% Domains</h3>
              ${alerts.bottom10Domains.map(d => `
                <div style="display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--border);">
                  <span style="color: var(--text);">${d.domain}</span>
                  <span style="color: var(--orange);">${(Number(d.replyRate) || 0).toFixed(2)}% reply rate</span>
                </div>
              `).join('')}
            </div>
          `;
        }

        if (!alertsHtml) {
          alertsHtml = `
            <div style="background: var(--green-bg); border: 1px solid rgba(34, 197, 94, 0.3); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
              <h3 style="color: var(--green); margin: 0;">✅ All Clear</h3>
              <p style="color: var(--text-muted); margin: 8px 0 0 0;">No critical issues detected. Infrastructure meets Eric's standards.</p>
            </div>
          `;
        }

        content.innerHTML = `
          <div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
              <h1 class="page-title">📋 Eric's Deliverability Benchmarks</h1>
              <p class="page-subtitle">Infrastructure health based on GEX Deliverability Guide</p>
            </div>
            <button onclick="renderDeliverability()" 
                    style="background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border); padding: 10px 16px; border-radius: 8px; cursor: pointer; font-size: 13px;">
              ↻ Refresh
            </button>
          </div>

          <!-- Summary Cards -->
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card">
              <div class="summary-label">Domains</div>
              <div class="summary-value" style="color: var(--blue);">${summary.totalDomains || 0}</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">Healthy</div>
              <div class="summary-value" style="color: var(--green);">${(summary.healthy ?? summary.healthyDomains) || 0}</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">To Kill</div>
              <div class="summary-value" style="color: var(--red);">${summary.toKill || 0}</div>
            </div>
            <div class="summary-card">
              <div class="summary-label">Inboxes &lt;98%</div>
              <div class="summary-value" style="color: ${summary.inboxesBelow98 > 0 ? 'var(--red)' : 'var(--green)'};">${summary.inboxesBelow98 || 0}</div>
            </div>
          </div>

          <!-- Capacity Meter -->
          <div class="summary-card" style="margin-bottom: 24px;">
            <div style="font-weight: 600; color: var(--text); margin-bottom: 16px;">📊 Capacity Analysis</div>
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
              <div>
                <div style="color: var(--text-muted); font-size: 12px; margin-bottom: 4px;">Daily Capacity</div>
                <div style="font-size: 24px; font-weight: 600; color: var(--blue);">${(capacity.total || capacity.current || 0).toLocaleString()}</div>
              </div>
              <div>
                <div style="color: var(--text-muted); font-size: 12px; margin-bottom: 4px;">Headroom</div>
                <div style="font-size: 24px; font-weight: 600; color: ${(capacity.headroom || 0) >= 1.5 ? 'var(--green)' : 'var(--yellow)'};">${(capacity.headroom || 0).toFixed(2)}x</div>
                <div style="font-size: 11px; color: var(--text-dim);">Target: 1.5x</div>
              </div>
              <div>
                <div style="color: var(--text-muted); font-size: 12px; margin-bottom: 4px;">Backup Pool</div>
                <div style="font-size: 24px; font-weight: 600; color: ${(capacity.backupRatio || 0) >= 0.5 ? 'var(--green)' : 'var(--red)'};">${((capacity.backupRatio || 0) * 100).toFixed(0)}%</div>
                <div style="font-size: 11px; color: var(--text-dim);">Target: 50%</div>
              </div>
            </div>
          </div>

          <!-- Alerts -->
          ${alertsHtml}

          <!-- Provider Split -->
          ${providerData ? `
          <div class="summary-card" style="margin-bottom: 24px;">
            <div style="font-weight: 600; color: var(--text); margin-bottom: 16px;">📬 Reply Performance by Provider</div>
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
              <div style="text-align: center; padding: 16px; background: var(--bg-elevated); border-radius: 8px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">📧 Gmail</div>
                <div style="font-size: 24px; font-weight: 600; color: var(--green);">${providerData.providers?.gmail?.positiveRate || '0%'}</div>
                <div style="font-size: 11px; color: var(--text-dim);">${providerData.providers?.gmail?.total || 0} replies</div>
              </div>
              <div style="text-align: center; padding: 16px; background: var(--bg-elevated); border-radius: 8px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">📮 Outlook</div>
                <div style="font-size: 24px; font-weight: 600; color: var(--blue);">${providerData.providers?.outlook?.positiveRate || '0%'}</div>
                <div style="font-size: 11px; color: var(--text-dim);">${providerData.providers?.outlook?.total || 0} replies</div>
              </div>
              <div style="text-align: center; padding: 16px; background: var(--bg-elevated); border-radius: 8px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">🌐 Other</div>
                <div style="font-size: 24px; font-weight: 600; color: var(--purple);">${providerData.providers?.other?.positiveRate || '0%'}</div>
                <div style="font-size: 11px; color: var(--text-dim);">${providerData.providers?.other?.total || 0} replies</div>
              </div>
            </div>
            ${providerData.recommendation ? `<p style="color: var(--yellow); font-size: 12px; margin-top: 12px;">💡 ${providerData.recommendation}</p>` : ''}
          </div>
          ` : ''}

          <!-- Domain Table -->
          <div class="data-table">
            <div style="padding: 16px; border-bottom: 1px solid var(--border);">
              <span style="font-weight: 600; color: var(--text);">All Domains</span>
              <span style="color: var(--text-muted); margin-left: 8px; font-size: 13px;">(sorted by health status)</span>
            </div>
            <table>
              <thead>
                <tr>
                  <th>Status</th>
                  <th>Domain</th>
                  <th>Avg Rep</th>
                  <th>Reply %</th>
                  <th>Bounce %</th>
                </tr>
              </thead>
              <tbody>
                ${domains.map(d => `
                  <tr>
                    <td>
                      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 50%; background: ${d.health.color}; margin-right: 6px;"></span>
                      <span style="color: ${d.health.color}; font-size: 11px; text-transform: uppercase;">${d.health.status}</span>
                    </td>
                    <td style="font-weight: 500;">${d.domain}</td>
                    <td style="color: ${d.avgReputation >= 98 ? 'var(--green)' : 'var(--red)'};">${d.avgReputation}%</td>
                    <td style="color: ${(Number(d.replyRate) || 0) >= 1 ? 'var(--green)' : d.sent > 100 ? 'var(--red)' : 'var(--text-muted)'};">${(Number(d.replyRate) || 0).toFixed(2)}%</td>
                    <td style="color: ${(Number(d.bounceRate) || 0) <= 2 ? 'var(--green)' : 'var(--red)'};">${(Number(d.bounceRate) || 0).toFixed(2)}%</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        `;
      } catch (err) {
        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">📋 Eric's Deliverability Benchmarks</h1>
              <p class="page-subtitle">Infrastructure health based on GEX Deliverability Guide</p>
            </div>
          </div>
          <div class="summary-card" style="background: var(--red-bg); border: 1px solid rgba(239, 68, 68, 0.3);">
            <p style="color: var(--red);">Error loading deliverability data: ${err.message}</p>
          </div>
        `;
      }
    }

    // #2 - Warmup Calendar
    async function renderWarmupCalendar() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `<div class="summary-card"><p style="color: var(--text-muted);">Loading warmup calendar...</p></div>`;

      try {
        const res = await fetch('/api/deliverability/warmup-calendar');
        const data = await res.json();

        content.innerHTML = `
          <div class="page-header">
            <h1 class="page-title">📅 Warmup Calendar</h1>
            <p class="page-subtitle">Domain readiness timeline - Per Eric: 4+ weeks for Outlook</p>
          </div>

          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Ready (98%+)</div>
              <div class="summary-value" style="color: var(--green);">${data.summary?.ready || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Almost Ready</div>
              <div class="summary-value" style="color: var(--yellow);">${data.summary?.almost || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Still Warming</div>
              <div class="summary-value" style="color: var(--blue);">${data.summary?.warming || 0}</div>
            </div>
          </div>

          <div class="data-table">
            <table>
              <thead>
                <tr>
                  <th>Status</th>
                  <th>Domain</th>
                  <th>Inboxes</th>
                  <th>Avg Rep</th>
                  <th>Est. Age</th>
                  <th>Ready For</th>
                  <th>Days Until Ready</th>
                </tr>
              </thead>
              <tbody>
                ${(data.domains || []).map(d => `
                  <tr>
                    <td>
                      <span style="color: ${d.readiness === 'READY' ? 'var(--green)' : d.readiness === 'ALMOST' ? 'var(--yellow)' : 'var(--blue)'};">
                        ${d.readiness === 'READY' ? '🟢' : d.readiness === 'ALMOST' ? '🟡' : '🔵'} ${d.readiness}
                      </span>
                    </td>
                    <td style="font-weight: 500;">${d.domain}</td>
                    <td>${d.inboxes}</td>
                    <td style="color: ${d.avgReputation >= 98 ? 'var(--green)' : 'var(--yellow)'};">${d.avgReputation}%</td>
                    <td>${d.estimatedWeeksOld}+ weeks</td>
                    <td>${d.readyFor?.join(', ') || '—'}</td>
                    <td>${d.daysUntilReady > 0 ? d.daysUntilReady + ' days' : '✓ Ready'}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        `;
      } catch (err) {
        content.innerHTML = `<div class="summary-card" style="background: var(--red-bg);"><p style="color: var(--red);">Error: ${err.message}</p></div>`;
      }
    }

    // #9 - Insurance Pool Dashboard
    async function renderInsurancePool() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `<div class="summary-card"><p style="color: var(--text-muted);">Loading insurance pool...</p></div>`;

      try {
        const res = await fetch('/api/deliverability/insurance-pool');
        const data = await res.json();

        const healthy = data.capacity?.healthy;

        content.innerHTML = `
          <div class="page-header">
            <h1 class="page-title">🛡️ Insurance Pool Dashboard</h1>
            <p class="page-subtitle">Backup inboxes ready to deploy - Per Eric: Target 50% of ADV</p>
          </div>

          ${!healthy ? `
          <div style="background: var(--yellow-bg); border: 1px solid rgba(234, 179, 8, 0.3); border-radius: 8px; padding: 16px; margin-bottom: 24px;">
            <strong style="color: var(--yellow);">⚠️ ${data.recommendation}</strong>
          </div>
          ` : ''}

          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Active (In Campaigns)</div>
              <div class="summary-value" style="color: var(--blue);">${data.summary?.active || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Backup (Ready)</div>
              <div class="summary-value" style="color: var(--green);">${data.summary?.backup || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Still Warming</div>
              <div class="summary-value" style="color: var(--yellow);">${data.summary?.warming || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Backup Ratio</div>
              <div class="summary-value" style="color: ${healthy ? 'var(--green)' : 'var(--red)'};">${data.capacity?.currentBackupRatio}</div>
              <div style="font-size: 11px; color: var(--text-dim);">Target: 50%</div>
            </div>
          </div>

          ${data.capacity?.inboxesNeeded > 0 ? `
          <div class="summary-card" style="margin-bottom: 24px;">
            <div style="font-weight: 600; color: var(--text); margin-bottom: 8px;">📦 Action Required</div>
            <p style="color: var(--text-muted);">Need <strong style="color: var(--accent);">${data.capacity.inboxesNeeded}</strong> more warmed inboxes to reach 50% backup target.</p>
          </div>
          ` : ''}

          <div class="data-table">
            <div style="padding: 16px; border-bottom: 1px solid var(--border);">
              <span style="font-weight: 600; color: var(--text);">🟢 Ready Backup Inboxes (${data.pools?.backup?.length || 0})</span>
            </div>
            <table>
              <thead><tr><th>Email</th><th>Domain</th><th>Reputation</th></tr></thead>
              <tbody>
                ${(data.pools?.backup || []).slice(0, 30).map(i => `
                  <tr>
                    <td>${i.email}</td>
                    <td>${i.domain}</td>
                    <td style="color: var(--green);">${i.reputation}%</td>
                  </tr>
                `).join('') || '<tr><td colspan="3" style="text-align:center; color: var(--text-muted);">No backup inboxes ready</td></tr>'}
              </tbody>
            </table>
          </div>
        `;
      } catch (err) {
        content.innerHTML = `<div class="summary-card" style="background: var(--red-bg);"><p style="color: var(--red);">Error: ${err.message}</p></div>`;
      }
    }

    // #8 - Campaign Health Scores
    async function renderCampaignHealth() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `<div class="summary-card"><p style="color: var(--text-muted);">Loading campaign health...</p></div>`;

      try {
        const res = await fetch('/api/deliverability/campaign-health');
        const data = await res.json();

        content.innerHTML = `
          <div class="page-header">
            <h1 class="page-title">🎯 Campaign Health Scores</h1>
            <p class="page-subtitle">Combined score: reply rate + bounce rate + inbox health + volume</p>
          </div>

          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">🟢 Healthy</div>
              <div class="summary-value" style="color: var(--green);">${data.summary?.healthy || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">🟡 Warning</div>
              <div class="summary-value" style="color: var(--yellow);">${data.summary?.warning || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">🟠 At Risk</div>
              <div class="summary-value" style="color: var(--orange);">${data.summary?.atRisk || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">🔴 Critical</div>
              <div class="summary-value" style="color: var(--red);">${data.summary?.critical || 0}</div>
            </div>
          </div>

          <div class="data-table">
            <table>
              <thead>
                <tr>
                  <th>Score</th>
                  <th>Campaign</th>
                  <th>Reply %</th>
                  <th>Bounce %</th>
                  <th>Inbox Health</th>
                  <th>Volume</th>
                </tr>
              </thead>
              <tbody>
                ${(data.campaigns || []).map(c => `
                  <tr>
                    <td>
                      <span style="display: inline-flex; align-items: center; gap: 6px;">
                        <span style="font-weight: 700; color: ${c.health?.color};">${c.health?.score || 0}</span>
                        <span style="font-size: 11px; color: ${c.health?.color};">${c.health?.status}</span>
                      </span>
                    </td>
                    <td style="font-weight: 500; max-width: 300px; overflow: hidden; text-overflow: ellipsis;">${c.name}</td>
                    <td style="color: ${(Number(c.replyRate) || 0) >= 1 ? 'var(--green)' : 'var(--red)'};">${(Number(c.replyRate) || 0).toFixed(2)}%</td>
                    <td style="color: ${(Number(c.bounceRate) || 0) <= 2 ? 'var(--green)' : 'var(--red)'};">${(Number(c.bounceRate) || 0).toFixed(2)}%</td>
                    <td>${c.health?.breakdown?.inboxHealth?.value || '—'}</td>
                    <td>${c.health?.breakdown?.volumeHealth?.value || '—'}</td>
                  </tr>
                `).join('') || '<tr><td colspan="6" style="text-align:center; color: var(--text-muted);">No campaigns</td></tr>'}
              </tbody>
            </table>
          </div>
        `;
      } catch (err) {
        content.innerHTML = `<div class="summary-card" style="background: var(--red-bg);"><p style="color: var(--red);">Error: ${err.message}</p></div>`;
      }
    }

    // #4 - Volume Ramp Tracker
    async function renderVolumeTracker() {
      const content = document.getElementById('mainContent');
      content.innerHTML = `<div class="summary-card"><p style="color: var(--text-muted);">Loading volume tracker...</p></div>`;

      try {
        const res = await fetch('/api/deliverability/volume-tracker');
        const data = await res.json();

        const statusColor = data.overall?.status === 'HEALTHY' ? 'var(--green)' : 
                           data.overall?.status === 'UNDER-SENDING' ? 'var(--yellow)' : 'var(--red)';

        content.innerHTML = `
          <div class="page-header">
            <h1 class="page-title">📊 Volume Ramp Tracker</h1>
            <p class="page-subtitle">Daily sending vs capacity - Per Eric: If under-sending, re-batch immediately</p>
          </div>

          ${data.note ? `
          <div style="background: var(--yellow-bg); border: 1px solid rgba(234, 179, 8, 0.3); border-radius: 8px; padding: 16px; margin-bottom: 24px;">
            <strong style="color: var(--yellow);">⚠️ ${data.note}</strong>
          </div>
          ` : ''}

          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Daily Capacity</div>
              <div class="summary-value" style="color: var(--blue);">${data.overall?.dailyCapacity?.toLocaleString() || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Estimated Sent</div>
              <div class="summary-value" style="color: var(--text);">${data.overall?.estimatedSent?.toLocaleString() || 0}</div>
            </div>
            <div class="summary-card" style="text-align: center;">
              <div class="summary-label">Utilization</div>
              <div class="summary-value" style="color: ${statusColor};">${data.overall?.utilization || '0%'}</div>
              <div style="font-size: 11px; color: var(--text-dim);">${data.overall?.status}</div>
            </div>
          </div>

          <div class="data-table">
            <div style="padding: 16px; border-bottom: 1px solid var(--border);">
              <span style="font-weight: 600; color: var(--text);">Per-Domain Volume</span>
            </div>
            <table>
              <thead>
                <tr>
                  <th>Status</th>
                  <th>Domain</th>
                  <th>Inboxes</th>
                  <th>Capacity</th>
                  <th>Sent</th>
                  <th>Utilization</th>
                </tr>
              </thead>
              <tbody>
                ${(data.domains || []).map(d => `
                  <tr>
                    <td>
                      <span style="color: ${d.status === 'OK' ? 'var(--green)' : d.status === 'UNDER' ? 'var(--yellow)' : 'var(--red)'};">
                        ${d.status === 'OK' ? '🟢' : d.status === 'UNDER' ? '🟡' : '🔴'} ${d.status}
                      </span>
                    </td>
                    <td style="font-weight: 500;">${d.domain}</td>
                    <td>${d.inboxes}</td>
                    <td>${d.capacity}</td>
                    <td>${d.sent}</td>
                    <td style="color: ${d.utilization >= 50 && d.utilization <= 90 ? 'var(--green)' : 'var(--yellow)'};">${d.utilization}%</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        `;
      } catch (err) {
        content.innerHTML = `<div class="summary-card" style="background: var(--red-bg);"><p style="color: var(--red);">Error: ${err.message}</p></div>`;
      }
    }

    // Interested Leads View - Central CRM
    let interestedLeadsSource = 'all';
    let interestedLeadsData = null;
    
    // Interested Leads state
    let interestedLeadsSortCol = 'lead_response';
    let interestedLeadsSortDir = 'asc'; // Default: oldest first
    let interestedLeadsAllData = [];
    let leadsIdleTimer = null;
    let leadsLastActivity = Date.now();
    const LEADS_IDLE_RESET_MS = 30000; // 30 seconds
    
    // Undo stack for Cmd+Z / Ctrl+Z
    const undoStack = [];
    const MAX_UNDO = 20;
    
    function pushUndo(action) {
      undoStack.push(action);
      if (undoStack.length > MAX_UNDO) undoStack.shift();
    }
    
    async function performUndo() {
      if (undoStack.length === 0) {
        showToast('Nothing to undo', 'info');
        return;
      }
      
      // Save scroll position (use specific selector for the scrollable container)
      const tableContainer = document.querySelector('#leadsTable')?.closest('div[style*="overflow"]');
      const scrollPos = tableContainer?.scrollTop || 0;
      
      const action = undoStack.pop();
      try {
        if (action.type === 'edit') {
          // Restore previous value
          await fetch('/api/curated-leads/' + action.leadId, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ [action.field]: action.oldValue })
          });
          const lead = interestedLeadsAllData.find(l => l.id === action.leadId);
          if (lead) lead[action.field] = action.oldValue;
          renderInterestedLeadsTable();
          showToast('Undone: ' + action.field, 'success');
        } else if (action.type === 'create') {
          // Delete the created lead
          await fetch('/api/curated-leads/' + action.leadId, { method: 'DELETE' });
          interestedLeadsAllData = interestedLeadsAllData.filter(l => l.id !== action.leadId);
          renderInterestedLeadsTable();
          showToast('Undone: new lead removed', 'success');
        } else if (action.type === 'delete') {
          // Re-create the deleted lead
          const res = await fetch('/api/curated-leads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(action.lead)
          });
          const result = await res.json();
          if (result.lead) interestedLeadsAllData.push(result.lead);
          renderInterestedLeadsTable();
          showToast('Undone: lead restored', 'success');
        }
        
        // Restore scroll position (re-find container since it was re-created)
        // Use 100ms to ensure this runs AFTER renderInterestedLeadsTable's 10ms restoration
        setTimeout(() => {
          const newTableContainer = document.querySelector('#leadsTable')?.closest('div[style*="overflow"]');
          if (newTableContainer) {
            // If we had a saved position, restore it; otherwise scroll to bottom (user's typical workspace)
            newTableContainer.scrollTop = scrollPos > 0 ? scrollPos : newTableContainer.scrollHeight;
          }
        }, 100);
      } catch (err) {
        showToast('Undo failed: ' + err.message, 'error');
      }
    }
    
    // Listen for Cmd+Z / Ctrl+Z (undo) and Cmd+N / Ctrl+N (new lead)
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'z' && !e.shiftKey) {
        e.preventDefault();
        performUndo();
      }
      if ((e.metaKey || e.ctrlKey) && e.key === 'n' && !e.shiftKey) {
        e.preventDefault();
        showNewLeadRow();
      }
    });
    
    // Reset sort to default after idle
    function resetLeadsSortIfIdle() {
      if (Date.now() - leadsLastActivity >= LEADS_IDLE_RESET_MS) {
        if (interestedLeadsSortCol !== 'lead_response' || interestedLeadsSortDir !== 'asc') {
          interestedLeadsSortCol = 'lead_response';
          interestedLeadsSortDir = 'asc';
          renderInterestedLeadsTable();
          showToast('Sort reset to default (oldest first)', 'info');
        }
      }
    }
    
    // Start idle timer when leads view is active
    function startLeadsIdleTimer() {
      leadsLastActivity = Date.now();
      if (leadsIdleTimer) clearInterval(leadsIdleTimer);
      leadsIdleTimer = setInterval(resetLeadsSortIfIdle, 5000); // Check every 5 seconds
    }
    
    function stopLeadsIdleTimer() {
      if (leadsIdleTimer) {
        clearInterval(leadsIdleTimer);
        leadsIdleTimer = null;
      }
    }
    
    function recordLeadsActivity() {
      leadsLastActivity = Date.now();
    }
    
    async function renderInterestedLeads() {
      const content = document.getElementById('mainContent');
      content.innerHTML = '<div class="loading-overlay"><div class="spinner"></div></div>';
      
      try {
        // Use response-times/stats API which returns curated_leads data
        const res = await fetch('/api/response-times/stats?days=365');
        const data = await res.json();
        
        if (data.error) throw new Error(data.error);
        
        // Store leads for sorting/filtering - add domain field
        interestedLeadsAllData = (data.leads || []).map(l => ({
          ...l,
          domain: l.email ? l.email.split('@')[1] : null
        }));
        interestedLeadsData = { leads: interestedLeadsAllData }; // For CSV export compatibility
        
        // Start idle timer for sort reset
        startLeadsIdleTimer();
        
        renderInterestedLeadsTable();
        
        // Scroll to bottom after render
        setTimeout(() => {
          const tableContainer = document.querySelector('#leadsTable')?.closest('div');
          if (tableContainer) tableContainer.scrollTop = tableContainer.scrollHeight;
        }, 100);
      } catch (err) {
        content.innerHTML = '<div style="padding: 20px; color: var(--red);">Error: ' + err.message + '</div>';
      }
    }
    
    function renderInterestedLeadsTable() {
      // Preserve scroll position before re-render
      const existingTableContainer = document.querySelector('#leadsTable')?.closest('div[style*="overflow"]');
      const savedScrollTop = existingTableContainer?.scrollTop || 0;
      
      const content = document.getElementById('mainContent');
      let leads = [...interestedLeadsAllData];
      
      // Sort leads
      leads.sort((a, b) => {
        let aVal = a[interestedLeadsSortCol];
        let bVal = b[interestedLeadsSortCol];
        
        // Handle nulls
        if (aVal == null && bVal == null) return 0;
        if (aVal == null) return 1;
        if (bVal == null) return -1;
        
        // Handle dates
        if (interestedLeadsSortCol.includes('response') || interestedLeadsSortCol.includes('time')) {
          aVal = new Date(aVal).getTime() || 0;
          bVal = new Date(bVal).getTime() || 0;
        }
        
        // Handle strings
        if (typeof aVal === 'string') aVal = aVal.toLowerCase();
        if (typeof bVal === 'string') bVal = bVal.toLowerCase();
        
        if (aVal < bVal) return interestedLeadsSortDir === 'asc' ? -1 : 1;
        if (aVal > bVal) return interestedLeadsSortDir === 'asc' ? 1 : -1;
        return 0;
      });
      
      const sortIcon = (col) => {
        if (interestedLeadsSortCol !== col) return '<span style="opacity:0.3">⇅</span>';
        return interestedLeadsSortDir === 'asc' ? '↑' : '↓';
      };
      
      const escapeHtml = (str) => {
        if (!str) return '';
        return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      };
      
      const formatDateTime = (d) => {
        if (!d) return '-';
        const date = new Date(d);
        const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const timeStr = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
        return dateStr + ' ' + timeStr;
      };
      
      const statusColor = (status) => {
        if (status === 'Booked') return 'var(--green)';
        if (status === 'Scheduling') return 'var(--yellow)';
        if (status === 'Not booked') return 'var(--red)';
        return 'var(--text-muted)';
      };
      
      const categoryColor = (cat) => {
        if (cat === 'Meeting Request' || cat === 'Meeting Booked') return 'var(--green)';
        if (cat === 'Interested') return 'var(--green)';
        return 'var(--text-muted)';
      };
      
      const ertColor = (ert) => {
        if (!ert) return 'var(--text-muted)';
        const parts = ert.split(':').map(Number);
        const hours = parts[0] + (parts[1] || 0) / 60;
        if (hours < 5/60) return '#22c55e'; // under 5min - bright green
        if (hours < 0.25) return '#4ade80'; // under 15min - green
        if (hours < 1) return '#86efac'; // under 1hr - light green
        if (hours < 3) return '#bbf7d0'; // under 3hr - pale green
        if (hours < 6) return '#fef08a'; // under 6hr - yellow
        if (hours < 12) return '#fcd34d'; // under 12hr - amber
        if (hours < 24) return '#fb923c'; // under 24hr - orange
        return '#ef4444'; // over 24hr - red
      };
      
      const getDomain = (email) => {
        if (!email) return null;
        const parts = email.split('@');
        return parts.length > 1 ? parts[1] : null;
      };
      
      content.innerHTML = `
        <style>
          .excel-table { width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed; }
          .excel-table th { font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--text-muted); 
            padding: 8px 6px; text-align: left; border-bottom: 2px solid var(--border); cursor: pointer; 
            position: sticky; top: 0; background: var(--bg-card); z-index: 10; white-space: nowrap; }
          .excel-table th:hover { background: var(--bg-card-hover); }
          .excel-table td { padding: 4px 6px; border-bottom: 1px solid var(--border); white-space: nowrap; 
            overflow: hidden; text-overflow: ellipsis; height: 28px; vertical-align: middle; }
          .excel-table tr:nth-child(even) { background: rgba(255,255,255,0.02); }
          .excel-table tr:hover { background: rgba(255,255,255,0.05); }
          .excel-toolbar { display: flex; gap: 12px; margin-bottom: 12px; align-items: center; flex-wrap: wrap; }
          .excel-search { padding: 6px 10px; background: var(--bg-card); border: 1px solid var(--border); 
            border-radius: 4px; color: var(--text); width: 250px; font-size: 12px; }
          .excel-count { color: var(--text-muted); font-size: 12px; }
          .editable-cell { cursor: pointer; transition: background 0.15s; padding: 2px 4px; border-radius: 3px; }
          .editable-cell:hover { background: rgba(249, 115, 22, 0.15); }
          .editable-cell.editing { background: var(--bg-card); }
          .editable-input { background: var(--bg-card); border: 1px solid var(--accent); color: var(--text); 
            padding: 2px 4px; font-size: 12px; width: 100%; border-radius: 3px; outline: none; }
          .editable-select { background: var(--bg-card); border: 1px solid var(--accent); color: var(--text); 
            padding: 2px 4px; font-size: 12px; border-radius: 3px; outline: none; cursor: pointer; }
          .new-lead-row { background: rgba(249, 115, 22, 0.1) !important; }
          .new-lead-row td { padding: 6px !important; }
          .new-lead-input { background: var(--bg-card); border: 1px solid var(--border); color: var(--text); 
            padding: 4px 6px; font-size: 12px; width: 100%; border-radius: 3px; }
          .new-lead-input:focus { border-color: var(--accent); outline: none; }
          .new-lead-input.required-empty { border-color: var(--red) !important; background: rgba(239, 68, 68, 0.1); }
          .add-lead-btn { background: var(--accent); color: #fff; border: none; padding: 6px 14px; 
            border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600; transition: background 0.15s; }
          .add-lead-btn:hover { background: var(--accent-hover); }
          .save-lead-btn { background: var(--green); color: #000; border: none; padding: 4px 10px; 
            border-radius: 3px; cursor: pointer; font-size: 11px; font-weight: 600; }
          .cancel-lead-btn { background: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border); 
            padding: 4px 10px; border-radius: 3px; cursor: pointer; font-size: 11px; margin-left: 6px; }
          .datetime-input { font-size: 12px !important; width: 180px; background: var(--bg-card); border: 1px solid var(--border); 
            color: var(--text); padding: 6px 8px; border-radius: 3px; }
          .datetime-input:focus { border-color: var(--accent); outline: none; }
          input[type="datetime-local"]::-webkit-calendar-picker-indicator { display: none !important; }
          input[type="datetime-local"]::-webkit-inner-spin-button { display: none; }
          .delete-btn { background: none; border: none; cursor: pointer; opacity: 0.4; font-size: 12px; padding: 2px; }
          .delete-btn:hover { opacity: 1; }
          .add-row-btn { display: block; width: 100%; padding: 8px; background: var(--bg-card); border: 1px dashed var(--border); 
            color: var(--text-muted); cursor: pointer; font-size: 12px; margin-top: 4px; border-radius: 4px; }
          .add-row-btn:hover { border-color: var(--accent); color: var(--accent); }
        </style>
        
        <div class="excel-toolbar">
          <input type="text" class="excel-search" id="leadsSearch" placeholder="🔍 Search email, company, name..." oninput="filterLeadsTable(this.value)">
          <select id="statusFilter" onchange="applyLeadsFilters()" style="padding: 6px 10px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px; color: var(--text); font-size: 12px; cursor: pointer;">
            <option value="">All Status</option>
            <option value="Booked">Booked</option>
            <option value="Scheduling">Scheduling</option>
            <option value="Not booked">Not booked</option>
          </select>
          <select id="categoryFilter" onchange="applyLeadsFilters()" style="padding: 6px 10px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px; color: var(--text); font-size: 12px; cursor: pointer;">
            <option value="">All Category</option>
            <option value="Meeting Request">Meeting Request</option>
            <option value="Interested">Interested</option>
            <option value="Information Request">Info Request</option>
          </select>
          <select id="ertFilter" onchange="applyLeadsFilters()" style="padding: 6px 10px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px; color: var(--text); font-size: 12px; cursor: pointer;">
            <option value="">All ERT</option>
            <option value="under1h">Under 1 hour</option>
            <option value="1to6h">1-6 hours</option>
            <option value="6to24h">6-24 hours</option>
            <option value="over24h">Over 24 hours</option>
          </select>
          <span class="excel-count" id="leadsCount">${leads.length} leads</span>
          <button class="btn btn-default" onclick="copySelectedEmails()" style="font-size: 12px; padding: 6px 12px;" id="copyEmailsBtn" disabled>📋 Copy Emails (0)</button>
          <button class="add-lead-btn" onclick="showNewLeadRow()">+ Add Lead</button>
          <button class="btn btn-default" onclick="exportLeadsCSV()" style="font-size: 12px; padding: 6px 12px;">📥 Export CSV</button>
          <div style="flex:1"></div>
          <a href="https://supabase.com/dashboard/project/rwhqshjmngkyremwandx/editor/29369" target="_blank" style="font-size: 12px; color: var(--green); text-decoration: none; padding: 8px 14px; border: 1px solid var(--green); border-radius: 6px; display: flex; align-items: center; gap: 8px;" title="View curated_leads table in Supabase">
            <span style="font-size: 14px;">📊</span>
            <span style="display: flex; flex-direction: column; line-height: 1.3;">
              <span style="font-weight: 600;">curated_leads</span>
              <span style="font-size: 10px; opacity: 0.7;">${leads.length} rows · Supabase</span>
            </span>
          </a>
        </div>
        
        <div style="overflow-x: auto; overflow-y: auto; max-height: calc(100vh - 180px); border: 1px solid var(--border); border-radius: 4px;">
          <table class="excel-table" id="leadsTable">
            <thead>
              <tr>
                <th style="width: 30px; text-align: center;"><input type="checkbox" id="selectAllLeads" onclick="toggleAllLeads(this.checked)"></th>
                <th style="width: 35px; text-align: center;">#</th>
                <th style="width: 170px" onclick="sortLeads('email')">Email ${sortIcon('email')}</th>
                <th style="width: 120px" onclick="sortLeads('company')">Company ${sortIcon('company')}</th>
                <th style="width: 100px" onclick="sortLeads('domain')">Domain ${sortIcon('domain')}</th>
                <th style="width: 100px" onclick="sortLeads('name')">Name ${sortIcon('name')}</th>
                <th style="width: 75px" onclick="sortLeads('status')">Status ${sortIcon('status')}</th>
                <th style="width: 90px" onclick="sortLeads('category')">Category ${sortIcon('category')}</th>
                <th style="width: 65px" onclick="sortLeads('ert')">ERT <span style="font-size:9px;color:var(--text-dim);font-weight:400">(HH:MM:SS)</span> ${sortIcon('ert')}</th>
                <th style="width: 160px" onclick="sortLeads('lead_response')">Lead Reply <span style="font-size:9px;color:var(--text-dim);font-weight:400">(ET)</span> ${sortIcon('lead_response')}</th>
                <th style="width: 160px" onclick="sortLeads('response_time')">Our Reply <span style="font-size:9px;color:var(--text-dim);font-weight:400">(ET)</span> ${sortIcon('response_time')}</th>
                <th style="width: 70px" onclick="sortLeads('source')">Source ${sortIcon('source')}</th>
                <th style="width: 130px" onclick="sortLeads('notes')">Notes ${sortIcon('notes')}</th>
                <th style="width: 30px"></th>
              </tr>
            </thead>
            <tbody id="leadsTableBody">
              ${leads.map((l, idx) => {
                const domain = getDomain(l.email);
                return `
                <tr data-id="${l.id}" data-search="${escapeHtml((l.email||'') + ' ' + (l.company||'') + ' ' + (l.name||'') + ' ' + (l.notes||'')).toLowerCase()}" data-email="${escapeHtml(l.email)}" data-status="${escapeHtml(l.status || '')}" data-category="${escapeHtml(l.category || '')}" data-ert-seconds="${l.ert_seconds || 0}">
                  <td style="text-align: center;"><input type="checkbox" class="lead-checkbox" data-email="${escapeHtml(l.email)}" onclick="updateCopyCount()"></td>
                  <td style="text-align: center; color: var(--text-dim); font-size: 11px;">${idx + 1}</td>
                  <td class="editable-cell" onclick="editLeadCell(this, ${l.id}, 'email')" title="Click to edit">${escapeHtml(l.email)}</td>
                  <td class="editable-cell" onclick="editLeadCell(this, ${l.id}, 'company')" title="Click to edit">${escapeHtml(l.company) || '<span style="opacity:0.3">-</span>'}</td>
                  <td class="editable-cell" onclick="editLeadCell(this, ${l.id}, 'domain')" title="Click to edit">${domain ? '<a href="https://' + domain + '" target="_blank" style="color: var(--accent); text-decoration: none;" onclick="event.stopPropagation()">' + domain + '</a>' : '<span style="opacity:0.3">-</span>'}</td>
                  <td class="editable-cell" onclick="editLeadCell(this, ${l.id}, 'name')" title="Click to edit">${escapeHtml(l.name) || '<span style="opacity:0.3">-</span>'}</td>
                  <td class="editable-cell" onclick="editLeadCellSelect(this, ${l.id}, 'status', ['Booked', 'Scheduling', 'Not booked'])" title="Click to edit"><span style="color: ${statusColor(l.status)}; font-weight: 500;">${escapeHtml(l.status) || '<span style="opacity:0.3">-</span>'}</span></td>
                  <td class="editable-cell" onclick="editLeadCellSelect(this, ${l.id}, 'category', ['Interested', 'Meeting Request', 'Information Request', 'Meeting Booked'])" title="Click to edit"><span style="color: ${categoryColor(l.category)};">${escapeHtml(l.category) || '<span style="opacity:0.3">-</span>'}</span></td>
                  <td class="editable-cell" onclick="editLeadCell(this, ${l.id}, 'ert')" title="Click to edit" style="font-family: monospace; color: ${ertColor(l.ert)}; font-weight: 500;">${escapeHtml(l.ert) || '<span style="opacity:0.3">-</span>'}</td>
                  <td class="editable-cell" onclick="editLeadCellDateTime(this, ${l.id}, 'lead_response')" title="Click to edit" style="color: var(--text-muted); font-size: 11px;">${formatDateTime(l.lead_response) || '<span style="opacity:0.3">-</span>'}</td>
                  <td class="editable-cell" onclick="editLeadCellDateTime(this, ${l.id}, 'response_time')" title="Click to edit" style="color: var(--text-muted); font-size: 11px;">${formatDateTime(l.response_time) || '<span style="opacity:0.3">-</span>'}</td>
                  <td class="editable-cell" onclick="editLeadCellSelect(this, ${l.id}, 'source', ['cold_email', 'inbound', 'outbound', 'reactivation'])" title="Click to edit">${escapeHtml(l.source) || '<span style="opacity:0.3">-</span>'}</td>
                  <td class="editable-cell" onclick="editLeadCell(this, ${l.id}, 'notes')" title="Click to edit" style="color: var(--text-dim);">${escapeHtml(l.notes) || '<span style="opacity:0.3">-</span>'}</td>
                  <td style="text-align: center;"><button class="delete-btn" onclick="deleteLead(${l.id}, '${escapeHtml(l.email)}')" title="Delete lead">🗑️</button></td>
                </tr>
              `;}).join('')}
            </tbody>
          </table>
        </div>
        <button class="add-row-btn" onclick="showNewLeadRow()">+ Add New Lead</button>
      `;
      
      // Restore scroll position after re-render
      if (savedScrollTop > 0) {
        setTimeout(() => {
          const newTableContainer = document.querySelector('#leadsTable')?.closest('div[style*="overflow"]');
          if (newTableContainer) newTableContainer.scrollTop = savedScrollTop;
        }, 10);
      }
    }
    
    // Editable cell - text input
    function editLeadCell(td, leadId, field) {
      recordLeadsActivity();
      if (td.querySelector('input')) return; // Already editing
      
      const currentValue = td.textContent.trim() === '-' ? '' : td.textContent.trim();
      const originalHtml = td.innerHTML;
      
      td.classList.add('editing');
      td.innerHTML = '<input type="text" class="editable-input" value="' + currentValue.replace(/"/g, '&quot;') + '">';
      const input = td.querySelector('input');
      input.focus();
      input.select();
      
      const saveValue = async () => {
        const newValue = input.value.trim();
        td.classList.remove('editing');
        
        if (newValue === currentValue) {
          td.innerHTML = originalHtml;
          return;
        }
        
        td.innerHTML = '<span style="opacity:0.5">Saving...</span>';
        
        try {
          const res = await fetch('/api/curated-leads/' + leadId, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ [field]: newValue || null })
          });
          const result = await res.json();
          if (result.error) throw new Error(result.error);
          
          // Update local data and track for undo
          const lead = interestedLeadsAllData.find(l => l.id === leadId);
          if (lead) {
            pushUndo({ type: 'edit', leadId, field, oldValue: currentValue || null });
            lead[field] = newValue || null;
          }
          
          td.innerHTML = newValue || '<span style="opacity:0.3">-</span>';
          showToast('Saved', 'success');
        } catch (err) {
          td.innerHTML = originalHtml;
          showToast('Error: ' + err.message, 'error');
        }
      };
      
      input.addEventListener('blur', saveValue);
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
        if (e.key === 'Escape') { td.innerHTML = originalHtml; td.classList.remove('editing'); }
      });
    }
    
    // Editable cell - select dropdown
    function editLeadCellSelect(td, leadId, field, options) {
      recordLeadsActivity();
      if (td.querySelector('select')) return; // Already editing
      
      const currentSpan = td.querySelector('span');
      const currentValue = currentSpan ? currentSpan.textContent.trim() : '';
      const originalHtml = td.innerHTML;
      
      td.classList.add('editing');
      td.innerHTML = '<select class="editable-select"><option value="">-</option>' + 
        options.map(opt => '<option value="' + opt + '"' + (opt === currentValue ? ' selected' : '') + '>' + opt + '</option>').join('') + 
        '</select>';
      
      const select = td.querySelector('select');
      select.focus();
      
      const saveValue = async () => {
        const newValue = select.value;
        td.classList.remove('editing');
        
        if (newValue === currentValue) {
          td.innerHTML = originalHtml;
          return;
        }
        
        td.innerHTML = '<span style="opacity:0.5">Saving...</span>';
        
        try {
          const res = await fetch('/api/curated-leads/' + leadId, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ [field]: newValue || null })
          });
          const result = await res.json();
          if (result.error) throw new Error(result.error);
          
          // Update local data and track for undo
          const lead = interestedLeadsAllData.find(l => l.id === leadId);
          if (lead) {
            pushUndo({ type: 'edit', leadId, field, oldValue: currentValue || null });
            lead[field] = newValue || null;
          }
          
          // Re-render to update colors
          renderInterestedLeadsTable();
          showToast('Saved', 'success');
        } catch (err) {
          td.innerHTML = originalHtml;
          showToast('Error: ' + err.message, 'error');
        }
      };
      
      select.addEventListener('change', saveValue);
      select.addEventListener('blur', () => {
        setTimeout(() => {
          if (td.querySelector('select')) td.innerHTML = originalHtml;
          td.classList.remove('editing');
        }, 100);
      });
      select.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { td.innerHTML = originalHtml; td.classList.remove('editing'); }
      });
    }
    
    // Editable cell - datetime picker
    function editLeadCellDateTime(td, leadId, field) {
      recordLeadsActivity();
      if (td.querySelector('input')) return;
      
      const lead = interestedLeadsAllData.find(l => l.id === leadId);
      const currentValue = lead ? lead[field] : null;
      const originalHtml = td.innerHTML;
      
      // Convert to datetime-local format (LOCAL time, not UTC)
      let inputValue = '';
      if (currentValue) {
        const d = new Date(currentValue);
        // Format in local timezone for datetime-local input
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        const hours = String(d.getHours()).padStart(2, '0');
        const mins = String(d.getMinutes()).padStart(2, '0');
        inputValue = year + '-' + month + '-' + day + 'T' + hours + ':' + mins;
      }
      
      td.classList.add('editing');
      td.innerHTML = '<input type="datetime-local" class="editable-input" value="' + inputValue + '" style="font-size: 13px; width: 185px; padding: 6px 8px;">';
      
      const input = td.querySelector('input');
      input.focus();
      
      let saved = false; // Prevent double-save
      const originalValue = currentValue; // Store for comparison
      
      const saveValue = async () => {
        if (saved) return;
        
        const newValue = input.value ? new Date(input.value).toISOString() : null;
        
        // Only save if value actually changed
        const oldTime = originalValue ? new Date(originalValue).getTime() : null;
        const newTime = newValue ? new Date(newValue).getTime() : null;
        if (oldTime === newTime) {
          // No change - just restore display without saving
          td.classList.remove('editing');
          td.innerHTML = originalHtml;
          return;
        }
        
        // Validate: lead_response must be before response_time
        if ((field === 'lead_response' || field === 'response_time') && lead) {
          const leadResponseVal = field === 'lead_response' ? newValue : lead.lead_response;
          const ourReplyVal = field === 'response_time' ? newValue : lead.response_time;
          
          if (leadResponseVal && ourReplyVal) {
            const leadTime = new Date(leadResponseVal);
            const ourTime = new Date(ourReplyVal);
            if (leadTime >= ourTime) {
              showToast('Lead reply must be BEFORE our reply', 'error');
              td.innerHTML = originalHtml;
              td.classList.remove('editing');
              return;
            }
          }
        }
        
        saved = true;
        td.classList.remove('editing');
        td.innerHTML = '<span style="opacity:0.5">Saving...</span>';
        
        try {
          // If lead_response or response_time changed, also recalculate ERT
          const updateData = { [field]: newValue };
          
          // Auto-calculate ERT when time fields change
          if ((field === 'lead_response' || field === 'response_time') && lead) {
            const leadResponse = field === 'lead_response' ? newValue : lead.lead_response;
            const ourReply = field === 'response_time' ? newValue : lead.response_time;
            
            console.log('ERT calc:', { field, leadResponse, ourReply }); // Debug
            
            if (leadResponse && ourReply) {
              const diffMs = Math.abs(new Date(ourReply) - new Date(leadResponse));
              const hours = Math.floor(diffMs / 3600000);
              const mins = Math.floor((diffMs % 3600000) / 60000);
              const secs = Math.floor((diffMs % 60000) / 1000);
              updateData.ert = String(hours).padStart(2, '0') + ':' + String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');
              console.log('New ERT:', updateData.ert); // Debug
            }
          }
          
          const res = await fetch('/api/curated-leads/' + leadId, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(updateData)
          });
          const result = await res.json();
          if (result.error) throw new Error(result.error);
          
          // Update local data and track for undo
          if (lead) {
            pushUndo({ type: 'edit', leadId, field, oldValue: currentValue });
            lead[field] = newValue;
            if (updateData.ert) lead.ert = updateData.ert;
          }
          
          renderInterestedLeadsTable();
          showToast('Saved', 'success');
        } catch (err) {
          td.innerHTML = originalHtml;
          showToast('Error: ' + err.message, 'error');
        }
      };
      
      input.addEventListener('blur', saveValue);
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { input.blur(); }
        if (e.key === 'Escape') { td.innerHTML = originalHtml; td.classList.remove('editing'); saved = true; }
      });
    }
    
    // Show new lead row
    let newLeadRowVisible = false;
    function showNewLeadRow() {
      recordLeadsActivity();
      if (newLeadRowVisible) return;
      newLeadRowVisible = true;
      
      const tbody = document.getElementById('leadsTableBody');
      const rowNum = tbody.querySelectorAll('tr').length + 1;
      
      const newRow = document.createElement('tr');
      newRow.className = 'new-lead-row';
      newRow.id = 'newLeadRow';
      // Get current Eastern time for auto-fill
      const nowET = new Date().toLocaleString('sv-SE', { timeZone: 'America/New_York' }).slice(0, 16).replace(' ', 'T');
      
      newRow.innerHTML = `
        <td></td>
        <td style="text-align: center; color: var(--accent); font-weight: bold;">${rowNum}</td>
        <td><input type="email" class="new-lead-input" id="newLeadEmail" placeholder="email@company.com" required></td>
        <td><input type="text" class="new-lead-input" id="newLeadCompany" placeholder="Company"></td>
        <td><input type="text" class="new-lead-input" id="newLeadDomain" placeholder="domain.com" style="width: 80px;"></td>
        <td><input type="text" class="new-lead-input" id="newLeadName" placeholder="Name"></td>
        <td>
          <select class="new-lead-input" id="newLeadStatus" style="padding: 3px 4px;">
            <option value="">-</option>
            <option value="Booked">Booked</option>
            <option value="Scheduling" selected>Scheduling</option>
            <option value="Not booked">Not booked</option>
          </select>
        </td>
        <td>
          <select class="new-lead-input" id="newLeadCategory" style="padding: 3px 4px;">
            <option value="Interested">Interested</option>
            <option value="Meeting Request">Meeting Request</option>
            <option value="Information Request">Information Request</option>
          </select>
        </td>
        <td style="color: var(--text-dim); font-size: 11px;">auto</td>
        <td><input type="datetime-local" class="new-lead-input datetime-input" id="newLeadResponse" value="${nowET}"> <span style="font-size:9px;color:var(--text-dim)">ET</span></td>
        <td><input type="datetime-local" class="new-lead-input datetime-input" id="newLeadOurReply" value="${nowET}"> <span style="font-size:9px;color:var(--text-dim)">ET</span></td>
        <td style="color: var(--text-dim);">outbound</td>
        <td>
          <button class="save-lead-btn" onclick="saveNewLead()">Save</button>
          <button class="cancel-lead-btn" onclick="cancelNewLead()">Cancel</button>
        </td>
        <td></td>
      `;
      tbody.appendChild(newRow);
      
      // Auto-extract name, company, domain from email
      const emailInput = document.getElementById('newLeadEmail');
      const nameInput = document.getElementById('newLeadName');
      const companyInput = document.getElementById('newLeadCompany');
      const domainInput = document.getElementById('newLeadDomain');
      emailInput.focus();
      
      // Auto-fill function - extract name, company, domain from email
      const autoFillFromEmail = () => {
        const email = emailInput.value.trim();
        if (email.includes('@')) {
          const [localPart, domain] = email.split('@');
          // Auto-fill name from local part (only if not manually edited)
          if (localPart && !nameInput.dataset.userEdited) {
            const name = localPart.replace(/[._-]/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
            nameInput.value = name;
          }
          // Auto-fill domain ALWAYS when we have something after @
          if (domain) {
            domainInput.value = domain;
            // Auto-fill company from domain (without TLD, only if not manually edited)
            if (!companyInput.dataset.userEdited) {
              // Handle domains with or without dots
              const companyPart = domain.includes('.') ? domain.split('.')[0] : domain;
              const companyName = companyPart.replace(/[._-]/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
              companyInput.value = companyName;
            }
          }
        }
      };
      
      // Trigger auto-fill on input, blur, and paste
      emailInput.addEventListener('input', autoFillFromEmail);
      emailInput.addEventListener('blur', autoFillFromEmail);
      emailInput.addEventListener('paste', () => setTimeout(autoFillFromEmail, 0));
      
      // Track if user manually edited name/company
      nameInput.addEventListener('input', () => nameInput.dataset.userEdited = 'true');
      companyInput.addEventListener('input', () => companyInput.dataset.userEdited = 'true');
      
      // Enter key saves the lead
      newRow.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          saveNewLead();
        }
      });
      
      // Scroll to bottom
      const tableContainer = tbody.closest('div');
      tableContainer.scrollTop = tableContainer.scrollHeight;
    }
    
    function cancelNewLead() {
      const row = document.getElementById('newLeadRow');
      if (row) row.remove();
      newLeadRowVisible = false;
    }
    
    async function saveNewLead() {
      console.log('saveNewLead called');
      recordLeadsActivity();
      const email = document.getElementById('newLeadEmail')?.value?.trim();
      console.log('Email:', email);
      const company = document.getElementById('newLeadCompany').value.trim();
      const domain = document.getElementById('newLeadDomain').value.trim();
      const name = document.getElementById('newLeadName').value.trim();
      const status = document.getElementById('newLeadStatus').value;
      const category = document.getElementById('newLeadCategory').value;
      const leadResponse = document.getElementById('newLeadResponse').value;
      const ourReply = document.getElementById('newLeadOurReply').value;
      
      // Validate email
      if (!email || !email.includes('@')) {
        document.getElementById('newLeadEmail').classList.add('required-empty');
        showToast('Email is required', 'error');
        return;
      }
      document.getElementById('newLeadEmail').classList.remove('required-empty');
      
      // Validate reply time is before our reply time
      if (leadResponse && ourReply) {
        const leadTime = new Date(leadResponse);
        const ourTime = new Date(ourReply);
        if (leadTime >= ourTime) {
          showToast('Lead reply must be BEFORE our reply', 'error');
          document.getElementById('newLeadResponse').focus();
          return;
        }
      }
      
      const saveBtn = document.querySelector('.save-lead-btn');
      saveBtn.textContent = 'Saving...';
      saveBtn.disabled = true;
      
      try {
        const res = await fetch('/api/curated-leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email,
            company: company || null,
            domain: domain || (email.includes('@') ? email.split('@')[1] : null),
            name: name || null,
            status: status || 'Scheduling',
            category: category || 'Interested',
            lead_response: leadResponse ? new Date(leadResponse).toISOString() : null,
            response_time: ourReply ? new Date(ourReply).toISOString() : null,
            source: 'outbound'
          })
        });
        
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        newLeadRowVisible = false;
        showToast('Lead created!', 'success');
        
        // Add new lead to local data and re-render table only (no full page refresh)
        if (result.lead) {
          result.lead.domain = result.lead.domain || (email.includes('@') ? email.split('@')[1] : null);
          interestedLeadsAllData.push(result.lead);
          pushUndo({ type: 'create', leadId: result.lead.id });
        }
        renderInterestedLeadsTable();
        
        // Scroll to bottom to show new lead
        setTimeout(() => {
          const tableContainer = document.querySelector('#leadsTable')?.closest('div');
          if (tableContainer) tableContainer.scrollTop = tableContainer.scrollHeight;
        }, 100);
      } catch (err) {
        console.error('Save error:', err);
        saveBtn.textContent = 'Save';
        saveBtn.disabled = false;
        showToast('Error: ' + err.message, 'error');
      }
    }
    
    // Delete lead (instant, no confirm)
    async function deleteLead(leadId, email) {
      // Find and save lead data for undo
      const leadToDelete = interestedLeadsAllData.find(l => l.id === leadId);
      if (leadToDelete) {
        pushUndo({ type: 'delete', leadId, lead: { ...leadToDelete } });
      }
      
      // Remove from UI immediately
      const row = document.querySelector(`tr[data-id="${leadId}"]`);
      if (row) row.style.opacity = '0.3';
      
      // Remove from local data
      interestedLeadsAllData = interestedLeadsAllData.filter(l => l.id !== leadId);
      
      // Delete from server in background
      fetch('/api/curated-leads/' + leadId, { method: 'DELETE' })
        .then(res => res.json())
        .then(result => {
          if (result.error) throw new Error(result.error);
          if (row) row.remove();
          showToast('Deleted', 'delete');
        })
        .catch(err => {
          showToast('Error: ' + err.message, 'error');
          // Restore if failed
          renderInterestedLeadsTable();
        });
    }
    
    // Simple toast helper
    function showToast(message, type = 'info') {
      const toast = document.createElement('div');
      toast.className = 'toast ' + type;
      const icon = type === 'success' ? '✓ ' : type === 'error' ? '✗ ' : type === 'delete' ? '🗑 ' : 'ℹ ';
      toast.innerHTML = icon + message;
      const container = document.querySelector('.toast-container') || (() => {
        const c = document.createElement('div');
        c.className = 'toast-container';
        document.body.appendChild(c);
        return c;
      })();
      container.appendChild(toast);
      setTimeout(() => { toast.classList.add('hide'); setTimeout(() => toast.remove(), 300); }, 2500);
    }
    
    function sortLeads(col) {
      recordLeadsActivity();
      if (interestedLeadsSortCol === col) {
        interestedLeadsSortDir = interestedLeadsSortDir === 'asc' ? 'desc' : 'asc';
      } else {
        interestedLeadsSortCol = col;
        interestedLeadsSortDir = 'asc';
      }
      renderInterestedLeadsTable();
    }
    
    function toggleAllLeads(checked) {
      document.querySelectorAll('.lead-checkbox').forEach(cb => cb.checked = checked);
      updateCopyCount();
    }
    
    function updateCopyCount() {
      const checked = document.querySelectorAll('.lead-checkbox:checked');
      const btn = document.getElementById('copyEmailsBtn');
      if (btn) {
        btn.textContent = '📋 Copy Emails (' + checked.length + ')';
        btn.disabled = checked.length === 0;
      }
    }
    
    async function copySelectedEmails() {
      const checked = document.querySelectorAll('.lead-checkbox:checked');
      const emails = Array.from(checked).map(cb => cb.dataset.email).filter(Boolean);
      if (emails.length === 0) return;
      
      try {
        await navigator.clipboard.writeText(emails.join('\n'));
        showToast('Copied ' + emails.length + ' email(s)', 'success');
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    }
    
    async function updateLeadBooking(id, status) {
      try {
        await fetch('/api/interested-leads/' + id, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ booking_status: status })
        });
        // Refresh data
        renderInterestedLeads();
      } catch (err) {
        alert('Error updating lead: ' + err.message);
      }
    }
    
    async function copyToClipboard(text) {
      try {
        await navigator.clipboard.writeText(text);
        // Show brief toast
        const toast = document.createElement('div');
        toast.textContent = '✓ Copied: ' + text;
        toast.style.cssText = 'position: fixed; bottom: 20px; right: 20px; background: var(--green); color: #000; padding: 10px 16px; border-radius: 6px; font-size: 13px; z-index: 2000; animation: fadeOut 2s forwards;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    }
    
    function showAddLeadModal() {
      document.getElementById('addLeadModal').style.display = 'flex';
    }
    
    function hideAddLeadModal() {
      document.getElementById('addLeadModal').style.display = 'none';
    }
    
    async function submitNewLead(e) {
      e.preventDefault();
      const form = e.target;
      const data = {
        email: form.email.value,
        name: form.name.value,
        company: form.company.value,
        source: form.source.value,
        booking_status: form.booking_status.value,
        meeting_date: form.meeting_date.value || null,
        notes: form.notes.value
      };
      
      try {
        const res = await fetch('/api/interested-leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        hideAddLeadModal();
        form.reset();
        renderInterestedLeads();
      } catch (err) {
        alert('Error adding lead: ' + err.message);
      }
    }
    
    function editLead(id) {
      // Find lead in data
      const lead = interestedLeadsData?.leads?.find(l => l.id === id);
      if (!lead) return;
      
      // Populate modal with lead data
      document.getElementById('editLeadId').value = id;
      document.getElementById('editLeadEmail').value = lead.email || '';
      document.getElementById('editLeadName').value = lead.name || '';
      document.getElementById('editLeadCompany').value = lead.company || '';
      document.getElementById('editLeadSource').value = lead.source || 'cold_email';
      document.getElementById('editLeadBookingStatus').value = lead.booking_status || 'Scheduling';
      document.getElementById('editLeadNotes').value = lead.notes || '';
      
      // Format meeting date for datetime-local input
      if (lead.meeting_date) {
        const date = new Date(lead.meeting_date);
        document.getElementById('editLeadMeetingDate').value = date.toISOString().slice(0, 16);
      } else {
        document.getElementById('editLeadMeetingDate').value = '';
      }
      
      document.getElementById('editLeadModal').style.display = 'flex';
    }
    
    function hideEditLeadModal() {
      document.getElementById('editLeadModal').style.display = 'none';
    }
    
    async function submitEditLead(e) {
      e.preventDefault();
      const form = e.target;
      const id = form.id.value;
      const data = {
        name: form.name.value,
        company: form.company.value,
        source: form.source.value,
        booking_status: form.booking_status.value,
        meeting_date: form.meeting_date.value || null,
        notes: form.notes.value
      };
      
      try {
        const res = await fetch('/api/interested-leads/' + id, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.error) throw new Error(result.error);
        
        hideEditLeadModal();
        renderInterestedLeads();
        
        // Show success toast
        const toast = document.createElement('div');
        toast.textContent = '✓ Lead updated successfully';
        toast.style.cssText = 'position: fixed; bottom: 20px; right: 20px; background: var(--green); color: #000; padding: 10px 16px; border-radius: 6px; font-size: 13px; z-index: 2000; animation: fadeOut 2s forwards;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
      } catch (err) {
        alert('Error updating lead: ' + err.message);
      }
    }
    
    function filterLeadsTable(query) {
      applyLeadsFilters();
    }
    
    function applyLeadsFilters() {
      const rows = document.querySelectorAll('#leadsTable tbody tr');
      const searchQuery = (document.getElementById('leadsSearch')?.value || '').toLowerCase().trim();
      const statusFilter = document.getElementById('statusFilter')?.value || '';
      const categoryFilter = document.getElementById('categoryFilter')?.value || '';
      const ertFilter = document.getElementById('ertFilter')?.value || '';
      
      let visibleCount = 0;
      let totalCount = 0;
      
      rows.forEach(row => {
        // Skip the "new lead" row
        if (row.id === 'newLeadRow') return;
        totalCount++;
        
        // Search filter
        const searchData = row.getAttribute('data-search') || row.textContent.toLowerCase();
        const matchesSearch = !searchQuery || searchData.includes(searchQuery);
        
        // Status filter
        const rowStatus = row.getAttribute('data-status') || '';
        const matchesStatus = !statusFilter || rowStatus === statusFilter;
        
        // Category filter
        const rowCategory = row.getAttribute('data-category') || '';
        const matchesCategory = !categoryFilter || rowCategory === categoryFilter;
        
        // ERT filter
        const rowErtSeconds = parseInt(row.getAttribute('data-ert-seconds') || '0', 10);
        let matchesErt = true;
        if (ertFilter) {
          if (ertFilter === 'under1h') matchesErt = rowErtSeconds > 0 && rowErtSeconds < 3600;
          else if (ertFilter === '1to6h') matchesErt = rowErtSeconds >= 3600 && rowErtSeconds < 21600;
          else if (ertFilter === '6to24h') matchesErt = rowErtSeconds >= 21600 && rowErtSeconds < 86400;
          else if (ertFilter === 'over24h') matchesErt = rowErtSeconds >= 86400;
        }
        
        const visible = matchesSearch && matchesStatus && matchesCategory && matchesErt;
        row.style.display = visible ? '' : 'none';
        if (visible) visibleCount++;
      });
      
      // Update count display
      const countEl = document.getElementById('leadsCount');
      const hasFilters = searchQuery || statusFilter || categoryFilter || ertFilter;
      if (countEl) {
        countEl.textContent = hasFilters ? `${visibleCount} of ${totalCount} leads` : `${totalCount} leads`;
      }
    }
    
    function exportLeadsCSV() {
      if (!interestedLeadsData?.leads) return;
      
      const headers = ['Email', 'Company', 'Name', 'Status', 'Category', 'ERT', 'Lead Reply', 'Our Reply', 'Source', 'Notes'];
      const rows = interestedLeadsData.leads.map(l => [
        l.email || '',
        l.company || '',
        l.name || '',
        l.status || '',
        l.category || '',
        l.ert || '',
        l.lead_response ? new Date(l.lead_response).toISOString() : '',
        l.response_time ? new Date(l.response_time).toISOString() : '',
        l.source || '',
        (l.notes || '').replace(/"/g, '""')
      ]);
      
      const csv = [headers.join(','), ...rows.map(r => r.map(c => '"' + c + '"').join(','))].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'interested-leads-' + new Date().toISOString().split('T')[0] + '.csv';
      a.click();
      URL.revokeObjectURL(url);
    }

    // Imann Bookings View
    async function renderImannBookings() {
      const content = document.getElementById('mainContent');
      content.innerHTML = '<div class="loading-overlay"><div class="spinner"></div></div>';
      
      try {
        // Fetch both bookings and upcoming meetings
        const [bookingsRes, meetingsRes] = await Promise.all([
          fetch('/api/imann/bookings'),
          fetch('/api/upcoming-meetings')
        ]);
        const data = await bookingsRes.json();
        const meetings = await meetingsRes.json();
        
        if (data.error) throw new Error(data.error);
        
        const { summary, monthlyBreakdown, weeklyBreakdown, responseTimeCorrelation, leads } = data;
        
        // Format upcoming meetings section
        const upcomingHTML = meetings.upcoming && meetings.upcoming.length > 0 ? `
          <div class="summary-card" style="grid-column: span 2; background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(99, 102, 241, 0.05)); border: 1px solid var(--accent);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
              <h3 style="font-size: 14px; color: var(--accent);">📅 UPCOMING MEETINGS (${meetings.summary.upcoming})</h3>
              ${meetings.summary.nextMeeting ? `<span style="background: var(--accent); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;">Next: ${meetings.summary.daysUntilNext === 0 ? 'TODAY!' : meetings.summary.daysUntilNext === 1 ? 'Tomorrow' : meetings.summary.daysUntilNext + ' days'}</span>` : ''}
            </div>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px;">
              ${meetings.upcoming.slice(0, 6).map(m => {
                const date = new Date(m.meeting_date);
                const isToday = date.toDateString() === new Date().toDateString();
                const isTomorrow = date.toDateString() === new Date(Date.now() + 86400000).toDateString();
                return `
                  <div style="background: var(--card-bg); border-radius: 8px; padding: 12px; border-left: 3px solid ${isToday ? 'var(--green)' : isTomorrow ? 'var(--yellow)' : 'var(--accent)'};">
                    <div style="font-size: 11px; color: ${isToday ? 'var(--green)' : isTomorrow ? 'var(--yellow)' : 'var(--accent)'}; font-weight: 600; margin-bottom: 4px;">
                      ${isToday ? '🟢 TODAY' : isTomorrow ? '🟡 TOMORROW' : date.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })}
                      · ${date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}
                    </div>
                    <div style="font-weight: 600; font-size: 14px;">${m.name || 'Unknown'}</div>
                    <div style="font-size: 12px; color: var(--text-muted);">@ ${m.company || 'Unknown Company'}</div>
                    <div style="font-size: 11px; color: var(--text-dim); margin-top: 4px;">${m.email}</div>
                  </div>
                `;
              }).join('')}
            </div>
            ${meetings.upcoming.length > 6 ? `<div style="margin-top: 12px; font-size: 12px; color: var(--text-dim);">+ ${meetings.upcoming.length - 6} more meetings scheduled</div>` : ''}
          </div>
        ` : '';
        
        content.innerHTML = `
          <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <div>
              <h1 class="page-title">📅 Bookings</h1>
              <p class="page-subtitle">Track meeting bookings and conversion rates</p>
            </div>
            <a href="https://supabase.com/dashboard/project/rwhqshjmngkyremwandx/editor/29369" target="_blank" style="font-size: 12px; color: var(--green); text-decoration: none; padding: 8px 14px; border: 1px solid var(--green); border-radius: 6px; display: flex; align-items: center; gap: 8px;" title="View curated_leads table in Supabase">
              <span style="font-size: 14px;">📊</span>
              <span style="display: flex; flex-direction: column; line-height: 1.3;">
                <span style="font-weight: 600;">curated_leads</span>
                <span style="font-size: 10px; opacity: 0.7;">${summary.total} rows · Supabase</span>
              </span>
            </a>
          </div>
          <div class="grid-2">
            ${upcomingHTML}
            
            <!-- Summary Cards -->
            <div class="summary-card" style="grid-column: span 2;">
              <h3 style="margin-bottom: 16px; font-size: 14px; color: var(--text-dim);">📊 BOOKING SUMMARY</h3>
              <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
                <div style="text-align: center;">
                  <div style="font-size: 36px; font-weight: 700; color: var(--green);">${summary.bookingRate}%</div>
                  <div style="font-size: 12px; color: var(--text-dim);">Booking Rate</div>
                </div>
                <div style="text-align: center;">
                  <div style="font-size: 36px; font-weight: 700; color: var(--green);">${summary.booked}</div>
                  <div style="font-size: 12px; color: var(--text-dim);">Booked</div>
                </div>
                <div style="text-align: center;">
                  <div style="font-size: 36px; font-weight: 700; color: var(--yellow);">${summary.scheduling}</div>
                  <div style="font-size: 12px; color: var(--text-dim);">Scheduling</div>
                </div>
                <div style="text-align: center;">
                  <div style="font-size: 36px; font-weight: 700; color: var(--red);">${summary.notBooked}</div>
                  <div style="font-size: 12px; color: var(--text-dim);">Not Booked</div>
                </div>
              </div>
            </div>
            
            <!-- Monthly Breakdown -->
            <div class="summary-card">
              <h3 style="margin-bottom: 16px; font-size: 14px; color: var(--text-dim);">📅 MONTHLY BOOKING RATE</h3>
              <table class="data-table" style="font-size: 13px;">
                <thead>
                  <tr>
                    <th>Month</th>
                    <th style="text-align: right;">Booked</th>
                    <th style="text-align: right;">Total</th>
                    <th style="text-align: right;">Rate</th>
                  </tr>
                </thead>
                <tbody>
                  ${monthlyBreakdown.map(m => `
                    <tr>
                      <td style="font-weight: 500;">${m.month}</td>
                      <td style="text-align: right; color: var(--green);">${m.booked}</td>
                      <td style="text-align: right;">${m.total}</td>
                      <td style="text-align: right; font-weight: 600; color: ${parseFloat(m.rate) >= 40 ? 'var(--green)' : parseFloat(m.rate) >= 30 ? 'var(--yellow)' : 'var(--red)'};">${m.rate}%</td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
            
            <!-- Response Time Correlation -->
            <div class="summary-card" style="grid-column: span 2;">
              <h3 style="margin-bottom: 16px; font-size: 14px; color: var(--text-dim);">⚡ RESPONSE TIME vs BOOKING RATE <span style="font-weight: 400; color: var(--text-dim);">(${summary.withResponseTime} leads with data)</span></h3>
              <table class="data-table" style="font-size: 13px;">
                <thead>
                  <tr>
                    <th>Response Time</th>
                    <th style="text-align: right;">Replies</th>
                    <th style="text-align: right;">Booked</th>
                    <th style="text-align: right;">Rate</th>
                    <th style="width: 200px;">Distribution</th>
                  </tr>
                </thead>
                <tbody>
                  ${responseTimeCorrelation.map(r => `
                    <tr>
                      <td style="font-weight: 500;">${r.bucket}</td>
                      <td style="text-align: right;">${r.total}</td>
                      <td style="text-align: right; color: var(--green);">${r.booked}</td>
                      <td style="text-align: right; font-weight: 600; color: ${parseFloat(r.rate) >= 50 ? 'var(--green)' : parseFloat(r.rate) >= 25 ? 'var(--yellow)' : 'var(--red)'};">${r.rate}%</td>
                      <td>
                        <div style="background: var(--card-bg); height: 20px; border-radius: 4px; overflow: hidden;">
                          <div style="background: ${parseFloat(r.rate) >= 50 ? 'var(--green)' : parseFloat(r.rate) >= 25 ? 'var(--yellow)' : 'var(--red)'}; height: 100%; width: ${r.rate}%;"></div>
                        </div>
                      </td>
                    </tr>
                  `).join('')}
                </tbody>
              </table>
            </div>
            
            <!-- All Leads Table -->
            <div class="summary-card" style="grid-column: span 2;">
              <h3 style="margin-bottom: 16px; font-size: 14px; color: var(--text-dim);">📋 ALL LEADS (${leads.length})</h3>
              <div style="max-height: 400px; overflow-y: auto;">
                <table class="data-table" style="font-size: 12px;">
                  <thead style="position: sticky; top: 0; background: var(--card-bg);">
                    <tr>
                      <th>Status</th>
                      <th>Lead</th>
                      <th>Company</th>
                      <th>Month</th>
                      <th>Response</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${leads.slice(0, 100).map(l => `
                      <tr>
                        <td>
                          <span style="padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; background: ${l.status === 'Booked' ? 'var(--green-bg)' : l.status === 'Scheduling' ? 'var(--yellow-bg)' : 'var(--red-bg)'}; color: ${l.status === 'Booked' ? 'var(--green)' : l.status === 'Scheduling' ? 'var(--yellow)' : 'var(--red)'};">
                            ${l.status}
                          </span>
                        </td>
                        <td>
                          <div style="font-weight: 600;">${l.name || '-'}</div>
                          <div style="font-size: 11px; color: var(--text-dim);">${l.email}</div>
                        </td>
                        <td>${l.company || '-'}</td>
                        <td>${l.conversation_month || '-'} ${l.conversation_year || ''}</td>
                        <td>${l.response_time_seconds ? formatResponseTime(l.response_time_seconds) : '-'}</td>
                      </tr>
                    `).join('')}
                  </tbody>
