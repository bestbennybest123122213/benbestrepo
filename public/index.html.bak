    async function viewResearch(filename) {
      try {
        const company = filename.replace('-research.md', '');
        const res = await fetch('/api/research/' + company);
        const data = await res.json();
        if (data.error) throw new Error(data.error);
        document.getElementById('researchTitle').textContent = filename;
        document.getElementById('researchContent').textContent = data.content;
        document.getElementById('researchModal').style.display = 'flex';
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }
    
    function hideResearchModal() {
      document.getElementById('researchModal').style.display = 'none';
    }
    
    function formatResponseTime(seconds) {
      if (seconds < 60) return seconds + 's';
      if (seconds < 3600) return Math.round(seconds / 60) + 'm';
      if (seconds < 86400) return (seconds / 3600).toFixed(1) + 'h';
      return (seconds / 86400).toFixed(1) + 'd';
    }

    // Main render function
    function render() {
      const content = document.getElementById('mainContent');
      document.getElementById('currentView').textContent = currentView.charAt(0).toUpperCase() + currentView.slice(1).replace(/([A-Z])/g, ' $1');
      
      // Stop leads idle timer when navigating away
      if (currentView !== 'interestedLeads') {
        stopLeadsIdleTimer();
      }
      
      switch (currentView) {
        case 'landing': return; // Don't render over landing page
        case 'campaignAnalytics': content.innerHTML = renderCampaignAnalytics(); break;
        case 'campaigns': content.innerHTML = renderCampaigns(); break;
        case 'sequences': content.innerHTML = renderSequenceAnalysis(); break;
        case 'replies': renderReplies(); break;
        case 'replyAnalytics': renderReplyAnalytics(); break;
        case 'comparison': content.innerHTML = renderComparison(); break;
        case 'comparisons': content.innerHTML = renderComparisons(); break;
        case 'insights': content.innerHTML = renderInsights(); break;
        case 'domains': content.innerHTML = renderDomains(); break;
        case 'warmup': content.innerHTML = renderWarmup(); break;
        case 'trends': renderTrends(); break;
        case 'responseTimes': renderResponseTimes(); break;
        case 'deliverability': renderDeliverability(); break;
        case 'warmupCalendar': renderWarmupCalendar(); break;
        case 'insurancePool': renderInsurancePool(); break;
        case 'imannBookings': renderImannBookings(); break;
        case 'interestedLeads': renderInterestedLeads(); break;
        case 'staleLeads': renderStaleLeads(); break;
        case 'hotProspects': renderHotProspects(); break;
        case 'research': renderResearch(); break;
        case 'campaignHealth': renderCampaignHealth(); break;
        case 'volumeTracker': renderVolumeTracker(); break;
        case 'verify': content.innerHTML = renderVerify(); break;
        default: content.innerHTML = renderCampaigns();
      }
    }

    // Sort handler
    function sortBy(column) {
      if (sortColumn === column) {
        sortDir *= -1;
      } else {
        sortColumn = column;
        sortDir = -1;
      }
      render();
    }

    // Search handler
    function handleSearch(value) {
      searchFilter = value;
      render();
    }

    // Sidebar navigation with page persistence
    const SESSION_TIMEOUT = 1 * 60 * 60 * 1000; // 1 hour
    
    function savePageState() {
      localStorage.setItem('gex_currentView', currentView);
      localStorage.setItem('gex_lastVisit', Date.now().toString());
    }
    
    function restorePageState() {
      const lastView = localStorage.getItem('gex_currentView');
      const lastVisit = parseInt(localStorage.getItem('gex_lastVisit') || '0');
      const timeSinceLastVisit = Date.now() - lastVisit;
      
      if (lastView && timeSinceLastVisit < SESSION_TIMEOUT) {
        // Quick refresh - restore page
        currentView = lastView;
        document.querySelectorAll('.nav-item').forEach(i => {
          i.classList.toggle('active', i.dataset.view === currentView);
        });
        return true;
      }
      // New session - show landing page
      return false;
    }
    
    function showLandingPage() {
      currentView = 'landing';
      document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
      const content = document.getElementById('mainContent');
      content.innerHTML = `
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 70vh;">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
            <div style="width: 64px; height: 64px; border-radius: 10px; overflow: hidden;"><img src="bull-logo.jpg?v=2" alt="BULL OS" style="width: 100%; height: 100%; object-fit: cover;"></div>
            <h1 style="font-size: 32px; color: var(--text); margin: 0;">BULL OS</h1>
          </div>
          <p style="color: var(--text-muted); margin-bottom: 40px;">Select a view to get started</p>
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 600px;">
            <button class="landing-btn" onclick="navigateTo('responseTimes')">📊 Response Times</button>
            <button class="landing-btn" onclick="navigateTo('interestedLeads')">🎯 Interested Leads</button>
            <button class="landing-btn" onclick="navigateTo('imannBookings')">📅 Bookings</button>
            <button class="landing-btn" onclick="navigateTo('staleLeads')">🔥 Stale Leads</button>
            <button class="landing-btn" onclick="navigateTo('campaignAnalytics')">📈 Campaign Analytics</button>
            <button class="landing-btn" onclick="navigateTo('domains')">🌐 Domain Health</button>
          </div>
        </div>
        <style>
          .landing-btn {
            background: var(--bg-card); border: 1px solid var(--border); color: var(--text);
            padding: 24px 20px; border-radius: 12px; font-size: 16px; cursor: pointer;
            transition: all 0.2s; text-align: center;
          }
          .landing-btn:hover { background: var(--bg-hover); border-color: var(--accent); transform: translateY(-2px); }
        </style>
      `;
      document.getElementById('currentView').textContent = 'Welcome';
    }
    
    function navigateTo(view) {
      currentView = view;
      document.querySelectorAll('.nav-item').forEach(i => {
        i.classList.toggle('active', i.dataset.view === view);
      });
      savePageState();
      render();
    }
    
    document.querySelectorAll('.nav-item').forEach(item => {
      item.addEventListener('click', () => {
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
        item.classList.add('active');
        currentView = item.dataset.view;
        savePageState();
        render();
      });
    });

    // Load dashboard data
    async function loadDashboard(force = false) {
      const btn = document.getElementById('refreshBtn');
      btn.disabled = true;
      btn.innerHTML = '<span>⏳</span> Loading...';
      
      // Show loading state immediately
      document.getElementById('mainContent').innerHTML = `
        <div style="padding: 40px; text-align: center;">
          <div class="spinner" style="margin: 0 auto 20px;"></div>
          <p style="color: var(--text-muted);">Loading dashboard data from SmartLead...</p>
          <p style="font-size: 12px; color: var(--text-dim); margin-top: 8px;">First load takes ~10 seconds</p>
        </div>
      `;

      try {
        const url = force ? '/api/dashboard?force=true' : '/api/dashboard';
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 60000); // 60s timeout
        
        const res = await fetch(url, { signal: controller.signal });
        clearTimeout(timeoutId);
        
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        data = await res.json();

        // Cache indicator
        const cacheStatus = document.getElementById('cacheStatus');
        if (data._fromCache) {
          cacheStatus.textContent = `⚡ Cached (${data._cacheAge}s ago)`;
          cacheStatus.style.display = 'inline-flex';
        } else {
          cacheStatus.style.display = 'none';
        }

        render();
      } catch (err) {
        const msg = err.name === 'AbortError' ? 'Request timed out (60s). Try again.' : err.message;
        document.getElementById('mainContent').innerHTML = `
          <div style="padding: 20px; background: var(--red-bg); border: 1px solid var(--red); border-radius: 8px; color: var(--red);">
            <strong>Error:</strong> ${msg}
            <br><br>
            <button class="btn btn-primary" onclick="loadDashboard(true)">Retry</button>
          </div>
        `;
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<span>↻</span> Force Refresh';
      }
    }

    // Load warmup data (with optional force refresh)
    async function loadWarmup(force = false) {
      try {
        const url = force ? '/api/warmup?force=true' : '/api/warmup';
        console.log(`[WARMUP] Loading${force ? ' (force refresh)' : ''}...`);
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        warmupData = await res.json();
        console.log('[WARMUP] Loaded:', warmupData.domainHealth?.length, 'domains');
        if (currentView === 'domains' || currentView === 'warmup' || currentView === 'comparison') render();
      } catch (err) {
        console.error('Warmup load failed:', err);
      }
    }

    // Load sequence analysis data
    async function loadSequenceData(force = false) {
      const content = document.getElementById('mainContent');
      
      // Show loading state
      content.innerHTML = `
        <div class="page-header">
          <div>
            <h1 class="page-title">📊 Sequence Analysis</h1>
            <p class="page-subtitle">Loading sequence data...</p>
          </div>
        </div>
        <div class="loading-overlay">
          <div style="text-align: center;">
            <div class="spinner"></div>
            <p style="margin-top: 16px; color: var(--text-muted);">Fetching statistics for all campaigns...</p>
            <p style="font-size: 12px; color: var(--text-dim);">This may take a minute.</p>
          </div>
        </div>
      `;

      try {
        const url = force ? '/api/sequence-analysis?force=true' : '/api/sequence-analysis';
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        sequenceData = await res.json();
        render();
      } catch (err) {
        console.error('Sequence analysis load failed:', err);
        content.innerHTML = `
          <div class="page-header">
            <div>
              <h1 class="page-title">📊 Sequence Analysis</h1>
              <p class="page-subtitle">Error loading data</p>
            </div>
          </div>
          <div style="padding: 20px; background: var(--red-bg); border: 1px solid var(--red); border-radius: 8px; color: var(--red);">
            <strong>Error:</strong> ${err.message}
            <br><br>
            <button class="btn btn-primary" onclick="loadSequenceData(true)">Try Again</button>
          </div>
        `;
      }
    }

    // Run verification
    async function runVerify() {
      const results = document.getElementById('verifyResults');
      results.innerHTML = '<div class="spinner" style="width: 24px; height: 24px;"></div>';

      try {
        const res = await fetch('/api/verify');
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const result = await res.json();

        const verifyStatus = document.getElementById('verifyStatus');
        if (result.verified) {
          verifyStatus.className = 'status-badge status-success';
          verifyStatus.textContent = '✓ Verified';
          verifyStatus.style.display = 'inline-flex';
          results.innerHTML = `
            <div style="padding: 12px; background: var(--green-bg); border-radius: 6px; color: var(--green);">
              ✓ All ${result.checksPerformed} checks passed! Data matches SmartLead API exactly.
            </div>
          `;
        } else if (result.status === 'no_cache') {
          verifyStatus.className = 'status-badge status-warning';
          verifyStatus.textContent = '⚠ Load data first';
          verifyStatus.style.display = 'inline-flex';
          results.innerHTML = `
            <div style="padding: 12px; background: var(--yellow-bg); border-radius: 6px; color: var(--yellow);">
              ⚠ Load dashboard data first, then verify.
            </div>
          `;
        } else {
          verifyStatus.className = 'status-badge status-error';
          verifyStatus.textContent = `⚠ ${result.discrepancies?.length || 0} issues`;
          verifyStatus.style.display = 'inline-flex';
          results.innerHTML = `
            <div style="padding: 12px; background: var(--red-bg); border-radius: 6px; color: var(--red);">
              <strong>⚠ ${result.discrepancies?.length || 0} discrepancies found:</strong>
              <ul style="margin: 8px 0 0 16px;">
                ${(result.discrepancies || []).map(d => `
                  <li>${d.metric}: SmartLead=${d.smartlead}, Dashboard=${d.dashboard} (diff: ${d.diff})</li>
                `).join('')}
              </ul>
              <p style="margin-top: 8px; font-size: 11px;">Try force refresh to sync data.</p>
            </div>
          `;
        }
      } catch (err) {
        results.innerHTML = `
          <div style="padding: 12px; background: var(--red-bg); border-radius: 6px; color: var(--red);">
            Error: ${err.message}
          </div>
        `;
      }
    }

    // Initial load
    // ==========================================
    // TOAST NOTIFICATION SYSTEM
    // ==========================================
    function showToast(message, type = 'info', duration = 4000) {
      let container = document.querySelector('.toast-container');
      if (!container) {
        container = document.createElement('div');
        container.className = 'toast-container';
        document.body.appendChild(container);
      }
      
      const toast = document.createElement('div');
      toast.className = `toast ${type}`;
      const icons = { success: '✓', error: '✕', warning: '⚠', info: 'ℹ' };
      toast.innerHTML = `<span>${icons[type] || 'ℹ'}</span><span>${message}</span>`;
      
      toast.onclick = () => {
        toast.classList.add('hide');
        setTimeout(() => toast.remove(), 300);
      };
      
      container.appendChild(toast);
      
      setTimeout(() => {
        if (toast.parentElement) {
          toast.classList.add('hide');
          setTimeout(() => toast.remove(), 300);
        }
      }, duration);
    }
    
    // Helper: format numbers with commas
    function formatNumber(num) {
      return new Intl.NumberFormat().format(num);
    }
    
    // Helper: format relative time
    function timeAgo(date) {
      const seconds = Math.floor((new Date() - new Date(date)) / 1000);
      if (seconds < 60) return 'just now';
      if (seconds < 3600) return Math.floor(seconds / 60) + 'm ago';
      if (seconds < 86400) return Math.floor(seconds / 3600) + 'h ago';
      return Math.floor(seconds / 86400) + 'd ago';
    }
    
    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      // ESC closes modals
      if (e.key === 'Escape') {
        document.querySelectorAll('[id$="Modal"]').forEach(modal => {
          if (modal.style.display !== 'none') modal.style.display = 'none';
        });
      }
      // R = refresh (when not typing)
      if (e.key === 'r' && !e.target.matches('input, textarea')) {
        e.preventDefault();
        loadDashboard(true);
        showToast('Refreshing data...', 'info');
      }
    });

    // Initial load - check for page persistence
    const restoredPage = restorePageState();
    if (restoredPage) {
      // Quick refresh - go to saved page
      loadDashboard();
    } else {
      // New session - show landing page first
      showLandingPage();
    }
    loadWarmup();
  </script>
  
  <!-- Data Sources Footer - HIDDEN (moved to toolbar) -->
  <div id="data-sources-footer" style="display: none; position: fixed; bottom: 0; right: 0; background: #1a1a1a; border: 1px solid #333; border-radius: 8px 0 0 0; padding: 12px 16px; font-size: 11px; z-index: 1000;">
    <div style="color: #888; margin-bottom: 8px; font-weight: 600;">📊 Data Sources (Supabase)</div>
    <div style="display: flex; flex-direction: column; gap: 4px;">
      <a href="https://supabase.com/dashboard/project/rwhqshjmngkyremwandx/editor/29369" target="_blank" style="color: #22c55e; text-decoration: none;">
        ✓ curated_leads (178 leads) - SINGLE SOURCE
      </a>
    </div>
    <div style="color: #555; margin-top: 8px; font-size: 10px;">
      All stats from curated_leads only
    </div>
  </div>
  
  <script src="/visualizations.js"></script>
  <script src="/quick-actions.js"></script>
  <script src="/stats-widgets.js"></script>
  <script src="/filters.js"></script>
  <script src="/notifications.js"></script>
  <script src="/theme-toggle.js"></script>
  <script src="/loading-states.js"></script>
  <script src="/quick-actions.js"></script>
  <script src="/keyboard-shortcuts.js"></script>
</body>
</html>
