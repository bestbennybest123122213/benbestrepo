      }
    }
    
    // Stale Leads Action Center
    async function renderStaleLeads() {
      const content = document.getElementById('mainContent');
      content.innerHTML = '<div class="loading-overlay"><div class="spinner"></div></div>';
      
      try {
        const res = await fetch('/api/stale-leads');
        const data = await res.json();
        
        if (data.error) throw new Error(data.error);
        
        const { total, leads, summary } = data;
        const { critical = 0, warm = 0, recent = 0 } = summary || {};
        
        content.innerHTML = `
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <div>
              <h2 style="margin: 0 0 8px 0; font-size: 24px;">🔥 Stale Leads Action Center</h2>
              <p style="color: var(--text-muted); margin: 0;">${total} leads need follow-up.</p>
            </div>
            <div style="font-size: 12px; color: var(--text-muted); padding: 8px 14px; border: 1px solid var(--border); border-radius: 6px; display: flex; align-items: center; gap: 8px;">
              <span style="font-size: 14px;">⚡</span>
              <span>SmartLead API · Live</span>
            </div>
          </div>
          
          <!-- Urgency Stats -->
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
            <div class="summary-card" style="text-align: center; padding: 20px; border-left: 4px solid var(--text-muted);">
              <div style="font-size: 36px; font-weight: 700;">${total}</div>
              <div style="font-size: 12px; color: var(--text-muted);">Total Stale</div>
            </div>
            <div class="summary-card" style="text-align: center; padding: 20px; border-left: 4px solid var(--red);">
              <div style="font-size: 36px; font-weight: 700; color: var(--red);">${critical}</div>
              <div style="font-size: 12px; color: var(--text-muted);">Critical (60+ days)</div>
            </div>
            <div class="summary-card" style="text-align: center; padding: 20px; border-left: 4px solid var(--yellow);">
              <div style="font-size: 36px; font-weight: 700; color: var(--yellow);">${warm}</div>
              <div style="font-size: 12px; color: var(--text-muted);">Warm (30-60 days)</div>
            </div>
          </div>
          
          <!-- Action Table -->
          <div class="summary-card">
            <div style="overflow-x: auto;">
              <table style="width: 100%;">
                <thead>
                  <tr>
                    <th>Urgency</th>
                    <th>Lead</th>
                    <th>Days Stale</th>
                    <th style="text-align: center;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  ${leads.map(l => {
                    const urgencyBadge = l.urgency === 'critical' 
                      ? '<span style="background: var(--red-bg); color: var(--red); padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600;">🔴 CRITICAL</span>'
                      : l.urgency === 'warm'
                      ? '<span style="background: var(--yellow-bg); color: var(--yellow); padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600;">🟠 WARM</span>'
                      : '<span style="background: var(--blue-bg); color: var(--blue); padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600;">🔵 RECENT</span>';
                    return `
                      <tr style="border-bottom: 1px solid var(--border);">
                        <td>${urgencyBadge}</td>
                        <td>
                          <div style="font-weight: 600;">${l.name || '-'}</div>
                          <div style="font-size: 11px; color: var(--text-dim);">${l.company || '-'} · ${l.email}</div>
                        </td>
                        <td style="font-weight: 600; color: ${l.days_stale >= 60 ? 'var(--red)' : l.days_stale >= 30 ? 'var(--yellow)' : 'var(--blue)'};">${l.days_stale}d</td>
                        <td style="text-align: center; white-space: nowrap;">
                          <button onclick="generateFollowUp('${l.email}')" class="btn btn-primary" style="padding: 4px 12px; font-size: 11px;">
                            ✉️ Generate Email
                          </button>
                          <button onclick="copyToClipboard('${l.email}')" class="btn btn-default" style="padding: 4px 8px; font-size: 11px;" title="Copy email">
                            📋
                          </button>
                        </td>
                      </tr>
                    `;
                  }).join('')}
                </tbody>
              </table>
            </div>
          </div>
          
          <!-- Email Preview Modal -->
          <div id="emailPreviewModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); z-index: 1000; align-items: center; justify-content: center;">
            <div style="background: #1e1e1e; border: 1px solid var(--border-light); border-radius: 12px; padding: 24px; width: 600px; max-width: 90vw; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.8);">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 style="margin: 0; font-size: 18px;">📧 Follow-Up Email</h3>
                <span id="emailUrgencyBadge"></span>
              </div>
              <div style="margin-bottom: 16px;">
                <label style="display: block; font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">TO</label>
                <div id="emailTo" style="background: var(--bg-dark); padding: 10px; border-radius: 6px; color: var(--text);"></div>
              </div>
              <div style="margin-bottom: 16px;">
                <label style="display: block; font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">SUBJECT</label>
                <input type="text" id="emailSubject" style="width: 100%; background: var(--bg-dark); padding: 10px; border: 1px solid var(--border); border-radius: 6px; color: var(--text);">
              </div>
              <div style="margin-bottom: 16px;">
                <label style="display: block; font-size: 11px; color: var(--text-muted); margin-bottom: 4px;">BODY</label>
                <textarea id="emailBody" rows="10" style="width: 100%; background: var(--bg-dark); padding: 10px; border: 1px solid var(--border); border-radius: 6px; color: var(--text); resize: vertical; font-family: inherit;"></textarea>
              </div>
              <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button class="btn btn-default" onclick="hideEmailPreview()">Cancel</button>
                <button class="btn btn-default" onclick="copySubject()">📋 Copy Subject</button>
                <button class="btn btn-primary" onclick="copyEmail()">📋 Copy Email Body</button>
              </div>
            </div>
          </div>
        `;
      } catch (err) {
        content.innerHTML = `<div class="summary-card" style="background: var(--red-bg);"><p style="color: var(--red);">Error: ${err.message}</p></div>`;
      }
    }
    
    async function generateFollowUp(email) {
      try {
        const res = await fetch('/api/generate-followup/' + encodeURIComponent(email));
        const data = await res.json();
        
        if (data.error) throw new Error(data.error);
        
        // Populate modal
        document.getElementById('emailTo').textContent = data.email + (data.name ? ' (' + data.name + ' @ ' + data.company + ')' : '');
        document.getElementById('emailSubject').value = data.subject;
        document.getElementById('emailBody').value = data.body;
        
        const urgencyBadge = data.urgency === 'critical' 
          ? '<span style="background: var(--red-bg); color: var(--red); padding: 4px 10px; border-radius: 4px; font-size: 12px;">🔴 ' + data.daysStale + ' days stale</span>'
          : data.urgency === 'warm'
          ? '<span style="background: var(--yellow-bg); color: var(--yellow); padding: 4px 10px; border-radius: 4px; font-size: 12px;">🟠 ' + data.daysStale + ' days stale</span>'
          : '<span style="background: var(--blue-bg); color: var(--blue); padding: 4px 10px; border-radius: 4px; font-size: 12px;">🔵 ' + data.daysStale + ' days stale</span>';
        document.getElementById('emailUrgencyBadge').innerHTML = urgencyBadge;
        
        // Show modal
        document.getElementById('emailPreviewModal').style.display = 'flex';
      } catch (err) {
        alert('Error generating email: ' + err.message);
      }
    }
    
    function hideEmailPreview() {
      document.getElementById('emailPreviewModal').style.display = 'none';
    }
    
    function copySubject() {
      const subject = document.getElementById('emailSubject').value;
      navigator.clipboard.writeText(subject).then(() => {
        const toast = document.createElement('div');
        toast.textContent = '✓ Subject copied!';
        toast.style.cssText = 'position: fixed; bottom: 20px; right: 20px; background: var(--green); color: #000; padding: 10px 16px; border-radius: 6px; font-size: 13px; z-index: 2000; animation: fadeOut 2s forwards;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
      });
    }
    
    function copyEmail() {
      const body = document.getElementById('emailBody').value;
      navigator.clipboard.writeText(body).then(() => {
        hideEmailPreview();
        const toast = document.createElement('div');
        toast.textContent = '✓ Email copied! Ready to paste in SmartLead';
        toast.style.cssText = 'position: fixed; bottom: 20px; right: 20px; background: var(--green); color: #000; padding: 10px 16px; border-radius: 6px; font-size: 13px; z-index: 2000; animation: fadeOut 2s forwards;';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
      });
    }
    
